          <svg width="18" height="18" viewBox="0 0 24 24" fill="#111" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {%- elsif i == npd_ceil and npd_has_half -%}
          <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="npdhalf"><stop offset="50%" stop-color="#111"/><stop offset="50%" stop-color="#ccc"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#npdhalf)"/></svg>
        {%- else -%}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#ccc" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {%- endif -%}
      {%- endfor -%}
    </span>
    <span class="npd-reviews__count">({{ npd_review_count }} Reviews)</span>
  </div>

  <h1 class="npd-title">{{ product.title | default: 'Creatine Gummies' }}</h1>

  <p class="npd-subtitle">Achieve Peak Performance</p>

  <div class="npd-tags">
    <span class="npd-tag">90 Gummies</span>
    <span class="npd-tag">1 Month Supply</span>
    <span class="npd-tag">Strawberry Flavour</span>
    <span class="npd-tag">Vegan</span>
    <span class="npd-tag">From £0.62 per day</span>
  </div>

  <a href="#sustainability" class="npd-badge">
    <span class="npd-badge__check">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </span>
    <span class="npd-badge__label">
      <span>Sustainability Claims</span>
      <small>PROVENANCE</small>
    </span>
    <span class="npd-badge__arrow">›</span>
  </a>

  <p class="npd-desc">Fuel your physical performance; with 5000mg of lab-verified, sugar-free creatine in each serving, formulated to meet the demands of high-intensity exercise. No mixing required, just take 3 gummies daily.</p>

</div>
