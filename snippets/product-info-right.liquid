<style>
  .npd-info { font-family: inherit; max-width: 640px; }

  /* 1. Reviews */
  .npd-reviews { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .npd-reviews__stars { display: inline-flex; gap: 1px; }
  .npd-reviews__count { font-size: 14px; color: #111; font-weight: 500; }

  /* 2. Heading */
  .npd-title { font-size: 42px; line-height: 1.05; font-weight: 800; color: #111; margin: 0 0 8px; letter-spacing: -0.5px; }

  /* 3. Subheading */
  .npd-subtitle { font-size: 22px; font-weight: 700; color: #111; margin: 0 0 20px; }

  /* 4. Five rounded boxes */
  .npd-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
  .npd-tag { border: 1px solid #e3e3e3; background: #fafafa; border-radius: 10px; padding: 10px 18px; font-size: 15px; font-weight: 600; color: #222; white-space: nowrap; }

  /* 5. Green clickable badge */
  .npd-badge { display: inline-flex; align-items: center; gap: 8px; background: #e8f3ec; color: #1c7c45; border: none; border-radius: 999px; padding: 8px 14px; font-size: 13px; font-weight: 700; text-decoration: none; cursor: pointer; margin-bottom: 22px; }
  .npd-badge:hover { background: #ddeee3; }
  .npd-badge__check { display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; background: #1c7c45; border-radius: 50%; }
  .npd-badge__label { display: flex; flex-direction: column; line-height: 1.1; text-align: left; }
  .npd-badge__label small { font-size: 10px; font-weight: 600; opacity: 0.75; letter-spacing: 0.04em; }
  .npd-badge__arrow { font-size: 14px; }

  /* 6. Description */
  .npd-desc { font-size: 17px; line-height: 1.6; color: #333; margin: 0; }

  @media (max-width: 749px) {
    .npd-title { font-size: 32px; }
    .npd-subtitle { font-size: 19px; }
  }
</style>

<div class="npd-info">

