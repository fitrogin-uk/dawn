{%- comment -%}
  Standalone Reviews Section
  Desktop: rating summary (left) + photo/review masonry grid (right)
  Mobile: rating summary stacked top + 2-col card grid
{%- endcomment -%}

{%- assign total_count = section.settings.review_count | plus: 0 -%}
{%- assign rating_val = section.settings.review_rating | times: 1.0 -%}

{%- comment -%} Tally star counts from blocks {%- endcomment -%}
{%- assign cnt5 = 0 -%}{%- assign cnt4 = 0 -%}{%- assign cnt3 = 0 -%}{%- assign cnt2 = 0 -%}{%- assign cnt1 = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'review' -%}
    {%- assign rv = block.settings.rating | times: 1.0 | round -%}
    {%- if rv == 5 -%}{%- assign cnt5 = cnt5 | plus: 1 -%}
    {%- elsif rv == 4 -%}{%- assign cnt4 = cnt4 | plus: 1 -%}
    {%- elsif rv == 3 -%}{%- assign cnt3 = cnt3 | plus: 1 -%}
    {%- elsif rv == 2 -%}{%- assign cnt2 = cnt2 | plus: 1 -%}
    {%- else -%}{%- assign cnt1 = cnt1 | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Use manual overrides if set {%- endcomment -%}
{%- if section.settings.count_5 != blank -%}{%- assign cnt5 = section.settings.count_5 | plus: 0 -%}{%- endif -%}
{%- if section.settings.count_4 != blank -%}{%- assign cnt4 = section.settings.count_4 | plus: 0 -%}{%- endif -%}
{%- if section.settings.count_3 != blank -%}{%- assign cnt3 = section.settings.count_3 | plus: 0 -%}{%- endif -%}
{%- if section.settings.count_2 != blank -%}{%- assign cnt2 = section.settings.count_2 | plus: 0 -%}{%- endif -%}
{%- if section.settings.count_1 != blank -%}{%- assign cnt1 = section.settings.count_1 | plus: 0 -%}{%- endif -%}

{%- assign bar_total = cnt5 | plus: cnt4 | plus: cnt3 | plus: cnt2 | plus: cnt1 -%}
{%- if bar_total == 0 -%}{%- assign bar_total = 1 -%}{%- endif -%}

<style>
  .rs { font-family: inherit; }
  .section-reviews { padding-left: 0 !important; padding-right: 0 !important; }
  .rs__inner { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px; }

  /* Desktop layout: full width stacked */
  .rs__layout { display: block; }
  .rs__summary { display: none; }

  /* Desktop header bar */
  .rs__desk-header { margin-bottom: 6px; padding: 0 10px; }
  .rs__desk-title { font-size: 38px; font-weight: 800; color: #111; margin: 0 0 10px; display: flex; align-items: center; gap: 16px; }
  .rs__desk-title::after { content: ''; flex: 1; height: 1px; background: #e0e0e0; }
  .rs__mob-heading { display: flex; align-items: center; gap: 12px; }
  .rs__mob-heading::after { content: ''; flex: 1; height: 1px; background: #e0e0e0; }
  .rs__desk-meta-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .rs__desk-meta-left { display: flex; flex-direction: column; gap: 2px; }
  .rs__desk-rating-row { display: flex; align-items: center; gap: 8px; }
  .rs__desk-rating-num { font-size: 18px; font-weight: 700; color: #111; }
  .rs__desk-rating-stars { display: flex; gap: 2px; }
  .rs__desk-based { font-size: 13px; color: #666; }
  .rs__desk-write { background: #111; color: #fff; border: none; border-radius: 999px; padding: 12px 28px; font-size: 15px; font-weight: 700; cursor: pointer; }
  .rs__desk-write:hover { opacity: 0.85; }
  .rs__filter-btn { background: #111; color: #fff; border: none; border-radius: 999px; padding: 12px 20px; font-size: 15px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
  .rs__filter-btn:hover { opacity: 0.85; }

  /* Grid */
  .rs__grid-header { display: none; }

  /* Carousel */
  .rs__carousel { position: relative; }
  .rs__carousel-nav { display: flex; gap: 8px; margin-top: 14px; justify-content: center; padding: 0 10px; }
  .rs__carousel-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #333; }
  .rs__carousel-btn:hover { background: #f5f5f5; }
  .rs__carousel-btn:disabled { opacity: 0.3; cursor: default; }
  .rs__photos { display: flex; gap: 6px; overflow-x: auto; overflow-y: visible; padding: 4px 10px 10px; scroll-behavior: smooth; align-items: flex-start; scrollbar-width: none; }
  .rs__photos::-webkit-scrollbar { display: none; }
  .rs__card { flex: 0 0 253px; background: #f4f4f4; border-radius: 12px; overflow: hidden; border: 1px solid #ebebeb; cursor: pointer; position: relative; align-self: flex-start; }
  .rs__card.rs__card--hidden { display: none; }
  /* Stacked column: two text-only cards vertically */
  .rs__col { flex: 0 0 253px; display: flex; flex-direction: column; gap: 6px; align-self: flex-start; }
  .rs__col .rs__card { flex: 0 0 auto; width: 100%; }
  @media (max-width: 749px) {
    .rs__card { flex: 0 0 160px; }
    .rs__col { flex: 0 0 160px; }
  }

  /* Filter dropdown */
  .rs__filter-dropdown { position: absolute; top: calc(100% + 6px); right: 0; background: #fff; border: 1px solid #e0e0e0; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); z-index: 100; min-width: 200px; padding: 12px 0; display: none; }
  .rs__filter-dropdown.is-open { display: block; }
  .rs__filter-section-label { padding: 4px 16px 8px; font-size: 13px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.04em; }
  .rs__filter-option { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; font-size: 14px; color: #111; cursor: pointer; }
  .rs__filter-option:hover { background: #f5f5f5; }
  .rs__filter-option.is-active { font-weight: 700; }
  .rs__filter-option .rs__check { visibility: hidden; font-size: 14px; }
  .rs__filter-option.is-active .rs__check { visibility: visible; }
  .rs__filter-divider { height: 1px; background: #e8e8e8; margin: 10px 0; }
  .rs__filter-breakdown { padding: 4px 16px 4px; }
  .rs__filter-breakdown-row { display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 13px; color: #444; }
  .rs__filter-breakdown-stars { display: flex; gap: 2px; }
  .rs__filter-breakdown-count { margin-left: auto; font-weight: 600; color: #111; }
  .rs__filter-wrap { position: relative; }
  .rs__card-img { position: relative; }
  .rs__card-img img { width: 100%; height: auto; display: block; object-fit: cover; }
  .rs__card-img video { width: 100%; height: auto; display: block; object-fit: cover; max-height: 320px; }
  .rs__card-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .rs__card-play-btn { width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center; }
  .rs__card-multi { position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,0.55); color: #fff; border-radius: 6px; padding: 3px 7px; font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 3px; }
  .rs__card-body { padding: 10px 12px 12px; }
  .rs__card-name { font-weight: 700; font-size: 21px; color: #111; display: flex; align-items: center; gap: 5px; margin-bottom: 4px; }
  .rs__card-verified svg { flex-shrink: 0; }
  .rs__card-stars { display: flex; gap: 2px; margin-bottom: 6px; }
  .rs__card-text { font-size: 16px; color: #444; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; word-break: break-word; overflow-wrap: break-word; }
  .rs__card-text.is-expanded { display: block; word-break: break-word; overflow-wrap: break-word; }
  .rs__card-text-more { font-size: 12px; font-weight: 600; color: #111; cursor: pointer; margin-top: 4px; display: inline-block; text-decoration: underline; }
  .rs__card-meta { font-size: 12px; color: #999; margin-top: 4px; display: flex; flex-direction: column; gap: 1px; }
  .rs__card-reply { margin-top: 10px; padding: 10px 12px; background: #fff; border-left: 3px solid #111; border-radius: 6px; }
  .rs__card-reply-author { font-size: 11px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
  .rs__card-reply-text { font-size: 13px; color: #444; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rs__card-reply-text.is-expanded { display: block; }
  .rs__card-reply-more { font-size: 12px; font-weight: 600; color: #111; cursor: pointer; margin-top: 4px; display: inline-block; text-decoration: underline; }
  .rs__card-meta-loc { line-height: 1.4; }
  .rs__card-meta-date { line-height: 1.4; }

  /* Lightbox */
  .rs__lb { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.82); z-index: 9200; align-items: center; justify-content: center; padding: 20px; }
  .rs__lb.is-open { display: flex; }
  .rs__lb-inner { display: flex; background: #fff; border-radius: 16px; overflow: hidden; width: 100%; max-width: 880px; max-height: 90vh; }
  .rs__lb-media { flex: 0 0 50%; background: #111; display: flex; align-items: center; justify-content: center; position: relative; }
  .rs__lb-media img, .rs__lb-media video { width: 100%; height: 100%; object-fit: cover; display: block; max-height: 90vh; }
  .rs__lb-side { flex: 1; display: flex; flex-direction: column; padding: 22px 26px 26px; overflow-y: auto; min-width: 0; }
  .rs__lb-controls { display: flex; align-items: center; gap: 8px; margin-bottom: 18px; }
  .rs__lb-btn { width: 34px; height: 34px; border-radius: 50%; border: 1px solid #e0e0e0; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #333; }
  .rs__lb-btn:hover { background: #f5f5f5; }
  .rs__lb-close-btn { margin-left: auto; }
  .rs__lb-rev-name { font-size: 16px; font-weight: 700; color: #111; margin-bottom: 4px; display: flex; align-items: center; gap: 6px; }
  .rs__lb-rev-stars { display: flex; gap: 2px; margin-bottom: 8px; }
  .rs__lb-rev-title { font-size: 14px; font-weight: 700; color: #111; margin-bottom: 6px; }
  .rs__lb-rev-text { font-size: 14px; color: #444; line-height: 1.55; margin-bottom: 8px; }
  .rs__lb-rev-meta { font-size: 12px; color: #999; margin-bottom: 16px; }
  .rs__lb-product { border: 1px solid #eee; border-radius: 12px; padding: 14px; display: flex; align-items: center; gap: 12px; margin-top: auto; }
  .rs__lb-product img { width: 56px; height: 56px; object-fit: contain; border-radius: 8px; flex-shrink: 0; }
  .rs__lb-product-info { flex: 1; min-width: 0; }
  .rs__lb-product-name { font-size: 13px; font-weight: 600; color: #111; }
  .rs__lb-buy { background: #111; color: #fff; border: none; border-radius: 999px; padding: 8px 18px; font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-block; margin-top: 6px; }
  .rs__lb-buy:hover { opacity: 0.85; }

  /* ---- Write review modal ---- */
  .rs__wr-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 9300; align-items: center; justify-content: center; padding: 20px; }
  .rs__wr-overlay.is-open { display: flex; }
  .rs__wr-wrap { position: relative; width: 100%; max-width: 520px; }
  .rs__wr-modal { background: #fff; border-radius: 16px; padding: 28px; width: 100%; max-height: 90vh; overflow-y: auto; }
  .rs__wr-title { font-size: 20px; font-weight: 800; color: #111; margin: 0 0 20px; }
  .rs__wr-close { position: absolute; top: -12px; right: -12px; width: 32px; height: 32px; border-radius: 50%; background: #000; border: none; cursor: pointer; color: #fff; font-size: 14px; display: flex; align-items: center; justify-content: center; }
  .rs__wr-label { font-size: 14px; font-weight: 600; color: #111; margin-bottom: 8px; display: block; }
  .rs__wr-stars { display: flex; gap: 6px; margin-bottom: 16px; cursor: pointer; }
  .rs__wr-stars svg { transition: transform 0.1s; }
  .rs__wr-stars svg:hover { transform: scale(1.15); }
  .rs__wr-input { width: 100%; border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; color: #111; box-sizing: border-box; font-family: inherit; margin-bottom: 14px; }
  .rs__wr-input:focus { outline: none; border-color: #111; }
  .rs__wr-textarea { width: 100%; border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; color: #111; box-sizing: border-box; font-family: inherit; resize: vertical; min-height: 90px; margin-bottom: 14px; }
  .rs__wr-textarea:focus { outline: none; border-color: #111; }
  .rs__wr-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px; }
  .rs__wr-row .rs__wr-input { margin-bottom: 0; }
  .rs__wr-actions { display: flex; justify-content: flex-end; gap: 10px; }
  .rs__wr-cancel { background: none; border: 1px solid #ddd; border-radius: 999px; padding: 10px 22px; font-size: 14px; font-weight: 600; cursor: pointer; color: #333; }
  .rs__wr-submit { background: #111; color: #fff; border: none; border-radius: 999px; padding: 10px 22px; font-size: 14px; font-weight: 700; cursor: pointer; }
  .rs__wr-thanks { display: none; text-align: center; padding: 20px 0 8px; }
  .rs__wr-thanks.is-shown { display: block; }
  .rs__wr-thanks h3 { font-size: 18px; font-weight: 700; color: #111; margin: 12px 0 6px; }
  .rs__wr-thanks p { font-size: 14px; color: #555; margin: 0; }

  /* Mobile-only elements hidden on desktop */
  .rs__mob-heading { display: none; }
  .rs__mob-rating-row { display: none; }
  .rs__mob-based { display: none; }
  .rs__mob-write { display: none; }
  .rs__mob-filter-row { display: none; }
  .rs__mob-actions { display: none; }

  /* ---- Mobile ---- */
  @media (max-width: 749px) {
    .rs__desk-header { display: none; }
    .rs__layout { display: block; }
    .rs__summary { display: none; }
    .rs__grid-header { display: none; }

    .rs__mob-heading { display: flex; font-size: 24px; font-weight: 800; color: #111; margin: 0 0 6px; padding: 0 10px; }
    .rs__mob-rating-row { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; padding: 0 10px; }
    .rs__mob-rating-num { font-size: 16px; font-weight: 700; color: #111; }
    .rs__mob-rating-stars { display: flex; gap: 2px; }
    .rs__mob-based { display: block; font-size: 13px; color: #555; margin-bottom: 14px; padding: 0 10px; }
    .rs__mob-actions { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; padding: 0 10px; }
    .rs__mob-write { display: block; flex: 1; background: #111; color: #fff; border: none; border-radius: 999px; padding: 14px; font-size: 16px; font-weight: 700; cursor: pointer; text-align: center; }
    .rs__mob-filter-row { display: flex; flex-shrink: 0; }
    .rs__filter-btn { background: #111; color: #fff; border: none; border-radius: 999px; padding: 14px 20px; font-size: 16px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }

    .rs__card-name { font-size: 16px; }
    .rs__card-text { font-size: 13px; }
    .rs__photos { padding: 0 10px 10px; }
    .rs__lb-inner { flex-direction: column; max-height: 95vh; }
    .rs__lb-media { flex: 0 0 220px; max-height: 220px; }
    .rs__lb-side { padding: 16px 18px 20px; }
    .rs__wr-row { grid-template-columns: 1fr; }
  }

</style>

<div class="rs">
  <div class="rs__inner">

    {%- assign hdr_floor = rating_val | floor -%}
    {%- assign hdr_ceil = rating_val | ceil -%}

    {%- comment -%} ===== DESKTOP HEADER (hidden on mobile) ===== {%- endcomment -%}
    <div class="rs__desk-header">
      <h2 class="rs__desk-title">Reviews</h2>
      <div class="rs__desk-meta-row">
        <div class="rs__desk-meta-left">
          <div class="rs__desk-rating-row">
            <span class="rs__desk-rating-num">{{ section.settings.review_rating }}</span>
            <div class="rs__desk-rating-stars">
              {%- for i in (1..5) -%}
                {%- if i <= hdr_floor -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="#111"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {%- elsif i == hdr_ceil and hdr_ceil != hdr_floor -%}
                  <svg width="20" height="20" viewBox="0 0 24 24"><defs><linearGradient id="dskhalf{{ section.id }}"><stop offset="60%" stop-color="#111"/><stop offset="60%" stop-color="#e0e0e0"/></linearGradient></defs><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="url(#dskhalf{{ section.id }})"/></svg>
                {%- else -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="#e0e0e0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
          <div class="rs__desk-based">Based on {{ section.settings.review_count }} reviews</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
          <button class="rs__desk-write" type="button" data-rs-open-write>Write Review</button>
          <div class="rs__filter-wrap">
            <button class="rs__filter-btn" type="button" data-rs-filter-toggle>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
              Filter
            </button>
            <div class="rs__filter-dropdown" id="rsFilterDrop-{{ section.id }}">
              <div class="rs__filter-section-label">Order By</div>
              <div class="rs__filter-option is-active" data-rs-sort="default"><span>All rating</span><span class="rs__check">✓</span></div>
              <div class="rs__filter-option" data-rs-sort="lowest"><span>Lowest rating</span><span class="rs__check">✓</span></div>
              <div class="rs__filter-option" data-rs-sort="highest"><span>Highest Rating</span><span class="rs__check">✓</span></div>
              {%- if section.settings.count_5 != blank or section.settings.count_4 != blank or section.settings.count_3 != blank or section.settings.count_2 != blank or section.settings.count_1 != blank -%}
              <div class="rs__filter-divider"></div>
              <div class="rs__filter-section-label">Breakdown</div>
              <div class="rs__filter-breakdown">
                {%- for i in (1..5) -%}
                  {%- assign star_num = 6 | minus: i -%}
                  {%- assign count_key = 'count_' | append: star_num -%}
                  {%- assign star_count = section.settings[count_key] -%}
                  {%- if star_count != blank -%}
                  <div class="rs__filter-breakdown-row">
                    <div class="rs__filter-breakdown-stars">
                      {%- for s in (1..5) -%}<svg width="13" height="13" viewBox="0 0 24 24"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" fill="{%- if s <= star_num -%}#111{%- else -%}#ddd{%- endif -%}" stroke="none"/></svg>{%- endfor -%}
                    </div>
                    <span class="rs__filter-breakdown-count">{{ star_count }}</span>
                  </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="rs__layout">
      <div class="rs__grid-col">

        {%- comment -%} Mobile-only summary header {%- endcomment -%}
        <h2 class="rs__mob-heading">Reviews</h2>
        <div class="rs__mob-rating-row">
          <span class="rs__mob-rating-num">{{ section.settings.review_rating }}</span>
          <div class="rs__mob-rating-stars">
            {%- for i in (1..5) -%}
              {%- if i <= hdr_floor -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#111"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {%- elsif i == hdr_ceil and hdr_ceil != hdr_floor -%}
                <svg width="16" height="16" viewBox="0 0 24 24"><defs><linearGradient id="mobhalf{{ section.id }}"><stop offset="60%" stop-color="#111"/><stop offset="60%" stop-color="#e0e0e0"/></linearGradient></defs><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="url(#mobhalf{{ section.id }})"/></svg>
              {%- else -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#e0e0e0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        <div class="rs__mob-based">Based on {{ section.settings.review_count }} reviews</div>
        <div class="rs__mob-actions">
          <button class="rs__mob-write" type="button" data-rs-open-write>Write Review</button>
          <div class="rs__filter-wrap">
            <button class="rs__filter-btn" type="button" data-rs-filter-toggle>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
              Filter
            </button>
            <div class="rs__filter-dropdown" id="rsFilterDropMob-{{ section.id }}">
              <div class="rs__filter-section-label">Order By</div>
              <div class="rs__filter-option is-active" data-rs-sort="default"><span>All rating</span><span class="rs__check">✓</span></div>
              <div class="rs__filter-option" data-rs-sort="lowest"><span>Lowest rating</span><span class="rs__check">✓</span></div>
              <div class="rs__filter-option" data-rs-sort="highest"><span>Highest Rating</span><span class="rs__check">✓</span></div>
              {%- if section.settings.count_5 != blank or section.settings.count_4 != blank or section.settings.count_3 != blank or section.settings.count_2 != blank or section.settings.count_1 != blank -%}
              <div class="rs__filter-divider"></div>
              <div class="rs__filter-section-label">Breakdown</div>
              <div class="rs__filter-breakdown">
                {%- for i in (1..5) -%}
                  {%- assign star_num = 6 | minus: i -%}
                  {%- assign count_key = 'count_' | append: star_num -%}
                  {%- assign star_count = section.settings[count_key] -%}
                  {%- if star_count != blank -%}
                  <div class="rs__filter-breakdown-row">
                    <div class="rs__filter-breakdown-stars">
                      {%- for s in (1..5) -%}<svg width="13" height="13" viewBox="0 0 24 24"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" fill="{%- if s <= star_num -%}#111{%- else -%}#ddd{%- endif -%}" stroke="none"/></svg>{%- endfor -%}
                    </div>
                    <span class="rs__filter-breakdown-count">{{ star_count }}</span>
                  </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- endif -%}
            </div>
          </div>
        </div>

        <div class="rs__carousel">
        <div class="rs__photos" id="rsPhotoGrid-{{ section.id }}">
          {%- assign card_idx = 0 -%}
          {%- assign pair_pending = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- assign rv_f = block.settings.rating | times: 1.0 -%}
              {%- assign rv_floor = rv_f | floor -%}
              {%- assign rv_ceil = rv_f | ceil -%}
              {%- assign is_small = true -%}
              {%- if block.settings.photo != blank or block.settings.video_url != blank -%}
                {%- assign is_small = false -%}
              {%- endif -%}

              {%- capture card_html -%}
                <div class="rs__card"
                  data-rs-card="{{ card_idx }}"
                  data-rs-src="{% if block.settings.photo != blank %}{{ block.settings.photo | image_url: width: 1200 }}{% endif %}"
                  data-rs-video="{% if block.settings.video_url != blank %}{{ block.settings.video_url }}{% endif %}"
                  data-rs-name="{{ block.settings.reviewer_name | escape }}"
                  data-rs-rating="{{ block.settings.rating }}"
                  data-rs-title="{{ block.settings.review_title | escape }}"
                  data-rs-text="{{ block.settings.review_text | escape }}"
                  data-rs-date="{{ block.settings.review_date | escape }}"
                  data-rs-verified="{{ block.settings.verified }}"
                  {{ block.shopify_attributes }}>
                  {%- if block.settings.photo != blank -%}
                    <div class="rs__card-img">
                      {{ block.settings.photo | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.reviewer_name }}
                      {%- if block.settings.video_url != blank -%}<div class="rs__card-multi"><svg width="10" height="10" viewBox="0 0 24 24" fill="#fff"><path d="M1 4l14 8-14 8V4z"/></svg>+1</div>{%- endif -%}
                    </div>
                  {%- elsif block.settings.video_url != blank -%}
                    <div class="rs__card-img">
                      <video src="{{ block.settings.video_url }}" muted playsinline preload="none" {% if block.settings.poster != blank %}poster="{{ block.settings.poster | image_url: width: 400 }}"{% endif %} style="max-height:220px;"></video>
                      <div class="rs__card-play"><div class="rs__card-play-btn"><svg width="14" height="16" viewBox="0 0 16 18" fill="#111"><path d="M1 1l14 8-14 8V1z"/></svg></div></div>
                    </div>
                  {%- endif -%}
                  <div class="rs__card-body">
                    <div class="rs__card-name">
                      {{ block.settings.reviewer_name }}
                      {%- if block.settings.verified -%}<span class="rs__card-verified"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#111111"/><polyline points="8 12 11 15 16 9" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>{%- endif -%}
                    </div>
                    <div class="rs__card-stars">
                      {%- for j in (1..5) -%}
                        {%- if j <= rv_floor -%}<svg width="13" height="13" viewBox="0 0 24 24" fill="#111"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        {%- elsif j == rv_ceil and rv_ceil != rv_floor -%}<svg width="13" height="13" viewBox="0 0 24 24"><defs><linearGradient id="rch{{ block.id }}"><stop offset="55%" stop-color="#111"/><stop offset="55%" stop-color="#e0e0e0"/></linearGradient></defs><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="url(#rch{{ block.id }})"/></svg>
                        {%- else -%}<svg width="13" height="13" viewBox="0 0 24 24" fill="#e0e0e0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>{%- endif -%}
                      {%- endfor -%}
                    </div>
                    <div class="rs__card-text" data-rs-review-text>{{ block.settings.review_text }}</div>
                    <span class="rs__card-text-more" data-rs-text-more>Read more</span>
                    {%- if block.settings.reviewer_location != blank or block.settings.review_date != blank -%}
                      <div class="rs__card-meta">{%- if block.settings.reviewer_location != blank -%}<span class="rs__card-meta-loc">{{ block.settings.reviewer_location }}</span>{%- endif -%}{%- if block.settings.review_date != blank -%}<span class="rs__card-meta-date">{{ block.settings.review_date }}</span>{%- endif -%}</div>
                    {%- endif -%}
                    {%- if block.settings.reply_text != blank -%}
                      <div class="rs__card-reply">
                        <div class="rs__card-reply-author">{{ block.settings.reply_name | default: 'Brand' }}</div>
                        <div class="rs__card-reply-text">{{ block.settings.reply_text }}</div>
                        <span class="rs__card-reply-more" data-rs-reply-more>Read more</span>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endcapture -%}

              {%- if is_small -%}
                {%- if pair_pending -%}
                  {{ pair_first_html }}
                  {{ card_html }}
                  </div>{%- comment -%}close rs__col{%- endcomment -%}
                  {%- assign pair_pending = false -%}
                {%- else -%}
                  {%- comment -%} peek ahead: if next review block is also small, open a col {%- endcomment -%}
                  {%- assign next_is_small = false -%}
                  {%- assign look_idx = forloop.index -%}
                  {%- for nb in section.blocks offset: look_idx -%}
                    {%- if nb.type == 'review' -%}
                      {%- if nb.settings.photo == blank and nb.settings.video_url == blank -%}
                        {%- assign next_is_small = true -%}
                      {%- endif -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if next_is_small -%}
                    <div class="rs__col">
                    {%- assign pair_first_html = card_html -%}
                    {%- assign pair_pending = true -%}
                  {%- else -%}
                    {{ card_html }}
                  {%- endif -%}
                {%- endif -%}
              {%- else -%}
                {%- if pair_pending -%}
                  {{ pair_first_html }}
                  </div>
                  {%- assign pair_pending = false -%}
                {%- endif -%}
                {{ card_html }}
              {%- endif -%}
              {%- assign card_idx = card_idx | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if pair_pending -%}{{ pair_first_html }}</div>{%- endif -%}
        </div>
          <div class="rs__carousel-nav">
            <button class="rs__carousel-btn" id="rsCarPrev-{{ section.id }}" aria-label="Previous">
              <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7l6 6" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="rs__carousel-btn" id="rsCarNext-{{ section.id }}" aria-label="Next">
              <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>{%- comment -%} end rs__carousel {%- endcomment -%}
      </div>

    </div>
  </div>
</div>

{%- comment -%} ===== LIGHTBOX ===== {%- endcomment -%}
<div class="rs__lb" id="rsLb-{{ section.id }}" role="dialog" aria-modal="true">
  <div class="rs__lb-inner">
    <div class="rs__lb-media" id="rsLbMedia-{{ section.id }}">
      <img src="" alt="" id="rsLbImg-{{ section.id }}" style="display:none;">
      <video id="rsLbVid-{{ section.id }}" muted playsinline controls style="display:none;"></video>
    </div>
    <div class="rs__lb-side">
      <div class="rs__lb-controls">
        <button class="rs__lb-btn" id="rsLbPrev-{{ section.id }}" aria-label="Previous">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7l6 6" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="rs__lb-btn" id="rsLbNext-{{ section.id }}" aria-label="Next">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="rs__lb-btn rs__lb-close-btn" id="rsLbClose-{{ section.id }}" aria-label="Close">&#x2715;</button>
      </div>
      <div id="rsLbInfo-{{ section.id }}">
        <div class="rs__lb-rev-name" id="rsLbName-{{ section.id }}"></div>
        <div class="rs__lb-rev-stars" id="rsLbStars-{{ section.id }}"></div>
        <div class="rs__lb-rev-title" id="rsLbTitle-{{ section.id }}"></div>
        <div class="rs__lb-rev-text" id="rsLbText-{{ section.id }}"></div>
        <div class="rs__lb-rev-meta" id="rsLbMeta-{{ section.id }}"></div>
      </div>
      <div class="rs__lb-product">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title }}">
        {%- endif -%}
        <div class="rs__lb-product-info">
          <div class="rs__lb-product-name">{{ product.title }}</div>
          <a href="{{ product.url }}" class="rs__lb-buy">Buy Now</a>
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} ===== WRITE REVIEW MODAL ===== {%- endcomment -%}
<div class="rs__wr-overlay" id="rsWrOverlay-{{ section.id }}">
  <div class="rs__wr-wrap">
    <button class="rs__wr-close" data-rs-close-write aria-label="Close">&#x2715;</button>
    <div class="rs__wr-modal">
      <div class="rs__wr-thanks" id="rsWrThanks-{{ section.id }}">
        <svg width="56" height="56" viewBox="0 0 80 80" fill="none"><circle cx="40" cy="40" r="38" stroke="#e0e0e0" stroke-width="2"/><circle cx="55" cy="55" r="13" fill="#1a9e47"/><polyline points="49 55 53 59 61 51" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Thank you for your review!</h3>
        <p>Your review has been submitted and is pending approval.</p>
      </div>
      <div id="rsWrForm-{{ section.id }}">
        <h3 class="rs__wr-title">Write a Review</h3>
        <label class="rs__wr-label">Your rating <span style="color:#e53">(required)</span></label>
        <div class="rs__wr-stars" id="rsWrStars-{{ section.id }}">
          {%- for i in (1..5) -%}
            <svg width="28" height="28" viewBox="0 0 24 24" data-rs-wstar="{{ i }}" fill="#e0e0e0" stroke="#ccc" stroke-width="0.8" style="cursor:pointer"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          {%- endfor -%}
        </div>
        <label class="rs__wr-label">Your feedback <span style="color:#e53">(required)</span></label>
        <textarea class="rs__wr-textarea" id="rsWrText-{{ section.id }}" placeholder="Share your experience..."></textarea>
        <div class="rs__wr-row">
          <div>
            <label class="rs__wr-label" style="margin-bottom:6px">Name <span style="color:#e53">(required)</span></label>
            <input class="rs__wr-input" type="text" id="rsWrName-{{ section.id }}" placeholder="Your name" style="margin-bottom:0">
          </div>
          <div>
            <label class="rs__wr-label" style="margin-bottom:6px">Email <span style="color:#e53">(required)</span></label>
            <input class="rs__wr-input" type="email" id="rsWrEmail-{{ section.id }}" placeholder="your@email.com" style="margin-bottom:0">
          </div>
        </div>
        <label class="rs__wr-label" style="margin-top:2px">Order number <span style="color:#e53">(required)</span></label>
        <input class="rs__wr-input" type="text" id="rsWrOrder-{{ section.id }}" placeholder="e.g. #1234">
        <div class="rs__wr-actions">
          <button class="rs__wr-cancel" type="button" data-rs-close-write>Cancel</button>
          <button class="rs__wr-submit" type="button" id="rsWrSubmit-{{ section.id }}">Submit</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var sid = '{{ section.id }}';

  // ---- Lightbox ----
  var lbEl     = document.getElementById('rsLb-' + sid);
  var lbImg    = document.getElementById('rsLbImg-' + sid);
  var lbVid    = document.getElementById('rsLbVid-' + sid);
  var lbPrev   = document.getElementById('rsLbPrev-' + sid);
  var lbNext   = document.getElementById('rsLbNext-' + sid);
  var lbClose  = document.getElementById('rsLbClose-' + sid);
  var cards    = Array.prototype.slice.call(document.querySelectorAll('#rsPhotoGrid-' + sid + ' .rs__card'));
  var lbCur    = 0;

  function starHTML(r){
    var h = '';
    for (var i = 1; i <= 5; i++){
      var c = i <= Math.floor(r) ? '#111' : (i === Math.ceil(r) && Math.ceil(r) !== Math.floor(r) ? '#111' : '#e0e0e0');
      h += '<svg width="14" height="14" viewBox="0 0 24 24" fill="' + c + '"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>';
    }
    return h;
  }

  function lbShow(idx){
    lbCur = (idx + cards.length) % cards.length;
    var c  = cards[lbCur];
    var src = c.getAttribute('data-rs-src') || '';
    var vid = c.getAttribute('data-rs-video') || '';

    if (vid){
      lbVid.src = vid; lbVid.style.display = ''; lbImg.style.display = 'none';
      lbVid.play().catch(function(){});
    } else if (src) {
      lbImg.src = src; lbImg.style.display = ''; lbVid.pause(); lbVid.style.display = 'none';
    }

    var nameEl  = document.getElementById('rsLbName-' + sid);
    var starsEl = document.getElementById('rsLbStars-' + sid);
    var titleEl = document.getElementById('rsLbTitle-' + sid);
    var textEl  = document.getElementById('rsLbText-' + sid);
    var metaEl  = document.getElementById('rsLbMeta-' + sid);
    var infoEl  = document.getElementById('rsLbInfo-' + sid);

    var name  = c.getAttribute('data-rs-name') || '';
    var rat   = parseFloat(c.getAttribute('data-rs-rating')) || 0;
    var title = c.getAttribute('data-rs-title') || '';
    var text  = c.getAttribute('data-rs-text') || '';
    var date  = c.getAttribute('data-rs-date') || '';
    var ver   = c.getAttribute('data-rs-verified') === 'true';

    if (nameEl) {
      nameEl.innerHTML = name + (ver ? ' <svg width="15" height="15" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="#111111"/><polyline points="8 12 11 15 16 9" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '');
    }
    if (starsEl) starsEl.innerHTML = rat ? starHTML(rat) : '';
    if (titleEl) { titleEl.textContent = title; titleEl.style.display = title ? '' : 'none'; }
    if (textEl)  textEl.textContent = text;
    if (metaEl)  metaEl.textContent = date;
    if (infoEl)  infoEl.style.display = (name || text) ? '' : 'none';
  }

  function lbOpen(idx){ lbShow(idx); lbEl.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  function lbClose_(){ lbEl.classList.remove('is-open'); document.body.style.overflow = ''; if(lbVid){ lbVid.pause(); } }

  cards.forEach(function(c, i){ c.addEventListener('click', function(){ lbOpen(i); }); });
  if (lbPrev)  lbPrev.addEventListener('click', function(){ lbShow(lbCur - 1); });
  if (lbNext)  lbNext.addEventListener('click', function(){ lbShow(lbCur + 1); });
  if (lbClose) lbClose.addEventListener('click', lbClose_);
  if (lbEl)    lbEl.addEventListener('click', function(e){ if (e.target === lbEl) lbClose_(); });

  // ---- Write Review ----
  var wrOverlay = document.getElementById('rsWrOverlay-' + sid);
  var wrThanks  = document.getElementById('rsWrThanks-' + sid);
  var wrForm    = document.getElementById('rsWrForm-' + sid);
  var wrSubmit  = document.getElementById('rsWrSubmit-' + sid);
  var wrStars   = document.querySelectorAll('#rsWrStars-' + sid + ' [data-rs-wstar]');
  var wrRating  = 0;

  document.querySelectorAll('[data-rs-open-write]').forEach(function(btn){
    btn.addEventListener('click', function(){
      if (wrThanks) wrThanks.classList.remove('is-shown');
      if (wrForm)   wrForm.style.display = '';
      wrOverlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    });
  });
  document.querySelectorAll('[data-rs-close-write]').forEach(function(btn){
    btn.addEventListener('click', function(){ wrOverlay.classList.remove('is-open'); document.body.style.overflow = ''; });
  });
  if (wrOverlay) wrOverlay.addEventListener('click', function(e){ if (e.target === wrOverlay){ wrOverlay.classList.remove('is-open'); document.body.style.overflow = ''; } });

  wrStars.forEach(function(s){
    s.addEventListener('mouseover', function(){
      var v = parseInt(s.getAttribute('data-rs-wstar'));
      wrStars.forEach(function(x){ var xv = parseInt(x.getAttribute('data-rs-wstar')); x.setAttribute('fill', xv <= v ? '#111' : '#e0e0e0'); x.setAttribute('stroke', xv <= v ? '#111' : '#ccc'); });
    });
    s.addEventListener('mouseout', function(){
      wrStars.forEach(function(x){ var xv = parseInt(x.getAttribute('data-rs-wstar')); x.setAttribute('fill', xv <= wrRating ? '#111' : '#e0e0e0'); x.setAttribute('stroke', xv <= wrRating ? '#111' : '#ccc'); });
    });
    s.addEventListener('click', function(){
      wrRating = parseInt(s.getAttribute('data-rs-wstar'));
      wrStars.forEach(function(x){ var xv = parseInt(x.getAttribute('data-rs-wstar')); x.setAttribute('fill', xv <= wrRating ? '#111' : '#e0e0e0'); x.setAttribute('stroke', xv <= wrRating ? '#111' : '#ccc'); });
    });
  });

  if (wrSubmit) wrSubmit.addEventListener('click', function(){
    var text  = document.getElementById('rsWrText-'  + sid);
    var name  = document.getElementById('rsWrName-'  + sid);
    var email = document.getElementById('rsWrEmail-' + sid);
    var order = document.getElementById('rsWrOrder-' + sid);
    if (!wrRating)              { alert('Please select a star rating.'); return; }
    if (!text  || !text.value.trim())  { alert('Please enter your feedback.'); return; }
    if (!name  || !name.value.trim())  { alert('Please enter your name.'); return; }
    if (!email || !email.value.trim()) { alert('Please enter your email address.'); return; }
    if (!order || !order.value.trim()) { alert('Please enter your order number.'); return; }
    if (wrForm)   wrForm.style.display = 'none';
    if (wrThanks) wrThanks.classList.add('is-shown');
  });

  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape'){
      lbClose_();
      wrOverlay.classList.remove('is-open');
      document.body.style.overflow = '';
    }
  });
  // Carousel prev/next
  var track   = document.getElementById('rsPhotoGrid-' + sid);
  var btnPrev = document.getElementById('rsCarPrev-' + sid);
  var btnNext = document.getElementById('rsCarNext-' + sid);
  if (track && btnPrev && btnNext) {
    function scrollAmount() { return track.querySelector('.rs__card') ? track.querySelector('.rs__card').offsetWidth + 12 : 280; }
    btnPrev.addEventListener('click', function(){ track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' }); });
    btnNext.addEventListener('click', function(){ track.scrollBy({ left:  scrollAmount(), behavior: 'smooth' }); });
    function updateBtns(){
      btnPrev.disabled = track.scrollLeft <= 0;
      btnNext.disabled = track.scrollLeft + track.offsetWidth >= track.scrollWidth - 2;
    }
    track.addEventListener('scroll', updateBtns);
    updateBtns();
  }

  // Filter
  document.querySelectorAll('[data-rs-filter-toggle]').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var wrap = btn.closest('.rs__filter-wrap');
      var drop = wrap.querySelector('.rs__filter-dropdown');
      // close all other dropdowns first
      document.querySelectorAll('.rs__filter-dropdown').forEach(function(d){ if(d !== drop) d.classList.remove('is-open'); });
      drop.classList.toggle('is-open');
    });
  });

  document.querySelectorAll('[data-rs-sort]').forEach(function(opt){
    opt.addEventListener('click', function(e){
      e.stopPropagation();
      var val = opt.getAttribute('data-rs-sort');
      // mark active in all dropdowns
      document.querySelectorAll('[data-rs-sort]').forEach(function(o){ o.classList.remove('is-active'); });
      document.querySelectorAll('[data-rs-sort="' + val + '"]').forEach(function(o){ o.classList.add('is-active'); });
      // close all dropdowns
      document.querySelectorAll('.rs__filter-dropdown').forEach(function(d){ d.classList.remove('is-open'); });
      // sort — treat .rs__col and standalone .rs__card as units
      if (track) {
        var units = Array.prototype.slice.call(track.children);
        units.sort(function(a, b){
          // get representative rating: first card inside col, or card itself
          var ca = a.classList.contains('rs__col') ? a.querySelector('.rs__card') : a;
          var cb = b.classList.contains('rs__col') ? b.querySelector('.rs__card') : b;
          var ra = parseFloat((ca && ca.getAttribute('data-rs-rating')) || 0);
          var rb = parseFloat((cb && cb.getAttribute('data-rs-rating')) || 0);
          if (val === 'highest') return rb - ra;
          if (val === 'lowest')  return ra - rb;
          var ia = parseInt((ca && ca.getAttribute('data-rs-card')) || 0);
          var ib = parseInt((cb && cb.getAttribute('data-rs-card')) || 0);
          return ia - ib;
        });
        units.forEach(function(u){ track.appendChild(u); });
        track.scrollLeft = 0;
        if (typeof updateBtns === 'function') updateBtns();
      }
    });
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', function(){
    document.querySelectorAll('.rs__filter-dropdown').forEach(function(d){ d.classList.remove('is-open'); });
  });

  // Read more / Read less helper
  function initReadMore(btnAttr) {
    document.querySelectorAll('[' + btnAttr + ']').forEach(function(btn){
      var textEl = btn.previousElementSibling;
      btn.addEventListener('click', function(e){
        e.stopPropagation();
        var expanded = textEl.classList.toggle('is-expanded');
        btn.textContent = expanded ? 'Read less' : 'Read more';
      });
    });
  }
  initReadMore('data-rs-text-more');
  initReadMore('data-rs-reply-more');
  // Hide Read more buttons where text fits without clamping — run after full page load
  function hideUnnecessaryReadMore() {
    document.querySelectorAll('[data-rs-text-more],[data-rs-reply-more]').forEach(function(btn){
      var textEl = btn.previousElementSibling;
      if (textEl.scrollHeight <= textEl.clientHeight + 2) { btn.style.display = 'none'; }
    });
  }
  if (document.readyState === 'complete') {
    hideUnnecessaryReadMore();
  } else {
    window.addEventListener('load', hideUnnecessaryReadMore);
    setTimeout(hideUnnecessaryReadMore, 800);
  }
})();
</script>

