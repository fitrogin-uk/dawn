<div class="cr-certs">
  <div class="cr-certs__inner">
    <h2 class="cr-section-title">{{ section.settings.title }}</h2>
    <p class="cr-section-subtitle">{{ section.settings.subtitle }}</p>
    <div class="cr-certs__grid">

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">🌿</div>
        <div class="cr-cert-badge__name">Cruelty Free</div>
        <div class="cr-cert-badge__desc">Never tested on animals</div>
      </div>

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">🔬</div>
        <div class="cr-cert-badge__name">3rd Party Tested</div>
        <div class="cr-cert-badge__desc">Eurofins verified every batch</div>
      </div>

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">🏭</div>
        <div class="cr-cert-badge__name">GMP Certified</div>
        <div class="cr-cert-badge__desc">Good Manufacturing Practice</div>
      </div>

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">✅</div>
        <div class="cr-cert-badge__name">Full Dose Guaranteed</div>
        <div class="cr-cert-badge__desc">What's on the label is what's inside</div>
      </div>

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">🇬🇧</div>
        <div class="cr-cert-badge__name">UK Made</div>
        <div class="cr-cert-badge__desc">Manufactured in the United Kingdom</div>
      </div>

      <div class="cr-cert-badge">
        <div class="cr-cert-badge__icon">👨‍🔬</div>
        <div class="cr-cert-badge__name">Expert Formulated</div>
        <div class="cr-cert-badge__desc">Developed with sports scientists</div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Certifications",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Quality You Can Trust" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Every jar is independently verified. No compromises, no shortcuts." }
  ],
  "presets": [{ "name": "Certifications" }]
}
{% endschema %}
