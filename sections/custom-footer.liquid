{% comment %}
  Custom Footer Section — FuelX
  Equal 5-col grid | large margins | 20px fonts | country-dial dropdown below input
{% endcomment %}

<footer class="cf-footer" role="contentinfo">
  <div class="cf-footer__inner">

    <!-- Col 1: Brand -->
    <div class="cf-footer__brand">
      <a href="{{ routes.root_url }}" class="cf-footer__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            width="200"
            height="auto"
            loading="lazy"
            class="cf-footer__logo-img"
          >
        {%- else -%}
          <span class="cf-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.phone != blank -%}
        <p class="cf-footer__phone">
          <strong>{{ section.settings.phone_label | default: 'Call us on:' }}</strong>
          <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
        </p>
      {%- endif -%}

      <!-- Email signup -->
      <form method="post" action="/contact#cf-email-form" id="cf-email-form" class="cf-footer__form" accept-charset="UTF-8" novalidate>
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="cf-footer__input-row">
          <input
            type="email"
            name="contact[email]"
            id="cf-email"
            class="cf-footer__input"
            placeholder="{{ section.settings.email_placeholder | default: 'Enter your email' }}"
            autocomplete="email"
            aria-label="Email address"
          >
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by email">
            {% render 'cf-footer-send-icon' %}
          </button>
        </div>
      </form>

      <!-- Phone signup with country-dial dropdown -->
      <form method="post" action="/contact#cf-phone-form" id="cf-phone-form" class="cf-footer__form" accept-charset="UTF-8" novalidate>
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[dial_code]" id="cf-dial-hidden" value="+44">

        <!-- Trigger row -->
        <div class="cf-footer__input-row cf-footer__input-row--phone">
          <button
            type="button"
            class="cf-dial__trigger"
            id="cf-dial-trigger"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="cf-dial-panel"
            aria-label="Select country code"
          >
            <span class="cf-dial__flag" id="cf-dial-flag" aria-hidden="true">🇬🇧</span>
            <span class="cf-dial__code" id="cf-dial-code">+44</span>
            <svg class="cf-dial__chevron" viewBox="0 0 10 6" fill="none" width="10" height="6" aria-hidden="true">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <span class="cf-dial__sep" aria-hidden="true"></span>
          <input
            type="tel"
            name="contact[phone]"
            id="cf-phone"
            class="cf-footer__input cf-footer__input--phone"
            placeholder="{{ section.settings.phone_placeholder | default: 'Phone Number' }}"
            autocomplete="tel"
            aria-label="Phone number"
          >
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by phone">
            {% render 'cf-footer-send-icon' %}
          </button>
        </div>

        <!-- Dropdown panel — sits BELOW the input row -->
        <div class="cf-dial__panel" id="cf-dial-panel" role="listbox" aria-label="Country codes" hidden>
          <div class="cf-dial__search-wrap">
            <svg class="cf-dial__search-icon" viewBox="0 0 18 18" fill="none" width="15" height="15" aria-hidden="true">
              <circle cx="7.5" cy="7.5" r="5.5" stroke="#aaa" stroke-width="1.6"/>
              <path d="M11.5 11.5L16 16" stroke="#aaa" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            <input type="text" class="cf-dial__search" id="cf-dial-search" placeholder="Search country…" aria-label="Search country" autocomplete="off">
          </div>
          <ul class="cf-dial__list" id="cf-dial-list"></ul>
        </div>
      </form>
    </div>

    <!-- Col 2: Company -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col2_heading | default: 'Company' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col2_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col2_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 3: Account -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col3_heading | default: 'Account' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col3_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col3_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 4: Legal -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col4_heading | default: 'Legal' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col4_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col4_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 5: Social -->
    <div class="cf-footer__col cf-footer__col--social">
      <h3 class="cf-footer__heading">{{ section.settings.social_heading | default: 'Follow Us' }}</h3>
      <div class="cf-footer__social-grid">
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_twitter != blank -%}
          <a href="{{ section.settings.social_twitter }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_linkedin != blank -%}
          <a href="{{ section.settings.social_linkedin }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.27a8.17 8.17 0 0 0 4.78 1.52V5.11a4.85 4.85 0 0 1-1-.42z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_whatsapp != blank -%}
          <a href="{{ section.settings.social_whatsapp }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="cf-footer__bottom">
    <p class="cf-footer__copyright">&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}</p>
    <div class="cf-footer__payments">
      {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'cf-footer__payment-icon' }}
    </div>
  </div>
</footer>

<style>
  /* ── Shell ────────────────────────────────────────────── */
  .cf-footer {
    background-color: {{ section.settings.bg_color | default: '#f5f5f7' }};
    color: {{ section.settings.text_color | default: '#333333' }};
    font-family: inherit;
    border-radius: 24px 24px 0 0;
    overflow: visible;
    padding-top: 64px;
  }

  /* ── Inner grid — 5 equal columns ────────────────────── */
  .cf-footer__inner {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    /* generous side padding so content lines up with header nav */
    padding: 0 clamp(40px, 7vw, 100px) 56px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    align-items: start;
  }

  /* ── Logo ────────────────────────────────────────────── */
  .cf-footer__logo-link  { display: inline-block; margin-bottom: 18px; }
  .cf-footer__logo-img   { max-width: 200px; height: auto; display: block; }
  .cf-footer__logo-text  {
    font-size: 26px; font-weight: 800; letter-spacing: -0.5px;
    color: {{ section.settings.text_color | default: '#333333' }};
    text-decoration: none;
  }

  /* ── Phone line ──────────────────────────────────────── */
  .cf-footer__phone {
    font-size: 16px;
    margin: 0 0 20px;
    color: {{ section.settings.text_color | default: '#333333' }};
  }
  .cf-footer__phone a { color: inherit; text-decoration: none; }
  .cf-footer__phone a:hover { text-decoration: underline; }

  /* ── Input rows ──────────────────────────────────────── */
  .cf-footer__form { margin-bottom: 12px; position: relative; }

  .cf-footer__input-row {
    display: flex;
    align-items: center;
    background: #fff;
    border: 1.5px solid #ddd;
    border-radius: 50px;
    height: 48px;
    padding-left: 16px;
    overflow: hidden;
  }
  .cf-footer__input-row--phone { padding-left: 0; overflow: visible; }

  .cf-footer__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 15px;
    color: #333;
    min-width: 0;
    padding: 0 6px;
  }
  .cf-footer__input--phone { padding-left: 4px; }

  .cf-footer__submit-btn {
    background: {{ section.settings.accent_color | default: '#e8175d' }};
    border: none;
    border-radius: 50%;
    width: 38px; height: 38px;
    flex-shrink: 0;
    margin: 5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s, transform 0.15s;
  }
  .cf-footer__submit-btn:hover {
    background: {{ section.settings.accent_hover | default: '#c0134d' }};
    transform: scale(1.08);
  }

  /* ── Country dial trigger (inside input row) ─────────── */
  .cf-dial__trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 10px 0 14px;
    height: 100%;
    border-radius: 50px 0 0 50px;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .cf-dial__trigger:hover   { background: rgba(0,0,0,0.05); }
  .cf-dial__trigger:focus   { outline: 2px solid {{ section.settings.accent_color | default: '#e8175d' }}; outline-offset: -2px; border-radius: 50px 0 0 50px; }
  .cf-dial__flag  { font-size: 18px; line-height: 1; }
  .cf-dial__code  { font-size: 14px; font-weight: 600; color: #333; white-space: nowrap; }
  .cf-dial__chevron { color: #999; transition: transform 0.2s; flex-shrink: 0; }
  .cf-dial__trigger[aria-expanded="true"] .cf-dial__chevron { transform: rotate(180deg); }

  /* thin vertical separator */
  .cf-dial__sep {
    width: 1px; height: 24px;
    background: #ddd;
    flex-shrink: 0;
    margin-right: 6px;
  }

  /* ── Dropdown panel — BELOW the input row ────────────── */
  .cf-dial__panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: 100%;
    min-width: 260px;
    background: #fff;
    border: 1.5px solid #e0e0e0;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.14);
    z-index: 9999;
    overflow: hidden;
  }
  .cf-dial__panel[hidden] { display: none; }

  .cf-dial__search-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 12px 8px;
    border-bottom: 1px solid #f0f0f0;
  }
  .cf-dial__search-icon { flex-shrink: 0; }
  .cf-dial__search {
    flex: 1;
    border: none;
    outline: none;
    font-size: 15px;
    color: #333;
    background: transparent;
  }
  .cf-dial__search::placeholder { color: #aaa; }

  .cf-dial__list {
    list-style: none;
    margin: 0;
    padding: 6px 0;
    max-height: 230px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #ddd transparent;
  }
  .cf-dial__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    cursor: pointer;
    font-size: 15px;
    transition: background 0.1s;
  }
  .cf-dial__list li:hover,
  .cf-dial__list li.is-active { background: #f5f5f7; }
  .cf-dial__list li.is-active  { font-weight: 600; }
  .cf-dial__list li[hidden]    { display: none; }
  .cf-dial__item-flag { font-size: 18px; flex-shrink: 0; }
  .cf-dial__item-name { flex: 1; color: #333; }
  .cf-dial__item-code { color: #999; font-size: 13px; white-space: nowrap; }

  /* ── Nav columns ─────────────────────────────────────── */
  .cf-footer__heading {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 20px;
    color: {{ section.settings.text_color | default: '#333333' }};
    letter-spacing: 0.01em;
  }
  .cf-footer__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 13px;
  }
  .cf-footer__links a {
    font-size: 20px;
    color: {{ section.settings.link_color | default: '#666666' }};
    text-decoration: none;
    transition: color 0.2s;
  }
  .cf-footer__links a:hover { color: {{ section.settings.accent_color | default: '#e8175d' }}; }

  /* ── Social ──────────────────────────────────────────── */
  .cf-footer__social-grid {
    display: grid;
    grid-template-columns: repeat(3, 44px);
    gap: 10px;
  }
  .cf-footer__social-link {
    display: flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #111; color: #fff;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .cf-footer__social-link:hover {
    background: {{ section.settings.accent_color | default: '#e8175d' }};
    transform: scale(1.1);
  }

  /* ── Bottom bar ──────────────────────────────────────── */
  .cf-footer__bottom {
    border-top: 1px solid #e0e0e0;
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 20px clamp(40px, 7vw, 100px);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
  }
  .cf-footer__copyright { font-size: 14px; color: #888; margin: 0; }
  .cf-footer__payments  { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .cf-footer__payment-icon { height: 28px; width: auto; border-radius: 4px; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 1100px) {
    .cf-footer__inner {
      grid-template-columns: repeat(3, 1fr);
    }
    .cf-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .cf-footer {
      border-radius: 16px 16px 0 0;
    }
    .cf-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .cf-footer__brand       { grid-column: 1 / -1; }
    .cf-footer__col--social { grid-column: 1 / -1; }
    .cf-footer__social-grid { grid-template-columns: repeat(6, 44px); }
    .cf-footer__bottom      { flex-direction: column; align-items: flex-start; }
  }
</style>

