{% comment %}Custom Footer — FuelX — card-style with side gaps{% endcomment %}

{%- assign pad = section.settings.side_gap | default: 60 -%}

<div class="cf-footer-wrap" style="padding-left:{{ pad }}px !important;padding-right:{{ pad }}px !important;box-sizing:border-box !important;display:block !important;">
<footer class="cf-footer" role="contentinfo">

  <div class="cf-footer__inner">

    <div class="cf-footer__brand">
      <a href="{{ routes.root_url }}" class="cf-footer__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" height="auto" loading="lazy" class="cf-footer__logo-img">
        {%- else -%}
          <span class="cf-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if section.settings.phone != blank -%}
        <p class="cf-footer__phone">
          <strong>{{ section.settings.phone_label | default: 'Call us on:' }}</strong>
          <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
        </p>
      {%- endif -%}
      <form method="post" action="/contact#cf-email-form" id="cf-email-form" class="cf-footer__form" accept-charset="UTF-8" novalidate>
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="cf-footer__input-row">
          <input type="email" name="contact[email]" id="cf-email" class="cf-footer__input" placeholder="{{ section.settings.email_placeholder | default: 'Enter your email' }}" autocomplete="email" aria-label="Email address">
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by email">{% render 'cf-footer-send-icon' %}</button>
        </div>
      </form>
      <form method="post" action="/contact#cf-phone-form" id="cf-phone-form" class="cf-footer__form" accept-charset="UTF-8" novalidate>
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[dial_code]" id="cf-dial-hidden" value="+44">
        <div class="cf-footer__input-row cf-footer__input-row--phone">
          <button type="button" class="cf-dial__trigger" id="cf-dial-trigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="cf-dial-panel" aria-label="Select country code">
            <img id="cf-dial-flag-img" src="https://flagcdn.com/20x15/gb.png" width="20" height="15" alt="GB" class="cf-dial__flag-img">
            <span class="cf-dial__code" id="cf-dial-code">+44</span>
            <svg class="cf-dial__chevron" viewBox="0 0 10 6" fill="none" width="10" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <span class="cf-dial__sep" aria-hidden="true"></span>
          <input type="tel" name="contact[phone]" id="cf-phone" class="cf-footer__input cf-footer__input--phone" placeholder="{{ section.settings.phone_placeholder | default: 'Phone Number' }}" autocomplete="tel" aria-label="Phone number">
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by phone">{% render 'cf-footer-send-icon' %}</button>
        </div>
        <div class="cf-dial__panel" id="cf-dial-panel" role="listbox" aria-label="Country codes" hidden>
          <ul class="cf-dial__list" id="cf-dial-list"></ul>
          <div class="cf-dial__search-wrap">
            <svg viewBox="0 0 18 18" fill="none" width="15" height="15" aria-hidden="true"><circle cx="7.5" cy="7.5" r="5.5" stroke="#aaa" stroke-width="1.6"/><path d="M11.5 11.5L16 16" stroke="#aaa" stroke-width="1.6" stroke-linecap="round"/></svg>
            <input type="text" class="cf-dial__search" id="cf-dial-search" placeholder="Search countries" aria-label="Search country" autocomplete="off">
          </div>
        </div>
      </form>
    </div>

    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col2_heading | default: 'Company' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col2_link'|append:i|append:'_label' -%}{%- assign uk='col2_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col3_heading | default: 'Account' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col3_link'|append:i|append:'_label' -%}{%- assign uk='col3_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col4_heading | default: 'Legal' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col4_link'|append:i|append:'_label' -%}{%- assign uk='col4_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>

    <div class="cf-footer__col cf-footer__col--social">
      <h3 class="cf-footer__heading">{{ section.settings.social_heading | default: 'Follow Us' }}</h3>
      <div class="cf-footer__social-grid">
        {%- if section.settings.social_facebook!=blank -%}<a href="{{ section.settings.social_facebook }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_twitter!=blank -%}<a href="{{ section.settings.social_twitter }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_instagram!=blank -%}<a href="{{ section.settings.social_instagram }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
        {%- if section.settings.social_linkedin!=blank -%}<a href="{{ section.settings.social_linkedin }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg></a>{%- endif -%}
        {%- if section.settings.social_tiktok!=blank -%}<a href="{{ section.settings.social_tiktok }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.27a8.17 8.17 0 0 0 4.78 1.52V5.11a4.85 4.85 0 0 1-1-.42z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_whatsapp!=blank -%}<a href="{{ section.settings.social_whatsapp }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg></a>{%- endif -%}
      </div>
    </div>

  </div>

  <div class="cf-footer__bottom">
    <p class="cf-footer__copyright">&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}</p>
    <div class="cf-footer__payments">{{ shop.enabled_payment_types | payment_type_svg_tag: class: 'cf-footer__payment-icon' }}</div>
  </div>

</footer>
</div>

<style>
  /* Outer wrapper — inline style (above) handles the gap with !important.
     CSS here is a fallback and for media queries. */
  .cf-footer-wrap {
    padding-left: {{ pad }}px !important;
    padding-right: {{ pad }}px !important;
    box-sizing: border-box !important;
    display: block !important;
    width: 100% !important;
  }

  .cf-footer {
    background-color: {{ section.settings.bg_color | default: '#f5f5f7' }};
    color: {{ section.settings.text_color | default: '#333333' }};
    font-family: inherit;
    text-align: left;
    border-radius: 24px 24px 0 0;
    overflow: visible;
    padding-top: 51px;
  }

  .cf-footer__inner {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 40px;
    padding: 0 40px 45px;
    box-sizing: border-box;
  }
  .cf-footer__brand,
  .cf-footer__col,
  .cf-footer__col--social { min-width: 0; width: auto; }

  .cf-footer__logo-link { display: inline-block; margin-bottom: 14px; }
  .cf-footer__logo-img  { max-width: 200px; height: auto; display: block; }
  .cf-footer__logo-text { font-size: 24px; font-weight: 800; color: {{ section.settings.text_color | default: '#333333' }}; text-decoration: none; }
  .cf-footer__phone { font-size: 15px; margin: 0 0 16px; color: {{ section.settings.text_color | default: '#333333' }}; }
  .cf-footer__phone a { color: inherit; text-decoration: none; }
  .cf-footer__phone a:hover { text-decoration: underline; }

  .cf-footer__form { margin-bottom: 10px; position: relative; width: 100%; }
  .cf-footer__input-row { display: flex; align-items: center; background: #fff; border: 1.5px solid #ddd; border-radius: 50px; height: 44px; padding-left: 16px; overflow: hidden; width: 100%; box-sizing: border-box; }
  .cf-footer__input-row--phone { padding-left: 0; overflow: visible; }
  .cf-footer__input { flex: 1; border: none; outline: none; background: transparent; font-size: 14px; color: #333; min-width: 0; padding: 0 6px; }
  .cf-footer__submit-btn { background: {{ section.settings.accent_color | default: '#e8175d' }}; border: none; border-radius: 50%; width: 36px; height: 36px; flex-shrink: 0; margin: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #fff; transition: background 0.2s, transform 0.15s; }
  .cf-footer__submit-btn:hover { background: {{ section.settings.accent_hover | default: '#c0134d' }}; transform: scale(1.08); }

  .cf-dial__trigger { display: flex; align-items: center; gap: 5px; background: none; border: none; cursor: pointer; padding: 0 10px 0 12px; height: 100%; border-radius: 50px 0 0 50px; transition: background 0.15s; flex-shrink: 0; }
  .cf-dial__trigger:hover { background: rgba(0,0,0,0.05); }
  .cf-dial__flag-img { border-radius: 2px; display: block; flex-shrink: 0; }
  .cf-dial__code { font-size: 13px; font-weight: 600; color: #333; white-space: nowrap; }
  .cf-dial__chevron { color: #999; transition: transform 0.2s; flex-shrink: 0; }
  .cf-dial__trigger[aria-expanded="true"] .cf-dial__chevron { transform: rotate(180deg); }
  .cf-dial__sep { width: 1px; height: 22px; background: #ddd; flex-shrink: 0; margin-right: 6px; }
  .cf-dial__panel { position: absolute; bottom: calc(100% + 8px); top: auto; left: 0; width: 100%; min-width: 260px; background: #fff; border: 1.5px solid #e0e0e0; border-radius: 16px; box-shadow: 0 -8px 40px rgba(0,0,0,0.13); z-index: 9999; overflow: hidden; display: flex; flex-direction: column; }
  .cf-dial__panel[hidden] { display: none; }
  .cf-dial__list { list-style: none; margin: 0; padding: 6px 0; max-height: 220px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #ddd transparent; order: 1; }
  .cf-dial__list li { display: flex; align-items: center; gap: 10px; padding: 8px 14px; cursor: pointer; font-size: 14px; transition: background 0.1s; }
  .cf-dial__list li:hover, .cf-dial__list li.is-active { background: #f5f5f7; }
  .cf-dial__list li.is-active { font-weight: 600; }
  .cf-dial__list li[hidden] { display: none; }
  .cf-dial__item-flag { flex-shrink: 0; border-radius: 2px; }
  .cf-dial__item-name { flex: 1; color: #333; }
  .cf-dial__item-code { color: #999; font-size: 12px; white-space: nowrap; }
  .cf-dial__search-wrap { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-top: 1px solid #f0f0f0; order: 2; }
  .cf-dial__search { flex: 1; border: none; outline: none; font-size: 14px; color: #333; background: transparent; }
  .cf-dial__search::placeholder { color: #aaa; }

  .cf-footer__heading { font-size: 20px; font-weight: 700; margin: 0 0 16px; color: {{ section.settings.text_color | default: '#333333' }}; }
  .cf-footer__links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .cf-footer__links a { font-size: 20px; color: {{ section.settings.link_color | default: '#666666' }}; text-decoration: none; transition: color 0.2s; }
  .cf-footer__links a:hover { color: {{ section.settings.accent_color | default: '#e8175d' }}; }

  .cf-footer__social-grid { display: grid; grid-template-columns: repeat(3, 42px); gap: 10px; }
  .cf-footer__social-link { display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: #111; color: #fff; text-decoration: none; transition: background 0.2s, transform 0.2s; }
  .cf-footer__social-link:hover { background: {{ section.settings.accent_color | default: '#e8175d' }}; transform: scale(1.1); }

  .cf-footer__bottom { border-top: 1px solid #e0e0e0; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; padding: 16px 40px; }
  .cf-footer__copyright { font-size: 13px; color: #888; margin: 0; }
  .cf-footer__payments  { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
  .cf-footer__payment-icon { height: 26px; width: auto; border-radius: 4px; }

  @media (max-width: 900px) {
    .cf-footer-wrap { padding-left: 20px !important; padding-right: 20px !important; }
    .cf-footer__inner { flex-wrap: wrap; }
    .cf-footer__brand { width: 100%; }
    .cf-footer__col, .cf-footer__col--social { flex: 1 1 140px; width: auto; }
  }
  @media (max-width: 640px) {
    .cf-footer-wrap { padding-left: 12px !important; padding-right: 12px !important; }
    .cf-footer { border-radius: 16px 16px 0 0; }
    .cf-footer__inner { padding: 0 20px 36px; }
    .cf-footer__col { flex: 1 1 calc(50% - 20px); }
    .cf-footer__col--social { width: 100%; }
    .cf-footer__social-grid { grid-template-columns: repeat(6, 42px); }
    .cf-footer__bottom { flex-direction: column; align-items: flex-start; padding: 16px 20px; }
  }
</style>

<script>
(function(){
  var C=[{iso:'gb',name:'United Kingdom',code:'+44'},{iso:'us',name:'United States',code:'+1'},{iso:'ca',name:'Canada',code:'+1'},{iso:'au',name:'Australia',code:'+61'},{iso:'ie',name:'Ireland',code:'+353'},{iso:'de',name:'Germany',code:'+49'},{iso:'fr',name:'France',code:'+33'},{iso:'es',name:'Spain',code:'+34'},{iso:'it',name:'Italy',code:'+39'},{iso:'nl',name:'Netherlands',code:'+31'},{iso:'be',name:'Belgium',code:'+32'},{iso:'se',name:'Sweden',code:'+46'},{iso:'no',name:'Norway',code:'+47'},{iso:'dk',name:'Denmark',code:'+45'},{iso:'fi',name:'Finland',code:'+358'},{iso:'ch',name:'Switzerland',code:'+41'},{iso:'at',name:'Austria',code:'+43'},{iso:'pt',name:'Portugal',code:'+351'},{iso:'pl',name:'Poland',code:'+48'},{iso:'gr',name:'Greece',code:'+30'},{iso:'za',name:'South Africa',code:'+27'},{iso:'in',name:'India',code:'+91'},{iso:'pk',name:'Pakistan',code:'+92'},{iso:'bd',name:'Bangladesh',code:'+880'},{iso:'sg',name:'Singapore',code:'+65'},{iso:'my',name:'Malaysia',code:'+60'},{iso:'nz',name:'New Zealand',code:'+64'},{iso:'jp',name:'Japan',code:'+81'},{iso:'kr',name:'South Korea',code:'+82'},{iso:'cn',name:'China',code:'+86'},{iso:'br',name:'Brazil',code:'+55'},{iso:'mx',name:'Mexico',code:'+52'},{iso:'ae',name:'UAE',code:'+971'},{iso:'sa',name:'Saudi Arabia',code:'+966'},{iso:'qa',name:'Qatar',code:'+974'},{iso:'ng',name:'Nigeria',code:'+234'},{iso:'ke',name:'Kenya',code:'+254'},{iso:'ru',name:'Russia',code:'+7'},{iso:'tr',name:'Turkey',code:'+90'}];
  function f(i){return 'https://flagcdn.com/20x15/'+i+'.png';}
  document.addEventListener('DOMContentLoaded',function(){
    var tr=document.getElementById('cf-dial-trigger'),pn=document.getElementById('cf-dial-panel'),fi=document.getElementById('cf-dial-flag-img'),co=document.getElementById('cf-dial-code'),hi=document.getElementById('cf-dial-hidden'),li=document.getElementById('cf-dial-list'),se=document.getElementById('cf-dial-search');
    if(!tr||!pn)return;
    C.forEach(function(c,i){var el=document.createElement('li');el.setAttribute('role','option');el.innerHTML='<img src="'+f(c.iso)+'" width="20" height="15" alt="'+c.iso.toUpperCase()+'" class="cf-dial__item-flag"><span class="cf-dial__item-name">'+c.name+'</span><span class="cf-dial__item-code">'+c.code+'</span>';if(i===0)el.classList.add('is-active');el.addEventListener('mousedown',function(e){e.preventDefault();fi.src=f(c.iso);fi.alt=c.iso.toUpperCase();co.textContent=c.code;hi.value=c.code;li.querySelectorAll('li').forEach(function(x,j){x.classList.toggle('is-active',j===i);});close();});li.appendChild(el);});
    function open(){pn.hidden=false;tr.setAttribute('aria-expanded','true');se.value='';flt('');li.scrollTop=0;setTimeout(function(){se.focus();},30);}
    function close(){pn.hidden=true;tr.setAttribute('aria-expanded','false');}
    function flt(q){var lq=q.toLowerCase();li.querySelectorAll('li').forEach(function(x,i){x.hidden=!(C[i].name.toLowerCase().includes(lq)||C[i].code.includes(lq));});}
    tr.addEventListener('click',function(){pn.hidden?open():close();});
    tr.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' '){e.preventDefault();open();}if(e.key==='Escape')close();});
    se.addEventListener('input',function(){flt(se.value);});
    se.addEventListener('keydown',function(e){if(e.key==='Escape')close();});
    document.addEventListener('click',function(e){if(!tr.closest('.cf-footer__form').contains(e.target))close();});
  });
})();
</script>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {"type":"header","content":"Brand"},
    {"type":"image_picker","id":"logo","label":"Logo image"},
    {"type":"text","id":"phone","label":"Phone number","default":"01863723207"},
    {"type":"text","id":"phone_label","label":"Phone label","default":"Call us on:"},
    {"type":"text","id":"email_placeholder","label":"Email placeholder","default":"Enter your email"},
    {"type":"text","id":"phone_placeholder","label":"Phone placeholder","default":"Phone Number"},
    {"type":"range","id":"side_gap","label":"Side gap (px)","min":0,"max":120,"step":4,"default":60},
    {"type":"header","content":"Column 2 — Company"},
    {"type":"text","id":"col2_heading","label":"Heading","default":"Company"},
    {"type":"text","id":"col2_link1_label","label":"Link 1","default":"Health Blog"},{"type":"url","id":"col2_link1_url","label":"Link 1 URL"},
    {"type":"text","id":"col2_link2_label","label":"Link 2","default":"Take Our Quiz"},{"type":"url","id":"col2_link2_url","label":"Link 2 URL"},
    {"type":"text","id":"col2_link3_label","label":"Link 3","default":"Shop Now"},{"type":"url","id":"col2_link3_url","label":"Link 3 URL"},
    {"type":"text","id":"col2_link4_label","label":"Link 4","default":"Contact Us"},{"type":"url","id":"col2_link4_url","label":"Link 4 URL"},
    {"type":"text","id":"col2_link5_label","label":"Link 5","default":"Who We Are"},{"type":"url","id":"col2_link5_url","label":"Link 5 URL"},
    {"type":"text","id":"col2_link6_label","label":"Link 6"},{"type":"url","id":"col2_link6_url","label":"Link 6 URL"},
    {"type":"header","content":"Column 3 — Account"},
    {"type":"text","id":"col3_heading","label":"Heading","default":"Account"},
