{% comment %}Custom Footer — FuelX — card-style with side gaps{% endcomment %}

{%- assign pad = section.settings.side_gap | default: 16 -%}

<div class="cf-footer-wrap">
<footer class="cf-footer" role="contentinfo">

  <div class="cf-footer__inner">

    <div class="cf-footer__brand">
      <a href="{{ routes.root_url }}" class="cf-footer__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" height="auto" loading="lazy" class="cf-footer__logo-img">
        {%- else -%}
          <span class="cf-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <p class="cf-footer__tagline">Fuel your potential.</p>
      <address class="cf-footer__address">Parker Lane, Burnley, BB11 2BU, UK</address>
    </div>

    <div class="cf-footer__col cf-footer__col--2">
      <h3 class="cf-footer__heading">{{ section.settings.col2_heading | default: 'Company' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col2_link'|append:i|append:'_label' -%}{%- assign uk='col2_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>
    <div class="cf-footer__col cf-footer__col--3">
      <h3 class="cf-footer__heading">{{ section.settings.col3_heading | default: 'Account' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col3_link'|append:i|append:'_label' -%}{%- assign uk='col3_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>
    <div class="cf-footer__col cf-footer__col--4">
      <h3 class="cf-footer__heading">{{ section.settings.col4_heading | default: 'Legal' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}{%- assign lk='col4_link'|append:i|append:'_label' -%}{%- assign uk='col4_link'|append:i|append:'_url' -%}{%- if section.settings[lk]!=blank -%}<li><a href="{{ section.settings[uk]|default:'#' }}">{{ section.settings[lk] }}</a></li>{%- endif -%}{%- endfor -%}
      </ul>
    </div>

    <div class="cf-footer__col cf-footer__col--social">
      <h3 class="cf-footer__heading">{{ section.settings.social_heading | default: 'Follow Us' }}</h3>
      <div class="cf-footer__social-grid">
        {%- if section.settings.social_facebook!=blank -%}<a href="{{ section.settings.social_facebook }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_twitter!=blank -%}<a href="{{ section.settings.social_twitter }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_instagram!=blank -%}<a href="{{ section.settings.social_instagram }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
        {%- if section.settings.social_linkedin!=blank -%}<a href="{{ section.settings.social_linkedin }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg></a>{%- endif -%}
        {%- if section.settings.social_tiktok!=blank -%}<a href="{{ section.settings.social_tiktok }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.27a8.17 8.17 0 0 0 4.78 1.52V5.11a4.85 4.85 0 0 1-1-.42z"/></svg></a>{%- endif -%}
        {%- if section.settings.social_whatsapp!=blank -%}<a href="{{ section.settings.social_whatsapp }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg></a>{%- endif -%}
      </div>
    </div>

  </div>

  <div class="cf-footer__bottom">
    <p class="cf-footer__copyright">&copy; {{ 'now' | date: '%Y' }}, FuelX</p>
    <div class="cf-footer__payments">{{ shop.enabled_payment_types | payment_type_svg_tag: class: 'cf-footer__payment-icon' }}</div>
  </div>

</footer>
</div>

<style>
  .cf-footer-wrap {
    padding-left: {{ pad }}px;
    padding-right: {{ pad }}px;
    margin-top: {{ section.settings.top_margin | default: 16 }}px;
    box-sizing: border-box;
  }

  .cf-footer {
    background-color: {{ section.settings.bg_color | default: '#f5f5f7' }};
    color: {{ section.settings.text_color | default: '#333333' }};
    font-family: inherit;
    text-align: left;
    border-radius: 0;
    overflow: visible;
    padding-top: 51px;
  }

  .cf-footer__inner {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 40px;
    padding: 0 40px 45px 100px;
    box-sizing: border-box;
    align-items: start;
  }
  .cf-footer__brand,
  .cf-footer__col,
  .cf-footer__col--social { min-width: 0; width: auto; }
  .cf-footer__brand { padding-right: 10px; }
  .cf-footer__col--2 { margin-left: {{ section.settings.col2_offset | default: 0 }}px; }
  .cf-footer__col--3 { margin-left: {{ section.settings.col3_offset | default: 0 }}px; }
  .cf-footer__col--4 { margin-left: {{ section.settings.col4_offset | default: 0 }}px; }
  .cf-footer__col--social { justify-self: end; margin-right: {{ section.settings.col5_offset | default: 0 }}px; }

  .cf-footer__logo-link { display: inline-block; margin-bottom: 0; max-width: 100%; }
  .cf-footer__logo-img  { max-width: 100%; width: auto; height: auto; display: block; }
  .cf-footer__logo-text { font-size: 24px; font-weight: 800; color: {{ section.settings.text_color | default: '#333333' }}; text-decoration: none; }
  .cf-footer__tagline { font-size: 15px; font-style: italic; font-weight: 600; color: #000; margin: -30px 0 20px; }
  .cf-footer__address { font-style: normal; margin-top: 8px; font-size: 14px; line-height: 1.6; color: #000; }

  .cf-footer__heading { font-size: 20px; font-weight: 700; margin: 0 0 16px; color: {{ section.settings.text_color | default: '#333333' }}; }
  .cf-footer__links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .cf-footer__links a { font-size: 20px; color: {{ section.settings.link_color | default: '#666666' }}; text-decoration: none; transition: color 0.2s; }
  .cf-footer__links a:hover { color: {{ section.settings.accent_color | default: '#e8175d' }}; }

  .cf-footer__social-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .cf-footer__social-link { display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: #111; color: #fff; text-decoration: none; transition: background 0.2s, transform 0.2s; }
  .cf-footer__social-link:hover { background: {{ section.settings.accent_color | default: '#e8175d' }}; transform: scale(1.1); }

  .cf-footer__bottom { border-top: none; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; padding: 16px 40px 24px; }
  .cf-footer__copyright { font-size: 13px; color: #888; margin: 0; white-space: nowrap; }
  .cf-footer__payments  { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .cf-footer__payment-icon { height: 28px; width: auto; border-radius: 4px; display: inline-block; }

  /* Hide the theme's built-in footer that shows as a black box below */
  footer:not(.cf-footer) { display: none !important; }

  @media (max-width: 768px) {
    .cf-footer-wrap { padding-left: 12px; padding-right: 12px; margin-top: 12px; }
    .cf-footer { border-radius: 0; padding-top: 32px; }
    .cf-footer__inner {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0 0 0;
    }
    /* Brand block */
    .cf-footer__brand {
      text-align: center;
      padding: 0 6px 24px;
      border-bottom: 1px solid #e0e0e0;
      margin-left: 0; margin-right: 0;
    }
    .cf-footer__logo-link { display: block; text-align: center; }
    .cf-footer__logo-img { margin: 0 auto; }
    .cf-footer__tagline { text-align: center; }
    .cf-footer__address { text-align: center; }

    /* Nav accordion columns */
    .cf-footer__col { margin-left: 0 !important; width: 100%; }
    .cf-footer__heading {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 16px;
      padding: 16px 6px;
      margin: 0;
      border-bottom: 1px solid #e0e0e0;
      cursor: pointer;
      user-select: none;
    }
    .cf-footer__heading::after {
      content: '';
      display: inline-block;
      width: 10px; height: 10px;
      border-right: 2px solid #333;
      border-bottom: 2px solid #333;
      transform: rotate(45deg);
      transition: transform 0.2s;
      flex-shrink: 0;
    }
    .cf-footer__heading.is-open::after { transform: rotate(-135deg); }
    .cf-footer__links {
      display: none;
      flex-direction: column;
      gap: 0;
      padding: 8px 6px 16px;
      border-bottom: 1px solid #e0e0e0;
    }
    .cf-footer__links.is-open { display: flex; }
    .cf-footer__links a { font-size: 15px; padding: 8px 0; color: {{ section.settings.link_color | default: '#666' }}; }

    /* Social — always open, centred */
    .cf-footer__col--social {
      justify-self: unset;
      margin-right: 0 !important;
      text-align: center;
      padding: 24px 6px;
      border-bottom: 1px solid #e0e0e0;
    }
    .cf-footer__col--social .cf-footer__heading {
      justify-content: center;
      border-bottom: none;
      padding: 0 0 14px;
      cursor: default;
      font-size: 18px;
    }
    .cf-footer__col--social .cf-footer__heading::after { display: none; }
    .cf-footer__social-grid { justify-content: center; }

    /* Bottom bar */
    .cf-footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 20px 6px 28px;
      gap: 14px;
    }
    .cf-footer__payments { justify-content: center; }
  }
</style>


<script>
(function(){
  function initAccordion(){
    if(window.innerWidth > 768) return;
    document.querySelectorAll('.cf-footer__col:not(.cf-footer__col--social) .cf-footer__heading').forEach(function(h){
      if(h.dataset.acc) return;
      h.dataset.acc = '1';
      h.addEventListener('click', function(){
        var ul = h.nextElementSibling;
        var open = ul.classList.contains('is-open');
        h.classList.toggle('is-open', !open);
        ul.classList.toggle('is-open', !open);
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initAccordion);
})();
</script>

