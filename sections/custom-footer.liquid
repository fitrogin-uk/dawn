{% comment %}
  Custom Footer Section — Novomins-inspired layout
  Columns: Logo/Contact/Newsletter | Company | Account | Legal | Follow Us
  Bottom bar: Copyright | Payment icons
{% endcomment %}

<footer class="cf-footer" role="contentinfo">
  <div class="cf-footer__inner">

    <!-- Col 1: Brand -->
    <div class="cf-footer__brand">
      <a href="{{ routes.root_url }}" class="cf-footer__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 180 }}"
            alt="{{ shop.name }}"
            width="180"
            height="auto"
            loading="lazy"
            class="cf-footer__logo-img"
          >
        {%- else -%}
          <span class="cf-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.phone != blank -%}
        <p class="cf-footer__phone">
          <strong>{{ section.settings.phone_label | default: 'Call us on:' }}</strong>
          <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
        </p>
      {%- endif -%}

      <!-- Email signup -->
      <form
        method="post"
        action="/contact#cf-email-form"
        id="cf-email-form"
        class="cf-footer__form"
        accept-charset="UTF-8"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="cf-footer__input-row">
          <input
            type="email"
            name="contact[email]"
            id="cf-email"
            class="cf-footer__input"
            placeholder="{{ section.settings.email_placeholder | default: 'Enter your email' }}"
            autocomplete="email"
            aria-label="{{ section.settings.email_placeholder | default: 'Enter your email' }}"
          >
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by email">
            {% render 'cf-footer-send-icon' %}
          </button>
        </div>
      </form>

      <!-- Phone signup -->
      <form
        method="post"
        action="/contact#cf-phone-form"
        id="cf-phone-form"
        class="cf-footer__form"
        accept-charset="UTF-8"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <div class="cf-footer__input-row">
          <div class="cf-footer__phone-input-wrap">
            <span class="cf-footer__flag" aria-hidden="true">🇬🇧</span>
            <input
              type="tel"
              name="contact[phone]"
              id="cf-phone"
              class="cf-footer__input cf-footer__input--phone"
              placeholder="{{ section.settings.phone_placeholder | default: 'Phone Number' }}"
              autocomplete="tel"
              aria-label="{{ section.settings.phone_placeholder | default: 'Phone Number' }}"
            >
          </div>
          <button type="submit" class="cf-footer__submit-btn" aria-label="Subscribe by phone">
            {% render 'cf-footer-send-icon' %}
          </button>
        </div>
      </form>
    </div>

    <!-- Col 2: Company links -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col2_heading | default: 'Company' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col2_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col2_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 3: Account links -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col3_heading | default: 'Account' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col3_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col3_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 4: Legal links -->
    <div class="cf-footer__col">
      <h3 class="cf-footer__heading">{{ section.settings.col4_heading | default: 'Legal' }}</h3>
      <ul class="cf-footer__links" role="list">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'col4_link' | append: i | append: '_label' -%}
          {%- assign url_key   = 'col4_link' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 5: Social -->
    <div class="cf-footer__col cf-footer__col--social">
      <h3 class="cf-footer__heading">{{ section.settings.social_heading | default: 'Follow Us' }}</h3>
      <div class="cf-footer__social-grid">
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_twitter != blank -%}
          <a href="{{ section.settings.social_twitter }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_linkedin != blank -%}
          <a href="{{ section.settings.social_linkedin }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.27a8.17 8.17 0 0 0 4.78 1.52V5.11a4.85 4.85 0 0 1-1-.42z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_whatsapp != blank -%}
          <a href="{{ section.settings.social_whatsapp }}" class="cf-footer__social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div><!-- /.cf-footer__inner -->

  <!-- Bottom bar -->
  <div class="cf-footer__bottom">
    <p class="cf-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}
    </p>
    <div class="cf-footer__payments">
      {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'cf-footer__payment-icon' }}
    </div>
  </div>

</footer>

<style>
  .cf-footer {
    background-color: {{ section.settings.bg_color | default: '#f5f5f7' }};
    color: {{ section.settings.text_color | default: '#333333' }};
    font-family: inherit;
    padding: 60px 0 0;
  }

  .cf-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Logo */
  .cf-footer__logo-link { display: inline-block; margin-bottom: 14px; }
  .cf-footer__logo-img  { max-width: 180px; height: auto; display: block; }
  .cf-footer__logo-text {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: {{ section.settings.text_color | default: '#333333' }};
    text-decoration: none;
  }

  /* Phone */
  .cf-footer__phone { font-size: 13px; margin: 0 0 16px; color: {{ section.settings.text_color | default: '#333333' }}; }
  .cf-footer__phone a { color: inherit; text-decoration: none; }
  .cf-footer__phone a:hover { text-decoration: underline; }

  /* Forms */
  .cf-footer__form { margin-bottom: 12px; }
  .cf-footer__input-row {
    display: flex;
    align-items: center;
    background: #fff;
    border: 1.5px solid #ddd;
    border-radius: 50px;
    overflow: hidden;
    height: 44px;
    padding-left: 14px;
  }
  .cf-footer__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 13px;
    color: #333;
    min-width: 0;
  }
  .cf-footer__phone-input-wrap {
    display: flex;
    align-items: center;
    flex: 1;
    gap: 6px;
    min-width: 0;
  }
  .cf-footer__flag { font-size: 16px; flex-shrink: 0; }
  .cf-footer__input--phone { flex: 1; }
  .cf-footer__submit-btn {
    background: {{ section.settings.accent_color | default: '#e8175d' }};
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    margin: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s ease;
  }
  .cf-footer__submit-btn:hover {
    background: {{ section.settings.accent_hover | default: '#c0134d' }};
  }
  .cf-footer__submit-btn svg { pointer-events: none; }

  /* Nav columns */
  .cf-footer__heading {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 16px;
    color: {{ section.settings.text_color | default: '#333333' }};
    letter-spacing: 0.02em;
  }
  .cf-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cf-footer__links a {
    font-size: 13px;
    color: {{ section.settings.link_color | default: '#666666' }};
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cf-footer__links a:hover { color: {{ section.settings.accent_color | default: '#e8175d' }}; }

  /* Social */
  .cf-footer__social-grid {
    display: grid;
    grid-template-columns: repeat(3, 40px);
    gap: 10px;
  }
  .cf-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #111;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .cf-footer__social-link:hover {
    background: {{ section.settings.accent_color | default: '#e8175d' }};
    transform: scale(1.08);
  }

  /* Bottom bar */
  .cf-footer__bottom {
    border-top: 1px solid #e0e0e0;
    max-width: 1280px;
    margin: 0 auto;
    padding: 18px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cf-footer__copyright {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .cf-footer__payments {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .cf-footer__payment-icon {
    height: 26px;
    width: auto;
    border-radius: 4px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .cf-footer__inner {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .cf-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .cf-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .cf-footer__brand { grid-column: 1 / -1; }
    .cf-footer__col--social { grid-column: 1 / -1; }
    .cf-footer__social-grid { grid-template-columns: repeat(6, 40px); }
    .cf-footer__bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

{% schema %}
