    { flag: '🇸🇦', name: 'Saudi Arabia',    code: '+966' },
    { flag: '🇶🇦', name: 'Qatar',           code: '+974' },
    { flag: '🇳🇬', name: 'Nigeria',         code: '+234' },
    { flag: '🇰🇪', name: 'Kenya',           code: '+254' },
    { flag: '🇷🇺', name: 'Russia',          code: '+7'   },
    { flag: '🇹🇷', name: 'Turkey',          code: '+90'  }
  ];

  document.addEventListener('DOMContentLoaded', function () {
    var trigger  = document.getElementById('cf-dial-trigger');
    var panel    = document.getElementById('cf-dial-panel');
    var flagEl   = document.getElementById('cf-dial-flag');
    var codeEl   = document.getElementById('cf-dial-code');
    var hidden   = document.getElementById('cf-dial-hidden');
    var listEl   = document.getElementById('cf-dial-list');
    var searchEl = document.getElementById('cf-dial-search');
    if (!trigger || !panel) return;

    /* Build list items */
    COUNTRIES.forEach(function (c, i) {
      var li = document.createElement('li');
      li.setAttribute('role', 'option');
      li.innerHTML =
        '<span class="cf-dial__item-flag">' + c.flag + '</span>' +
        '<span class="cf-dial__item-name">' + c.name + '</span>' +
        '<span class="cf-dial__item-code">' + c.code + '</span>';
      if (i === 0) li.classList.add('is-active');
      li.addEventListener('mousedown', function (e) {
        e.preventDefault();
        select(i);
        close();
      });
      listEl.appendChild(li);
    });

    function select(i) {
      var c = COUNTRIES[i];
      flagEl.textContent = c.flag;
      codeEl.textContent = c.code;
      hidden.value = c.code;
      listEl.querySelectorAll('li').forEach(function (el, j) {
        el.classList.toggle('is-active', j === i);
      });
    }

    function open() {
      panel.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      searchEl.value = '';
      filter('');
      setTimeout(function () { searchEl.focus(); }, 30);
    }

    function close() {
      panel.hidden = true;
      trigger.setAttribute('aria-expanded', 'false');
    }

    function filter(q) {
      var lq = q.toLowerCase();
      listEl.querySelectorAll('li').forEach(function (li, i) {
        li.hidden = !(COUNTRIES[i].name.toLowerCase().includes(lq) || COUNTRIES[i].code.includes(lq));
      });
    }

    trigger.addEventListener('click', function () {
      panel.hidden ? open() : close();
    });
    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
      if (e.key === 'Escape') close();
    });
    searchEl.addEventListener('input', function () { filter(searchEl.value); });
    searchEl.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

    document.addEventListener('click', function (e) {
      if (!trigger.closest('.cf-footer__form').contains(e.target)) close();
    });
  });
})();
</script>

