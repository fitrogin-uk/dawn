{% comment %}
  Shopify Custom Footer Template - Structural Part with Restored Schema
  Save this content as 'sections/custom-footer.liquid'
{% endcomment %}

<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand Logo & Phone Number -->
    <div class="footer-column brand-column">
      <div class="footer-logo-wrapper">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 250 }}" alt="{{ shop.name }}" class="footer-logo">
        {% else %}
          <h2 class="footer-brand-name">{{ shop.name }}</h2>
        {% endif %}
      </div>
      
      {% if section.settings.phone_number != blank %}
        <p class="footer-phone">Call us on: <a href="tel:{{ section.settings.phone_number }}">{{ section.settings.phone_number }}</a></p>
      {% endif %}
    </div>

    <!-- Column 2: Hardcoded Company Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Company</h3>
      <ul class="footer-menu-links">
        <li><a href="/blogs/news">Blogs</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/about-us">Who We Are</a></li>
      </ul>
    </div>

    <!-- Column 3: Hardcoded Account Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Account</h3>
      <ul class="footer-menu-links">
        <li><a href="/account/login">Login</a></li>
        <li><a href="/account/register">Register</a></li>
        <li><a href="/account">My Orders</a></li>
      </ul>
    </div>

    <!-- Column 4: Hardcoded Legal Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Legal</h3>
      <ul class="footer-menu-links">
        <li><a href="/policies/terms-of-service">Terms of Service</a></li>
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        <li><a href="/policies/refund-policy">Refund Policy</a></li>
      </ul>
    </div>

    <!-- Column 5: Hardcoded Follow Us Social Column (Always Displayed & Clickable) -->
    <div class="footer-column social-column">
      <h3 class="footer-heading">Follow Us</h3>
      <div class="social-icons">
        <!-- Facebook Link -->
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 12.991 22 12z"/></svg>
        </a>
        
        <!-- Instagram Link -->
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.668-.072-4.948-.2-4.358-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>

        <!-- Premium WhatsApp Circular Branding Logo -->
        <a href="https://wa.me" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.004 0C5.374 0 .002 5.372.002 12.001c0 2.112.551 4.171 1.597 5.977L.023 24l6.19-1.623c1.745.952 3.715 1.453 5.787 1.454 6.63 0 12.002-5.372 12.002-12.001C24.002 5.372 18.63 0 12.004 0zm0 21.992c-1.892 0-3.748-.51-5.375-1.47l-.385-.23-3.667.962.98-3.575-.252-.4c-1.054-1.68-1.61-3.623-1.61-5.642.003-5.513 4.487-9.997 10.006-9.997 2.672 0 5.184 1.042 7.075 2.934a9.923 9.923 0 0 1 2.93 7.072c-.003 5.515-4.487 10.001-10.002 10.001zM16.92 14.1c-.27-.135-1.59-.785-1.836-.874-.245-.09-.424-.134-.6.134-.177.27-.686.874-.842 1.053-.156.18-.313.202-.582.067-.27-.135-1.137-.42-2.167-1.34-.8-.713-1.34-1.595-1.497-1.864-.157-.27-.017-.415.118-.55.122-.12.27-.314.405-.471.134-.157.18-.27.27-.45.09-.18.044-.336-.023-.471-.067-.134-.6-1.446-.823-1.984-.216-.522-.435-.451-.6-.46-.156-.008-.335-.008-.514-.008-.18 0-.47.067-.716.336-.246.27-1.41 1.37-1.41 3.341 0 1.972 1.433 3.876 1.633 4.146.2.27 2.82 4.305 6.83 6.035.955.412 1.698.658 2.28.843.96.305 1.833.262 2.523.159.77-.116 2.375-.972 2.71-1.913.336-.941.336-1.748.236-1.916-.1-.168-.37-.27-.64-.405z"/></svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Copyright & Settings -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <div class="copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. All rights reserved.
      </div>
      
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Modern Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "01863723207"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Modern Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Company" } },
        { "type": "link_list", "settings": { "heading": "Account" } },
        { "type": "link_list", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}


<style>
  /* Outer background settings */
  footer.site-footer,
  .site-footer {
    background: transparent !important;
    background-color: transparent !important;
    padding-top: 40px !important;
    padding-bottom: 0px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  /* Main Layout Box Container with exactly 3vw / 3vw margins and 94vw width */
  .footer-container {
    background-color: #f7f7f7 !important;
    margin-left: 3vw !important;                
    margin-right: 3vw !important;               
    width: 94vw !important;                     
    max-width: 100% !important;                  
    padding: 60px 40px 10px 40px !important; 
    border-radius: 24px 24px 0 0 !important;
    display: flex !important;
    flex-wrap: nowrap !important;
    justify-content: space-between !important;
    align-items: flex-start !important;        
    gap: 20px !important;
    box-sizing: border-box !important;
  }

  /* Logo adjustment configurations alignment */
  .footer-logo-wrapper {
    margin-top: -16px !important;             
    margin-bottom: 20px !important;
    display: block !important;
    line-height: 1 !important;                 
  }
  
  .footer-logo {
    max-width: 135px !important;              
    height: auto !important;
    display: block !important;
  }

  .footer-brand-name {
    margin: 0 0 20px 0 !important;
    font-size: 22px !important;
    line-height: 1 !important;
  }

  .footer-phone {
    font-size: 14px !important;
    margin-bottom: 15px !important;
  }

  /* Bottom copyright panel dimensions matching 3vw / 3vw / 94vw */
  .footer-bottom {
    margin-left: 3vw !important;                
    margin-right: 3vw !important;               
    width: 94vw !important;                     
    max-width: 100% !important;
    background-color: #f7f7f7 !important;
    padding: 0 40px 40px 40px !important;
    border-radius: 0px !important;
    box-sizing: border-box !important;
  }

  .footer-bottom-container {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-top: none !important; 
    padding-top: 10px !important;
    width: 100% !important;
  }

  /* Sizing rules for columns */
  .footer-column {
    flex: 1 !important;
    min-width: 120px !important;
  }

  .brand-column {
    flex: 0 0 25% !important;
    min-width: 240px !important;
  }

  /* Bold Header Fonts styling */
  .footer-heading {
    font-size: 17px !important;                
    text-transform: uppercase !important;
    margin: 0 0 20px 0 !important;             
    font-weight: 800 !important;               
    letter-spacing: 1.2px !important;
    line-height: 1 !important;
    color: #000 !important;
  }

  .footer-menu-links {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .footer-menu-links li {
    margin-bottom: 12px !important;
  }

  .footer-menu-links a {
    text-decoration: none !important;
    color: #555 !important;
    font-size: 14px !important;
  }

  .footer-menu-links a:hover {
    color: #000 !important;
  }

  /* High-visibility Social Icons Setup */
  .social-icons {
    display: flex !important;
    gap: 15px !important;
    margin-top: 15px !important;
  }

  .social-icons a {
    color: #000 !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 24px !important;                    
    height: 24px !important;
    transition: transform 0.2s ease !important;
  }

  .social-icons a:hover {
    transform: scale(1.1) !important;
  }

  .social-icons svg {
    width: 100% !important;
    height: 100% !important;
    display: block !important;
  }

  /* Responsive breakpoints properties matrix */
  @media (max-width: 1150px) {
    .footer-container, .footer-bottom {
      flex-wrap: wrap !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      width: 100% !important;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column !important;
      padding: 30px 20px !important;
      gap: 30px !important;
    }
    .footer-bottom {
      padding: 0 20px 30px 20px !important;
    }
    .footer-bottom-container {
      flex-direction: column !important;
      gap: 15px !important;
      text-align: center !important;
    }
  }
</style>
