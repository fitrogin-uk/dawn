{% comment %}
  Shopify Custom Footer Template - Structural Part
  Save this content as 'sections/custom-footer.liquid'
{% endcomment %}

<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand Logo & Phone Number -->
    <div class="footer-column brand-column">
      <div class="footer-logo-wrapper">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 250 }}" alt="{{ shop.name }}" class="footer-logo">
        {% else %}
          <h2 class="footer-brand-name">{{ shop.name }}</h2>
        {% endif %}
      </div>
      
      {% if section.settings.phone_number != blank %}
        <p class="footer-phone">Call us on: <a href="tel:{{ section.settings.phone_number }}">{{ section.settings.phone_number }}</a></p>
      {% endif %}
    </div>

    <!-- Column 2: Hardcoded Company Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Company</h3>
      <ul class="footer-menu-links">
        <li><a href="/blogs/news">Blogs</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/about-us">Who We Are</a></li>
      </ul>
    </div>

    <!-- Column 3: Hardcoded Account Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Account</h3>
      <ul class="footer-menu-links">
        <li><a href="/account/login">Login</a></li>
        <li><a href="/account/register">Register</a></li>
        <li><a href="/account">My Orders</a></li>
      </ul>
    </div>

    <!-- Column 4: Hardcoded Legal Menu -->
    <div class="footer-column menu-column">
      <h3 class="footer-heading">Legal</h3>
      <ul class="footer-menu-links">
        <li><a href="/policies/terms-of-service">Terms of Service</a></li>
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        <li><a href="/policies/refund-policy">Refund Policy</a></li>
      </ul>
    </div>

    <!-- Column 5: Hardcoded Follow Us Social Column (Circular Solid Icons Layout) -->
    <div class="footer-column social-column">
      <h3 class="footer-heading">Follow Us</h3>
      <div class="social-icons">
        <!-- Solid Facebook Circle Icon -->
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook" class="social-circle-btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12a12 12 0 10-13.875 11.854v-8.385H7.078V12h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874V12h3.328l-.532 3.469h-2.796v8.385A12.001 12.001 0 0024 12z"/></svg>
        </a>
        
        <!-- Solid Instagram Circle Icon -->
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram" class="social-circle-btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.921 15.65c0 1.25-.213 1.954-1.127 2.868-.913.914-1.617 1.127-2.868 1.127H10.07c-1.251 0-1.955-.213-2.868-1.127-.914-.914-1.127-1.617-1.127-2.868V10.07c0-1.251.213-1.955 1.127-2.868.913-.914 1.617-1.127 2.868-1.127h3.856c1.251 0 1.955.213 2.868 1.127.914.913 1.127 1.617 1.127 2.868v5.58zm-5.921-8.118a4.468 4.468 0 100 8.936 4.468 4.468 0 000-8.936zm0 7.35a2.883 2.883 0 110-5.766 2.883 2.883 0 010 5.766zm4.561-6.83a1.045 1.045 0 100 2.091 1.045 1.045 0 000-2.091z"/></svg>
        </a>

        <!-- Solid WhatsApp Circle Icon -->
        <a href="https://wa.me" target="_blank" rel="noopener" aria-label="WhatsApp" class="social-circle-btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12a11.933 11.933 0 001.815 6.353L.027 24l5.807-1.523A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm5.637 15.65c-.244.685-1.42 1.252-1.955 1.336-.484.077-.96.06-1.536-.123-.346-.11-1.393-.541-2.935-1.228-2.632-1.085-4.331-3.76-4.463-3.935-.13-.175-1.066-1.417-1.066-2.703 0-1.286.673-1.919.912-2.164.24-.245.52-.307.693-.307.174 0 .347.001.498.008.156.007.364-.06.57.45.21.524.723 1.761.786 1.893.064.131.107.284.02.46-.088.174-.132.283-.263.435-.13.152-.275.339-.393.454-.132.128-.27.268-.117.53.153.262.68 1.118 1.458 1.81.998.889 1.838 1.164 2.099 1.295.262.131.415.11.568-.065.153-.175.655-.762.83-1.024.175-.262.35-.218.59-.131.24.087 1.529.72 1.79 1.85.262 1.13.262 2.113-.044 2.798z"/></svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Copyright & Settings -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <div class="copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. All rights reserved.
      </div>
      
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Modern Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "01863723207"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Modern Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Company" } },
        { "type": "link_list", "settings": { "heading": "Account" } },
        { "type": "link_list", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
<style>
  /* Outer background settings */
  footer.site-footer,
  .site-footer {
    background: transparent !important;
    background-color: transparent !important;
    padding-top: 40px !important;
    padding-bottom: 0px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  /* Main Layout Box Container with 3% Margins */
  .footer-container {
    background-color: #f7f7f7 !important;
    margin-left: 3vw !important;                
    margin-right: 3vw !important;               
    width: 94vw !important;                     
    max-width: 100% !important;                  
    padding: 60px 40px 10px 40px !important; 
    border-radius: 24px 24px 0 0 !important;
    display: flex !important;
    flex-wrap: nowrap !important;
    justify-content: space-between !important;
    align-items: flex-start !important;        
    gap: 20px !important;
    box-sizing: border-box !important;
  }

  /* Logo adjustment configurations alignment */
  .footer-logo-wrapper {
    margin-top: -16px !important;             
    margin-bottom: 20px !important;
    display: block !important;
    line-height: 1 !important;                 
  }
  
  .footer-logo {
    max-width: 135px !important;              
    height: auto !important;
    display: block !important;
  }

  .footer-brand-name {
    margin: 0 0 20px 0 !important;
    font-size: 22px !important;
    line-height: 1 !important;
  }

  .footer-phone {
    font-size: 14px !important;
    margin-bottom: 15px !important;
  }

  /* Bottom copyright panel dimensions */
  .footer-bottom {
    margin-left: 3vw !important;                
    margin-right: 3vw !important;               
    width: 94vw !important;                     
    max-width: 100% !important;
    background-color: #f7f7f7 !important;
    padding: 0 40px 40px 40px !important;
    border-radius: 0px !important;
    box-sizing: border-box !important;
  }

  .footer-bottom-container {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-top: none !important; 
    padding-top: 10px !important;
    width: 100% !important;
  }

  /* Sizing rules for columns */
  .footer-column {
    flex: 1 !important;
    min-width: 120px !important;
  }

  .brand-column {
    flex: 0 0 25% !important;
    min-width: 240px !important;
  }

  /* Bold Header Fonts styling */
  .footer-heading {
    font-size: 17px !important;                
    text-transform: uppercase !important;
    margin: 0 0 20px 0 !important;             
    font-weight: 800 !important;               
    letter-spacing: 1.2px !important;
    line-height: 1 !important;
    color: #000 !important;
  }

  .footer-menu-links {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .footer-menu-links li {
    margin-bottom: 12px !important;
  }

  .footer-menu-links a {
    text-decoration: none !important;
    color: #555 !important;
    font-size: 14px !important;
  }

  .footer-menu-links a:hover {
    color: #000 !important;
  }

  /* High-visibility Solid Round Social Buttons */
  .social-icons {
    display: flex !important;
    gap: 12px !important;
    margin-top: 15px !important;
  }

  .social-circle-btn {
    color: #1a1a1a !important;                 /* Solid background color from shared images */
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 36px !important;                    /* Balanced size footprint */
    height: 36px !important;
    border-radius: 50% !important;             /* Creates perfect circular boundary */
    transition: transform 0.2s ease, opacity 0.2s ease !important;
    cursor: pointer !important;
  }

  .social-circle-btn:hover {
    transform: scale(1.08) !important;
    opacity: 0.9 !important;
  }

  /* Keeps the interior custom graphics centered cleanly */
  .social-circle-btn svg {
    width: 100% !important;
    height: 100% !important;
    display: block !important;
  }

  /* Responsive breakpoints properties matrix */
  @media (max-width: 1150px) {
    .footer-container, .footer-bottom {
      flex-wrap: wrap !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      width: 100% !important;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column !important;
      padding: 30px 20px !important;
      gap: 30px !important;
    }
    .footer-bottom {
      padding: 0 20px 30px 20px !important;
    }
    .footer-bottom-container {
      flex-direction: column !important;
      gap: 15px !important;
      text-align: center !important;
    }
  }
</style>
