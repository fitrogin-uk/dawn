{% comment %}
  Shopify Custom Footer Template
  Inspired by Novomins Nutrition Footer Layout
  Save this file as 'sections/custom-footer.liquid'
{% endcomment %}

<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand, Contact & Newsletter -->
    <div class="footer-column brand-column">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-logo">
      {% else %}
        <h2 class="footer-brand-name">{{ shop.name }}</h2>
      {% endif %}
      
      {% if section.settings.phone_number != blank %}
        <p class="footer-phone">Call us on: <a href="tel:{{ section.settings.phone_number }}">{{ section.settings.phone_number }}</a></p>
      {% endif %}
      
      <div class="footer-newsletter">
        {% form 'customer' %}
          {{ form.errors | default_errors }}
          {% if form.posted_successfully? %}
            <p class="form-success">Thank you for subscribing!</p>
          {% else %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            
            <div class="input-group">
              <input type="email" name="contact[email]" placeholder="Enter your email" required aria-label="Enter your email">
              <button type="submit" class="btn-submit" aria-label="Submit email">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M1.946 9.315c-.522-.174-.527-.455.01-.634l20.587-6.862c.539-.18.825.1.642.643l-6.862 20.587c-.179.537-.46.532-.634.01L11.42 12.58 1.946 9.315z"/></svg>
              </button>
            </div>

            <div class="input-group">
              <input type="tel" name="contact[phone]" placeholder="Phone Number" aria-label="Phone Number">
              <button type="submit" class="btn-submit" aria-label="Submit phone number">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M1.946 9.315c-.522-.174-.527-.455.01-.634l20.587-6.862c.539-.18.825.1.642.643l-6.862 20.587c-.179.537-.46.532-.634.01L11.42 12.58 1.946 9.315z"/></svg>
              </button>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>

    <!-- Dynamic Menu Columns 2, 3, 4 -->
    {% for block in section.blocks %}
      {% if block.type == 'link_list' %}
        <div class="footer-column menu-column" {{ block.shopify_attributes }}>
          <h3 class="footer-heading">{{ block.settings.heading | escape }}</h3>
          <ul class="footer-menu-links">
            {% for link in block.settings.menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Column 5: Social Media Links -->
    <div class="footer-column social-column">
      <h3 class="footer-heading">Follow Us</h3>
      <div class="social-icons">
        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" target="_blank" aria-label="Facebook">FB</a>
        {% endif %}
        {% if settings.social_twitter_link != blank %}
          <a href="{{ settings.social_twitter_link }}" target="_blank" aria-label="X (Twitter)">X</a>
        {% endif %}
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" target="_blank" aria-label="Instagram">IG</a>
        {% endif %}
        {% if settings.social_linkedin_link != blank %}
          <a href="{{ settings.social_linkedin_link }}" target="_blank" aria-label="LinkedIn">LN</a>
        {% endif %}
        {% if settings.social_tiktok_link != blank %}
          <a href="{{ settings.social_tiktok_link }}" target="_blank" aria-label="TikTok">TT</a>
        {% endif %}
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Copyright & Payment Icons -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <div class="copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. All rights reserved.
      </div>
      
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #f7f7f7;
    color: #333333;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    padding: 60px 0 20px 0;
    font-size: 14px;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr) 1.2fr;
    gap: 40px;
  }
  .footer-column {
    display: flex;
    flex-direction: column;
  }
  .footer-logo {
    max-width: 150px;
    margin-bottom: 15px;
  }
  .footer-brand-name {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 15px 0;
    letter-spacing: -0.5px;
  }
  .footer-phone {
    margin: 0 0 20px 0;
    color: #555;
  }
  .footer-phone a {
    color: inherit;
    text-decoration: none;
  }
  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 260px;
  }
  .input-group {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-group input {
    width: 100%;
    padding: 12px 45px 12px 15px;
    border: 1px solid #cccccc;
    border-radius: 25px;
    font-size: 14px;
    outline: none;
    background: #ffffff;
  }
  .btn-submit {
    position: absolute;
    right: 5px;
    background: #e91e63; /* Custom pink accent color from template */
    color: #ffffff;
    border: none;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .btn-submit:hover {
    background: #d81b60;
  }
  .footer-heading {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 20px 0;
    color: #111111;
  }
  .footer-menu-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-menu-links a {
    color: #666666;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-menu-links a:hover {
    color: #000000;
  }
  .social-icons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #111111;
    color: #ffffff;
    text-decoration: none;
    font-size: 12px;
    font-weight: bold;
  }
  .footer-bottom {
    margin-top: 60px;
    border-top: 1px solid #e5e5e5;
    padding-top: 20px;
  }
  .footer-bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .copyright {
    color: #888888;
    font-size: 13px;
  }
  .payment-icons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .payment-icon {
    width: 38px;
    height: auto;
  }

  /* Responsive Design Styles */
  @media (max-width: 991px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
    .brand-column {
      grid-column: span 2;
      margin-bottom: 10px;
    }
  }
  @media (max-width: 480px) {
    .footer-container {
      grid-template-columns: 1fr;
    }
    .brand-column {
      grid-column: span 1;
    }
    .footer-bottom-container {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Modern Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "01863723207"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Modern Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Company" } },
        { "type": "link_list", "settings": { "heading": "Account" } },
        { "type": "link_list", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
