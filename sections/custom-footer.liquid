<style>
  .site-footer {
    background-color: #f7f7f7;
    color: #333333;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    
    /* Doubled Structural Canvas Spacing & Profile Curve */
    padding: 120px 80px 40px 80px; /* Doubled internal breathing room */
    margin: 0 40px 40px 40px;       /* Doubled external clearance margins */
    border-radius: 48px;            /* Doubled layout profile corner radius */
    
    font-size: 14px;
    overflow: hidden;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr) 1.2fr;
    gap: 80px;                      /* Doubled separation spacing between main columns */
  }
  .footer-column {
    display: flex;
    flex-direction: column;
  }
  .footer-logo {
    max-width: 150px;
    margin-bottom: 30px;            /* Doubled gap under brand mark */
  }
  .footer-brand-name {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 30px 0;             /* Doubled gap under plain title */
    letter-spacing: -0.5px;
  }
  .footer-phone {
    margin: 0 0 40px 0;             /* Doubled gap under telephone details */
    color: #555;
  }
  .footer-phone a {
    color: inherit;
    text-decoration: none;
  }
  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 24px;                      /* Doubled gap between individual inputs */
    max-width: 260px;
  }
  .input-group {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-group input {
    width: 100%;
    padding: 12px 45px 12px 15px;
    border: 1px solid #cccccc;
    border-radius: 25px;
    font-size: 14px;
    outline: none;
    background: #ffffff;
  }
  .btn-submit {
    position: absolute;
    right: 5px;
    background: #e91e63;
    color: #ffffff;
    border: none;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .btn-submit:hover {
    background: #d81b60;
  }
  .footer-heading {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 40px 0;             /* Doubled spacing below titles */
    color: #111111;
  }
  .footer-menu-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;                      /* Doubled navigation list row heights */
  }
  .footer-menu-links a {
    color: #666666;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-menu-links a:hover {
    color: #000000;
  }

  /* Inline SVG Icon Wrapper Adjustments */
  .social-icons {
    display: flex;
    gap: 24px;                      /* Doubled gap between app badges */
    flex-wrap: wrap;
  }
  .social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #111111;
    color: #ffffff;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .social-icons a:hover {
    transform: scale(1.08);
    background: #e91e63;
  }
  .social-icons svg {
    width: 18px;
    height: 18px;
  }

  .footer-bottom {
    margin-top: 120px;              /* Doubled elevation clearance above horizontal line */
    border-top: 1px solid #e5e5e5;
    padding-top: 40px;              /* Doubled top shelf height for fine print rows */
  }
  .footer-bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 40px;                      /* Doubled responsive row wraps */
  }
  .copyright {
    color: #888888;
    font-size: 13px;
  }
  .payment-icons {
    display: flex;
    gap: 16px;                      /* Doubled gateway shield separations */
    flex-wrap: wrap;
  }
  .payment-icon {
    width: 38px;
    height: auto;
  }

  /* Responsive Spacing Strategy */
  @media (max-width: 991px) {
    .site-footer {
      padding: 80px 48px 40px 48px;
      margin: 0 20px 20px 20px;
      border-radius: 32px;
    }
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }
    .brand-column {
      grid-column: span 2;
      margin-bottom: 20px;
    }
  }
  @media (max-width: 480px) {
    .site-footer {
      padding: 60px 24px 30px 24px;
      margin: 0 10px 10px 10px;
      border-radius: 24px;
    }
    .footer-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .brand-column {
      grid-column: span 1;
    }
    .footer-bottom-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 30px;
    }
  }
</style>
