{% comment %}
  Shopify Custom Footer Template - Structural Part
  Inspired by Novomins Nutrition Footer Layout
  Save this content as 'sections/custom-footer.liquid'
{% endcomment %}

<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand, Contact & Newsletter -->
    <div class="footer-column brand-column">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-logo">
      {% else %}
        <h2 class="footer-brand-name">{{ shop.name }}</h2>
      {% endif %}
      
      {% if section.settings.phone_number != blank %}
        <p class="footer-phone">Call us on: <a href="tel:{{ section.settings.phone_number }}">{{ section.settings.phone_number }}</a></p>
      {% endif %}
      
      <div class="footer-newsletter">
        {% form 'customer' %}
          {{ form.errors | default_errors }}
          {% if form.posted_successfully? %}
            <p class="form-success">Thank you for subscribing!</p>
          {% else %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            
            <div class="input-group">
              <input type="email" name="contact[email]" placeholder="Enter your email" required aria-label="Enter your email">
              <button type="submit" class="btn-submit" aria-label="Submit email">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M1.946 9.315c-.522-.174-.527-.455.01-.634l20.587-6.862c.539-.18.825.1.642.643l-6.862 20.587c-.179.537-.46.532-.634.01L11.42 12.58 1.946 9.315z"/></svg>
              </button>
            </div>

            <div class="input-group">
              <input type="tel" name="contact[phone]" placeholder="Phone Number" aria-label="Phone Number">
              <button type="submit" class="btn-submit" aria-label="Submit phone number">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M1.946 9.315c-.522-.174-.527-.455.01-.634l20.587-6.862c.539-.18.825.1.642.643l-6.862 20.587c-.179.537-.46.532-.634.01L11.42 12.58 1.946 9.315z"/></svg>
              </button>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>

    <!-- Dynamic Menu Columns 2, 3, 4 -->
    {% for block in section.blocks %}
      {% if block.type == 'link_list' %}
        <div class="footer-column menu-column" {{ block.shopify_attributes }}>
          <h3 class="footer-heading">{{ block.settings.heading | escape }}</h3>
          <ul class="footer-menu-links">
            {% for link in block.settings.menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Column 5: Social Media Links (Native Brand SVGs) -->
    <div class="footer-column social-column">
      <h3 class="footer-heading">Follow Us</h3>
      <div class="social-icons">
        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" target="_blank" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 12.991 22 12z"/></svg>
          </a>
        {% endif %}
        {% if settings.social_twitter_link != blank %}
          <a href="{{ settings.social_twitter_link }}" target="_blank" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {% endif %}
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" target="_blank" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.668-.072-4.948-.2-4.358-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {% endif %}
        {% if settings.social_linkedin_link != blank %}
          <a href="{{ settings.social_linkedin_link }}" target="_blank" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        {% endif %}
        {% if settings.social_tiktok_link != blank %}
          <a href="{{ settings.social_tiktok_link }}" target="_blank" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.01 1.61 4.19 1.12 1.24 2.68 1.96 4.3 2.13v3.83c-1.39-.07-2.74-.58-3.86-1.47-.78-.62-1.4-1.42-1.82-2.33v7.02c.04 2.12-.62 4.22-1.89 5.91-1.63 2.24-4.22 3.6-6.98 3.65-2.6-.01-5.11-1.24-6.68-3.32-1.71-2.23-2.18-5.26-1.25-7.91C1.22 8.92 3.6 6.84 6.42 6.4c1.23-.2 2.49-.04 3.64.47v4.02c-.81-.43-1.72-.6-2.63-.48-1.45.18-2.73 1.15-3.32 2.49-.66 1.48-.48 3.28.48 4.59 1 1.33 2.64 2.11 4.3 2.06 1.63.02 3.16-.86 3.91-2.31.42-.78.63-1.65.61-2.53V.02z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Copyright & Payment Icons -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <div class="copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. All rights reserved.
      </div>
      
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Modern Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "01863723207"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Modern Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Company" } },
        { "type": "link_list", "settings": { "heading": "Account" } },
        { "type": "link_list", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
<style>
  /* Outer area wrapper set to transparent */
  footer.site-footer,
  .site-footer {
    background: transparent !important;
    background-color: transparent !important;
    padding-top: 40px !important;
    padding-bottom: 0px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  /* 
    Main footer layout block.
    Forces both margins to be completely equal at exactly 1vw (1% of viewport width).
    The width is calculated to occupy exactly 98% of the remaining screen space.
  */
  .footer-container {
    background-color: #f7f7f7 !important;
    margin-left: 1vw !important;                 /* Absolute 1% screen margin on left */
    margin-right: 1vw !important;                /* Absolute 1% screen margin on right */
    width: 98vw !important;                      /* Total container width matches 98% */
    max-width: 100% !important;                  /* Unlocks restrictions to prevent scaling errors */
    padding: 50px 40px 30px 40px !important;
    border-radius: 24px 24px 0 0 !important;
    display: flex !important;
    flex-wrap: nowrap !important;
    justify-content: space-between !important;
    gap: 20px !important;
    box-sizing: border-box !important;
  }

  /* Bottom copyright bar matches the 1% viewport matrix layout parameters */
  .footer-bottom {
    margin-left: 1vw !important;               
    margin-right: 1vw !important;               
    width: 98vw !important;               
    max-width: 100% !important;
    background-color: #f7f7f7 !important;
    padding: 0 40px 40px 40px !important;
    border-radius: 0px !important;
    box-sizing: border-box !important;
  }

  .footer-bottom-container {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-top: 1px solid #e5e5e5 !important;
    padding-top: 20px !important;
    width: 100% !important;
  }

  /* Standard grid widths for columns */
  .footer-column {
    flex: 1 1 18% !important;
    min-width: 140px !important;
  }

  .brand-column {
    flex: 1 1 28% !important;
    min-width: 240px !important;
  }

  /* Input form visual settings */
  .input-group {
    display: flex !important;
    margin-bottom: 10px !important;
    max-width: 240px !important;
  }

  .input-group input {
    flex: 1 !important;
    padding: 10px 15px !important;
    border: 1px solid #e0e0e0 !important;
    border-radius: 20px 0 0 20px !important;
    outline: none !important;
    font-size: 14px !important;
    background-color: #fff !important;
  }

  .btn-submit {
    background-color: #e91e63 !important;
    color: #fff !important;
    border: none !important;
    padding: 0 15px !important;
    border-radius: 0 20px 20px 0 !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* Responsive styling rules */
  @media (max-width: 1150px) {
    .footer-container, .footer-bottom {
      flex-wrap: wrap !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      width: 100% !important;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column !important;
      padding: 30px 20px !important;
    }
    .footer-bottom {
      padding: 0 20px 30px 20px !important;
    }
    .footer-bottom-container {
      flex-direction: column !important;
      gap: 15px !important;
      text-align: center !important;
    }
  }
</style>
