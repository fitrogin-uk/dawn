<div class="gummy-features-section gummy-{{ section.id }}">
  <div class="gummy-container">
    {%- if section.settings.title != blank -%}
      <h2 class="gummy-main-title">
        <span>{{ section.settings.title }}</span>
      </h2>
    {%- endif -%}

    <div class="gummy-grid">
      {%- for block in section.blocks -%}
        <div class="gummy-card" {{ block.shopify_attributes }}>
          <div class="gummy-icon-wrapper">
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 300 }}" 
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="auto"
                height="auto"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'gummy-placeholder' }}
            {%- endif -%}
          </div>
          
          <h3 class="gummy-card-title">{{ block.settings.title }}</h3>
          
          <div class="gummy-card-text">
            {{ block.settings.text }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
.gummy-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* Wide screen boundary layout */
.gummy-container {
  max-width: 1800px;
  margin: 0 auto;
  padding: 0 50px;
}

/* Section Header flexbox setup to put line horizontally next to text */
.gummy-main-title {
  display: flex;
  align-items: center;
  font-size: 38px;
  font-weight: 700;
  color: #1a1a1a;
  margin-top: 0;
  margin-bottom: 50px;
  font-family: inherit;
  width: 100%;
}

/* Horizontal line starting right after the text ends */
.gummy-main-title::after {
  content: '';
  flex-grow: 1;
  height: 1px;
  background-color: #e0e0e0;
  margin-left: 20px;
}

/* Desktop Grid Setup */
.gummy-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16px;
}

/* 
  DESKTOP BOX ADJUSTMENTS:
  - Vertical inner padding: 72px
  - Horizontal inner padding: 33px
*/
.gummy-card {
  background-color: #f5f5f5;
  border-radius: 20px;
  padding: 72px 33px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
}

/* Desktop Icon Wrapper Zone */
.gummy-icon-wrapper {
  height: 143px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35px;
  width: 100%;
}

.gummy-icon-wrapper img {
  max-height: 100%;
  max-width: 100%;
  object-fit: contain;
}

.gummy-placeholder {
  width: 100px;
  height: 100px;
  fill: #999;
}

/* Card typography styling */
.gummy-card-title {
  font-size: 21px;
  font-weight: 700;
  color: #222222;
  margin-top: 0;
  margin-bottom: 20px;
}

.gummy-card-text {
  font-size: 16px;
  line-height: 1.6;
  color: #4a4a4a;
}

.gummy-card-text p {
  margin: 0;
}

/* Tablet Responsive Breakpoint */
@media (max-width: 1400px) {
  .gummy-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
}

/* 
  MOBILE OPTIMIZATION (SCROLL & SMALL SIZE)
  Applies to mobile layout widths up to 768px
*/
@media (max-width: 768px) {
  .gummy-container {
    padding: 0 10px;
    overflow: hidden; /* Avoids breaking parent containers */
  }

  /* Main Title Scaling */
  .gummy-main-title {
    font-size: 24px;
    margin-bottom: 30px;
  }

  /* Converts grid into a fluid horizontal scroller */
  .gummy-grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 12px;
    padding-bottom: 15px; /* Clear room for smooth touch actions */
    margin-right: -20px;  /* Lets cards elegantly bleed past container edges */
    padding-right: 20px;
  }

  /* Hides ugly native browser scrollbars */
  .gummy-grid::-webkit-scrollbar {
    display: none;
  }
  .gummy-grid {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* 
    DOWNSIZED MOBILE CARDS:
    - Sized at 75% viewport width so users can easily see there are more cards to horizontal scroll to
    - Significantly tightened internal paddings for mobile screens
  */
  .gummy-card {
    flex: 0 0 75%; 
    scroll-snap-align: start;
    padding: 35px 20px; 
    border-radius: 14px;
  }

  /* Compacted Mobile Icons */
  .gummy-icon-wrapper {
    height: 70px;
    margin-bottom: 15px;
  }

  .gummy-placeholder {
    width: 55px;
    height: 55px;
  }

  /* Compact Mobile Text */
  .gummy-card-title {
    font-size: 16px;
    margin-bottom: 10px;
  }

  .gummy-card-text {
    font-size: 13px;
    line-height: 1.5;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Gummy Trust Features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Delicious Gummy Vitamins"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge Icon/Logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Card Description",
          "default": "<p>Add short descriptive text here matching your badge asset.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gummy Trust Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "B Corp Certified" } },
        { "type": "feature", "settings": { "title": "Cruelty Free" } },
        { "type": "feature", "settings": { "title": "3rd Party Tested" } },
        { "type": "feature", "settings": { "title": "FDA Registered Facility" } },
        { "type": "feature", "settings": { "title": "GMP Certified" } },
        { "type": "feature", "settings": { "title": "Expert Formulated" } }
      ]
    }
  ]
}
{% endschema %}