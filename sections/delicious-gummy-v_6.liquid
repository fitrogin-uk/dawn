<div class="gummy-features-section gummy-{{ section.id }}">
  <div class="gummy-container">
    {%- if section.settings.title != blank -%}
      <h2 class="gummy-main-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="gummy-grid">
      {%- for block in section.blocks -%}
        <div class="gummy-card" {{ block.shopify_attributes }}>
          <div class="gummy-icon-wrapper">
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 150 }}" 
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="auto"
                height="auto"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'gummy-placeholder' }}
            {%- endif -%}
          </div>
          
          <h3 class="gummy-card-title">{{ block.settings.title }}</h3>
          
          <div class="gummy-card-text">
            {{ block.settings.text }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
.gummy-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.gummy-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.gummy-main-title {
  font-size: 28px;
  font-weight: 700;
  color: #1a1a1a;
  margin-top: 0;
  margin-bottom: 30px;
  font-family: inherit;
  position: relative;
}

/* Horizontal line under title matching image layout */
.gummy-main-title::after {
  content: '';
  display: block;
  width: 100%;
  height: 1px;
  background-color: #e0e0e0;
  margin-top: 15px;
}

.gummy-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 15px;
}

.gummy-card {
  background-color: #f5f5f5;
  border-radius: 12px;
  padding: 25px 15px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gummy-icon-wrapper {
  height: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.gummy-icon-wrapper img {
  max-height: 100%;
  max-width: 100%;
  object-fit: contain;
}

.gummy-placeholder {
  width: 50px;
  height: 50px;
  fill: #999;
}

.gummy-card-title {
  font-size: 16px;
  font-weight: 600;
  color: #222222;
  margin-top: 0;
  margin-bottom: 12px;
}

.gummy-card-text {
  font-size: 13px;
  line-height: 1.5;
  color: #707070;
}

.gummy-card-text p {
  margin: 0;
}

/* Responsive Breakpoints */
@media (max-width: 1024px) {
  .gummy-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
}

@media (max-width: 600px) {
  .gummy-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }
  .gummy-main-title {
    font-size: 22px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Gummy Trust Features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Delicious Gummy Vitamins"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge Icon/Logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Card Description",
          "default": "<p>Add short descriptive text here matching your badge asset.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gummy Trust Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "B Corp Certified" } },
        { "type": "feature", "settings": { "title": "Cruelty Free" } },
        { "type": "feature", "settings": { "title": "3rd Party Tested" } },
        { "type": "feature", "settings": { "title": "FDA Registered Facility" } },
        { "type": "feature", "settings": { "title": "GMP Certified" } },
        { "type": "feature", "settings": { "title": "Expert Formulated" } }
      ]
    }
  ]
}
{% endschema %}

