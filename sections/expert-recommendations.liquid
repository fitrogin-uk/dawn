{% comment %}
  Expert & Customer Reviews Wide-Grid Section
  - Part 1 of 2: Handles rendering markup and style sheets
{% endcomment %}

<div class="reviews-section-wrapper color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="section-heading-container">
        <h2 class="reviews-main-heading">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="reviews-subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="reviews-flexible-grid">
      {%- for block in section.blocks -%}
        <div class="review-card-item" {{ block.shopify_attributes }}>
          
          <!-- Top Section: Image Box -->
          <div class="review-image-container">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 33vw, 100vw',
                class: 'review-card-img'
              }}
            {%- else -%}
              <div class="review-image-placeholder">
                <svg xmlns="http://w3.org" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="placeholder-icon">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <!-- Bottom Section: Content Text Box -->
          <div class="review-text-container">
            
            <div class="review-quote-content">
              <p class="review-quote-text">
                {%- if block.settings.quote_text != blank -%}
                  “{{ block.settings.quote_text | escape }}”
                {%- else -%}
                  "Review text goes here..."
                {%- endif -%}
              </p>
              
              {%- if block.settings.product_tag != blank -%}
                <p class="review-product-tag">{{ block.settings.product_tag | escape }}</p>
              {%- endif -%}
            </div>

            <!-- Author Info with Embedded Verification Badge -->
            <div class="review-author-meta">
              <div class="review-author-header">
                <h3 class="review-author-name">
                  {{ block.settings.author_name | default: "Name" | escape }}
                </h3>
                
                {%- if block.settings.show_verified -%}
                  <span class="review-verified-badge" aria-label="Verified account">
                    <svg viewBox="0 0 24 24" class="verified-svg-icon">
                      <g>
                        <path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.99-3.818-3.99-.48 0-.94.1-1.348.27C14.825 2.515 13.512 1.5 12 1.5s-2.825 1.015-3.422 2.28c-.406-.17-.866-.27-1.348-.27-2.108 0-3.818 1.78-3.818 3.99 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.58.875 2.95 2.148 3.6-.154.435-.238.905-.238 1.4 0 2.21 1.71 3.99 3.818 3.99.48 0 .94-.1 1.348-.27.597 1.265 1.91 2.28 3.422 2.28s2.825-1.015 3.422-2.28c.406.17.866.27 1.348.27 2.108 0 3.818-1.78 3.818-3.99 0-.495-.084-.965-.238-1.4 1.273-.65 2.148-2.02 2.148-3.6zm-12.72 4.212l-3.32-3.32 1.414-1.414 1.906 1.906 5.17-5.17 1.414 1.414-6.584 6.584z"></path>
                      </g>
                    </svg>
                  </span>
                {%- endif -%}
              </div>
              
              {%- if block.settings.author_title != blank -%}
                <p class="review-author-title">{{ block.settings.author_title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.author_location != blank -%}
                <p class="review-author-location">{{ block.settings.author_location | escape }}</p>
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  /* Layout Spacing Overrides to maximize horizontal scale */
  .reviews-section-wrapper {
    width: 100% !important;
    box-sizing: border-box !important;
    background-color: #ffffff !important;
    padding-left: 2.5rem !important;
    padding-right: 2.5rem !important;
    display: block !important;
    clear: both !important;
  }

  /* Forces container wide, overriding template rules */
  .reviews-section-wrapper .page-width {
    max-width: 1600px !important; 
    width: 100% !important;
    padding: 0 !important;
    margin: 0 auto !important;
  }

  .section-heading-container {
    text-align: left;
    margin-bottom: 44px;
  }

  .reviews-main-heading {
    font-size: 32px;
    font-weight: 700;
    color: #1c1e24;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .reviews-subheading {
    font-size: 16px;
    color: #6b7280;
    margin: 0;
  }

  /* Flex Grid Engine rules */
  .reviews-flexible-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)) !important;
    gap: 40px !important; 
    align-items: start !important;
    width: 100% !important;
  }

  /* Card Block Design formatting */
  .review-card-item {
    background: #ffffff !important;
    border: 1px solid #f3f4f6 !important;
    border-radius: 24px !important;
    overflow: hidden !important;
    display: flex !important;
    flex-direction: column !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important;
    transition: transform 0.2s ease !important;
    height: 100% !important;
  }

  /* Vertically scales up portraits smoothly */
  .review-image-container {
    position: relative !important;
    width: 100% !important;
    height: 440px !important; 
    background-color: #e5e7eb !important;
    overflow: hidden !important;
  }

  .review-card-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: top center !important;
  }

  .review-image-placeholder {
    width: 100% !important;
    height: 100% !important;
    background-color: #e5e7eb !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .placeholder-icon {
    width: 64px !important;
    height: 64px !important;
    color: #9ca3af !important;
  }

  /* Spacings within Text Content boxes */
  .review-text-container {
    padding: 36px !important; 
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
    flex-grow: 1 !important;
  }

  .review-quote-content {
    margin-bottom: 32px !important;
  }

  .review-quote-text {
    font-size: 20px !important;
    line-height: 1.6 !important;
    font-weight: 400 !important;
    color: #2d3142 !important;
    margin: 0 0 16px 0 !important;
  }

  .review-product-tag {
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #9ca3af !important;
    margin: 0 !important;
    text-transform: capitalize !important;
  }

  /* Profile alignment row */
  .review-author-meta {
    display: flex !important;
    flex-direction: column !important;
    gap: 4px !important;
    border-top: 1px solid #f3f4f6 !important;
    padding-top: 20px !important;
  }

  .review-author-header {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
  }

  .review-author-name {
    font-size: 24px;
    font-weight: 600;
    color: #1c1e24;
    margin: 0 !important;
  }

  .review-verified-badge {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 20px !important;
    height: 20px !important;
    color: #1d9bf0 !important;
    flex-shrink: 0 !important;
  }

  .verified-svg-icon {
    width: 100% !important;
    height: 100% !important;
    fill: currentColor !important;
  }

  .review-author-title {
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #6b7280 !important;
    margin: 0 !important;
  }

  .review-author-location {
    font-size: 12px !important;
    color: #9ca3af !important;
    margin: 0 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
  }

  /* Breakpoint Handling for Mobile viewports */
  @media screen and (max-width: 749px) {
    .reviews-section-wrapper {
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
    }
    .reviews-flexible-grid {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
    .review-image-container {
      height: 340px !important;
    }
    .review-text-container {
      padding: 24px !important;
    }
    .review-quote-text {
      font-size: 18px !important;
    }
    .review-author-name {
      font-size: 20px !important;
    }
  }
</style>
{% schema %}
{
  "name": "Expert & Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Recommended by Health Experts"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Formulated on serious science..."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Reviewer Image"
        },
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Review Quote",
          "default": "They worked!! After taking Biotin gummies everyday for 2 months I could not actually believe the results! After taking out my braids I noticed how thicker and longer my hair was. The gummies were also easy to take and tasted really good."
        },
        {
          "type": "text",
          "id": "product_tag",
          "label": "Product Tag Label",
          "default": "Biotin Gummies"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Zara Asare Evans"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show Verified Checkmark Badge",
          "default": true
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author Subtitle / Job Title",
          "default": "Registered Nurse"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author Location (Optional)",
          "default": "London, UK"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expert & Customer Reviews",
      "blocks": [
        {
          "type": "review_card",
          "settings": {
            "quote_text": "They worked!! After taking Biotin gummies everyday for 2 months I could not actually believe the results! After taking out my braids I noticed how thicker and longer my hair was. The gummies were also easy to take and tasted really good.",
            "product_tag": "Biotin Gummies",
            "author_name": "Zara Asare Evans",
            "author_title": "Registered Nurse",
            "author_location": "London, UK"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "quote_text": "Creatine is one of the most researched supplements...",
            "product_tag": "Creatine Gummies",
            "author_name": "Dr Peter McQuillan",
            "author_title": "Registered Doctor",
            "author_location": "London, UK"
          }
        }
      ]
    }
  ]
}
{% endschema %}
