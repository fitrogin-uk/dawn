{% comment %}
  Expert & Customer Reviews Grid Section
  - Supports image scaling, text bounding boxes, and custom badge integration.
{% endcomment %}

<div class="reviews-section-wrapper color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="section-heading-container">
        <h2 class="reviews-main-heading">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="reviews-subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="reviews-flexible-grid">
      {%- for block in section.blocks -%}
        <div class="review-card-item" {{ block.shopify_attributes }}>
          
          <!-- Top Section: Image Box -->
          <div class="review-image-container">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                class: 'review-card-img'
              }}
            {%- else -%}
              <!-- Standard Placeholder for Empty States -->
              <div class="review-image-placeholder">
                <svg xmlns="http://w3.org" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="placeholder-icon">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <!-- Bottom Section: Content Text Box -->
          <div class="review-text-container">
            
            <!-- Quote Block -->
            <div class="review-quote-content">
              <p class="review-quote-text">
                {%- if block.settings.quote_text != blank -%}
                  “{{ block.settings.quote_text | escape }}”
                {%- else -%}
                  "Review text goes here..."
                {%- endif -%}
              </p>
              
              {%- if block.settings.product_tag != blank -%}
                <p class="review-product-tag">{{ block.settings.product_tag | escape }}</p>
              {%- endif -%}
            </div>

            <!-- Author & Verification Row -->
            <div class="review-author-meta">
              <div class="review-author-header">
                <h3 class="review-author-name">
                  {{ block.settings.author_name | default: "Name" | escape }}
                </h3>
                
                {%- if block.settings.show_verified -%}
                  <!-- Crisp, Responsive Native Vector Checkmark Badge -->
                  <span class="review-verified-badge" aria-label="Verified account">
                    <svg viewBox="0 0 24 24" class="verified-svg-icon">
                      <g>
                        <path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.99-3.818-3.99-.48 0-.94.1-1.348.27C14.825 2.515 13.512 1.5 12 1.5s-2.825 1.015-3.422 2.28c-.406-.17-.866-.27-1.348-.27-2.108 0-3.818 1.78-3.818 3.99 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.58.875 2.95 2.148 3.6-.154.435-.238.905-.238 1.4 0 2.21 1.71 3.99 3.818 3.99.48 0 .94-.1 1.348-.27.597 1.265 1.91 2.28 3.422 2.28s2.825-1.015 3.422-2.28c.406.17.866.27 1.348.27 2.108 0 3.818-1.78 3.818-3.99 0-.495-.084-.965-.238-1.4 1.273-.65 2.148-2.02 2.148-3.6zm-12.72 4.212l-3.32-3.32 1.414-1.414 1.906 1.906 5.17-5.17 1.414 1.414-6.584 6.584z"></path>
                      </g>
                    </svg>
                  </span>
                {%- endif -%}
              </div>
              
              {%- if block.settings.author_title != blank -%}
                <p class="review-author-title">{{ block.settings.author_title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.author_location != blank -%}
                <p class="review-author-location">{{ block.settings.author_location | escape }}</p>
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% style %}
  /* Section Layout & Spacing Rules */
  .reviews-section-wrapper {
    width: 100%;
    box-sizing: border-box;
    background-color: #ffffff;
  }
  .section-heading-container {
    text-align: left;
    margin-bottom: 40px;
    font-family: inherit;
  }
  .reviews-main-heading {
    font-size: 32px;
    font-weight: 700;
    color: #1c1e24;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }
  .reviews-subheading {
    font-size: 16px;
    color: #6b7280;
    margin: 0;
  }

  /* Flex Grid Engine - Matches Image Columns Proportionally */
  .reviews-flexible-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 40px;
    align-items: start;
    width: 100%;
  }

  /* The Card Component Container */
  .review-card-item {
    background: #ffffff;
    border-radius: 24px;
    border: 1px solid #f3f4f6;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s ease;
    height: 100%;
  }

  /* Image Area Scales Horizontally & Vertically */
  .review-image-container {
    position: relative;
    width: 100%;
    height: 420px;
    background-color: #e5e7eb;
    overflow: hidden;
  }
  .review-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .review-image-placeholder {
    width: 100%;
    height: 100%;
    background-color: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-icon {
    width: 64px;
    height: 64px;
    color: #9ca3af;
  }

  /* Bottom Content Text Box Adjustments */
  .review-text-container {
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
  }
  .review-quote-content {
    margin-bottom: 32px;
  }
  .review-quote-text {
    font-size: 20px;
    line-height: 1.6;
    font-weight: 400;
    color: #2d3142;
    margin: 0 0 16px 0;
  }
  .review-product-tag {
    font-size: 14px;
    font-weight: 500;
    color: #9ca3af;
    margin: 0;
    text-transform: capitalize;
  }

  /* Meta & Verification Badge Integration Rules */
  .review-author-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid #f3f4f6;
    padding-top: 20px;
  }
  .review-author-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .review-author-name {
    font-size: 24px;
    font-weight: 600;
    color: #1c1e24;
    margin: 0;
  }
  .review-verified-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: #1d9bf0;
    flex-shrink: 0;
  }
  .verified-svg-icon {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
  .review-author-title {
    font-size: 14px;
    font-weight: 500;
    color: #6b7280;
    margin: 0;
  }
  .review-author-location {
    font-size: 12px;
    color: #9ca3af;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Responsive Rules for Small Devices */
  @media screen and (max-width: 749px) {
    .reviews-flexible-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .review-image-container {
      height: 320px;
    }
    .review-text-container {
      padding: 24px;
    }
    .review-quote-text {
      font-size: 18px;
    }
    .review-author-name {
      font-size: 20px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Expert & Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Recommended by Health Experts"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Formulated on serious science..."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Reviewer Image"
        },
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Review Quote",
          "default": "Biotin gummies everyday for 2 months changed my hair health."
        },
        {
          "type": "text",
          "id": "product_tag",
          "label": "Product Tag Label",
          "default": "Biotin Gummies"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Zara Asare Evans"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show Verified Checkmark Badge",
          "default": true
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author Subtitle / Job Title",
          "default": "Registered Nurse"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author Location (Optional)",
          "default": "London, UK"
        }
      ]
    }
  ],
  "presets": [
    {

        "name": "Expert & Customer Reviews",
        "blocks": [
            { "type": "review_card" },
            { "type": "review_card" }
      ]
    }
  ]
}
{% endschema %}
