{{ 'section-multi-column.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .expert-section-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Headings Typography Layout */
  .expert-heading-area {
    margin-bottom: 3.5rem;
    max-width: 100%;
  }

  .expert-heading-area .title {
    font-family: inherit;
    font-size: 3.2rem;
    font-weight: 600;
    color: #121212;
    margin: 0 0 1rem 0;
    letter-spacing: -0.03em;
  }

  .expert-heading-area .title em {
    font-style: italic;
    font-weight: 400;
  }

  .expert-subtitle-text {
    font-size: 1.4rem;
    line-height: 1.5;
    color: #555555;
    max-width: 900px;
    margin: 0;
  }

  /* Grid Layout and Exact Distances */
  .expert-grid-layout {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px; /* Precise distance between the boxes */
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Card Structure Elements */
  .expert-card {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: none;
  }

  /* Exact Top Gray Background Image Wrapper Block */
  .expert-card__image-wrapper {
    position: relative;
    background-color: #dfdfdf; /* Identical cool gray background matching left panel */
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
  }

  .expert-card__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 10 / 11; /* Vertical rect portrait proportion matching reference */
    object-fit: cover;
  }

  .expert-card__info {
    padding: 2.5rem 0.5rem 1rem 0.5rem; /* Clean edge padding aligning perfectly to outer box bounds */
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* Exact Quote Font Alignment Rules */
  .expert-card__quote {
    font-size: 1.35rem;
    line-height: 1.5;
    color: #333333;
    margin: 0 0 2rem 0;
    flex-grow: 1;
    font-weight: 400;
    letter-spacing: 0;
  }

  .expert-card__product-tag {
    font-size: 1.05rem;
    color: #999999;
    margin-bottom: 2rem;
    font-weight: 400;
  }

  /* Identity Metadata Block Alignment */
  .expert-card__meta {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .expert-card__name-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .expert-card__name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #121212;
    margin: 0;
  }

  /* Solid Blue Circle Verified Badge Checkmark Markup */
  .expert-card__verified-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #0084ff; /* Pure medical profile verified blue hex color value */
    color: #ffffff;
    width: 15px;
    height: 15px;
    border-radius: 50%;
  }

  .expert-card__verified-badge svg {
    width: 9px;
    height: 9px;
    fill: currentColor;
  }

  .expert-card__title,
  .expert-card__location {
    font-size: 1.2rem;
    color: #777777;
    margin: 0;
    font-weight: 400;
  }

  /* High performance CSS mobile responsive view slider */
  @media screen and (max-width: 989px) {
    .expert-grid-layout {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .expert-section-wrapper {
      padding: 0 1.5rem;
    }
    .expert-grid-layout {
      display: flex !important;
      flex-wrap: nowrap !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      gap: 15px;
    }
    .expert-grid-layout::-webkit-scrollbar {
      display: none;
    }
    .expert-grid-layout > li {
      width: 78% !important;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .expert-heading-area .title {
      font-size: 2.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="expert-section-wrapper">
    
    <div class="expert-heading-area">
      <h2 class="title">
        {{ section.settings.title }}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <div class="expert-subtitle-text">
          {{ section.settings.subtitle }}
        </div>
      {%- endif -%}
    </div>

    <ul class="expert-grid-layout" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <li {{ block.shopify_attributes }}>
            <div class="expert-card">
              
              <div class="expert-card__image-wrapper">
                {%- if block.settings.image != blank -%}
                  {%- capture sizes -%}(min-width: 990px) 25vw, (min-width: 750px) 50vw, 80vw{%- endcapture -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    sizes: sizes,
                    widths: '300, 450, 600',
                    class: 'expert-card__image'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg expert-card__image' }}
                {%- endif -%}
              </div>

              <div class="expert-card__info">
                <p class="expert-card__quote">{{ block.settings.quote }}</p>
                
                {%- if block.settings.product_label != blank -%}
                  <div class="expert-card__product-tag">{{ block.settings.product_label }}</div>
                {%- endif -%}

                <div class="expert-card__meta">
                  <div class="expert-card__name-wrapper">
                    <h3 class="expert-card__name">{{ block.settings.name }}</h3>
                    {%- if block.settings.show_verified -%}
                      <span class="expert-card__verified-badge" title="Verified Profile">
                        <svg viewBox="0 0 24 24">
                          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                        </svg>
                      </span>
                    {%- endif -%}
                  </div>
                  
                  {%- if block.settings.expert_title != blank -%}
                    <p class="expert-card__title">{{ block.settings.expert_title }}</p>
                  {%- endif -%}
                  {%- if block.settings.expert_location != blank -%}
                    <p class="expert-card__location">{{ block.settings.expert_location }}</p>
                  {%- endif -%}
                </div>
              </div>

            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Expert Recommendations",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Recommended by <em>Health</em> Experts",
      "label": "Heading (Use <em>Text</em> for italics)"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "default": "Novomins gummies aren't just delicious, they're formulated on serious science...",
      "label": "Description Subtitle"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Expert Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Expert Portrait Image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "default": "Creatine is one of the most researched supplements, shown to effectively increase muscle strength...",
          "label": "Recommendation Quote"
        },
        {
          "type": "text",
          "id": "product_label",
          "default": "Creatine Gummies",
          "label": "Product Sub-label"
        },
        {
          "type": "text",
          "id": "name",
          "default": "Dr Peter McQuillan",
          "label": "Expert Name"
        },
        {
          "type": "text",
          "id": "expert_title",
          "default": "Registered Doctor",
          "label": "Expert Credentials / Title"
        },
        {
          "type": "text",
          "id": "expert_location",
          "default": "London, UK",
          "label": "Reviewer Location"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show Verified Badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expert Recommendations",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
