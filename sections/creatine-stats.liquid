<div class="cr-stats">
  <div class="cr-stats__inner">
    <div class="cr-stats__left">
      <p class="cr-stats__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="cr-stats__headline">{{ section.settings.headline }}</h2>
      <p class="cr-stats__body">{{ section.settings.body }}</p>
    </div>
    <div class="cr-stats__right">
      <div class="cr-stat-item">
        <div class="cr-stat-item__pct">95<span>%</span></div>
        <p class="cr-stat-item__label">{{ section.settings.stat1 }}</p>
      </div>
      <div class="cr-stat-item">
        <div class="cr-stat-item__pct">89<span>%</span></div>
        <p class="cr-stat-item__label">{{ section.settings.stat2 }}</p>
      </div>
      <div class="cr-stat-item">
        <div class="cr-stat-item__pct">85<span>%</span></div>
        <p class="cr-stat-item__label">{{ section.settings.stat3 }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social Proof Stats",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Customer Results" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Real people. Real results." },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Based on a survey of verified Fitrogin customers after 30 days of daily use." },
    { "type": "text", "id": "stat1", "label": "Stat 1 label", "default": "Consider our gummies more effective than powder and capsules" },
    { "type": "text", "id": "stat2", "label": "Stat 2 label", "default": "Prefer gummies to capsules and powders" },
    { "type": "text", "id": "stat3", "label": "Stat 3 label", "default": "Would recommend Fitrogin Creatine to friends and family" }
  ],
  "presets": [{ "name": "Social Proof Stats" }]
}
{% endschema %}
