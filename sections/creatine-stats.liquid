<section class="cr-stats-section" aria-label="Product statistics">
  <div class="cr-stats-section__inner">
    <h2 class="cr-stats-section__heading">{{ section.settings.title | default: 'The Results Speak for Themselves' }}</h2>
    <p class="cr-stats-section__sub">{{ section.settings.subtitle | default: 'Based on customer feedback and clinical research' }}</p>
    <div class="cr-stats-grid">

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="cr-stat-card" {{ block.shopify_attributes }}>
            <div class="cr-stat-card__number">{{ block.settings.number }}</div>
            <div class="cr-stat-card__label">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="cr-stat-card">
          <div class="cr-stat-card__number">95%</div>
          <div class="cr-stat-card__label">of users noticed increased strength within 4 weeks</div>
        </div>
        <div class="cr-stat-card">
          <div class="cr-stat-card__number">89%</div>
          <div class="cr-stat-card__label">reported better workout performance</div>
        </div>
        <div class="cr-stat-card">
          <div class="cr-stat-card__number">92%</div>
          <div class="cr-stat-card__label">prefer gummies over powder or capsules</div>
        </div>
        <div class="cr-stat-card">
          <div class="cr-stat-card__number">4.9★</div>
          <div class="cr-stat-card__label">average rating from verified UK buyers</div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats Bar",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "The Results Speak for Themselves" },
    { "type": "text", "id": "subtitle", "label": "Subheading", "default": "Based on customer feedback and clinical research" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number / Percentage", "default": "95%" },
        { "type": "text", "id": "label", "label": "Label", "default": "of users noticed increased strength within 4 weeks" }
      ]
    }
  ],
  "presets": [{ "name": "Stats Bar" }]
}
{% endschema %}
