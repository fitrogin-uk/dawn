{% comment %}
  custom-split-hero-banner.liquid
  A modern, fully customizable split hero banner section for Shopify Dawn theme.
  Place this file in: /sections/custom-split-hero-banner.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --hero-bg: {{ section.settings.background_color }};
    --hero-accent: {{ section.settings.accent_color }};
    --hero-text-primary: {{ section.settings.text_color_primary }};
    --hero-text-secondary: {{ section.settings.text_color_secondary }};
    --hero-btn-primary-bg: {{ section.settings.btn_primary_bg }};
    --hero-btn-primary-text: {{ section.settings.btn_primary_text }};
    --hero-btn-secondary-border: {{ section.settings.btn_secondary_border }};
    --hero-btn-secondary-text: {{ section.settings.btn_secondary_text }};
    --hero-min-height: {{ section.settings.section_height }}px;
    --hero-content-max-width: 560px;
    --hero-transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .custom-split-hero {
    position: relative;
    display: flex;
    align-items: stretch;
    min-height: var(--hero-min-height);
    background-color: var(--hero-bg);
    overflow: hidden;
  }

  /* ── Inner layout ── */
  .custom-split-hero__inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: 60px 48px;
    gap: 40px;
    position: relative;
    z-index: 2;
  }

  /* ── Content column ── */
  .custom-split-hero__content {
    flex: 0 0 auto;
    width: 100%;
    max-width: var(--hero-content-max-width);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Rating bar ── */
  .custom-split-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(16px);
    animation: heroFadeUp 0.6s var(--hero-transition) 0.1s forwards;
  }

  .custom-split-hero__stars {
    display: flex;
    gap: 2px;
  }

  .custom-split-hero__stars svg {
    width: 16px;
    height: 16px;
    fill: {{ section.settings.stars_color }};
  }

  .custom-split-hero__rating-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--hero-text-secondary);
    letter-spacing: 0.01em;
  }

  .custom-split-hero__rating-text strong {
    color: var(--hero-text-primary);
  }

  /* ── Headline ── */
  .custom-split-hero__heading {
    font-size: clamp(38px, 5vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--hero-text-primary);
    margin: 0 0 20px;
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.65s var(--hero-transition) 0.2s forwards;
  }

  /* ── Subheading ── */
  .custom-split-hero__subheading {
    font-size: clamp(15px, 1.8vw, 18px);
    font-weight: 400;
    color: var(--hero-text-secondary);
    margin: 0 0 32px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.65s var(--hero-transition) 0.3s forwards;
  }

  /* ── Button group ── */
  .custom-split-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.65s var(--hero-transition) 0.4s forwards;
  }

  .custom-split-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: none;
    transition: transform var(--hero-transition), box-shadow var(--hero-transition), background-color var(--hero-transition);
    white-space: nowrap;
  }

  .custom-split-hero__btn--primary {
    background-color: var(--hero-btn-primary-bg);
    color: var(--hero-btn-primary-text);
    border: 2px solid var(--hero-btn-primary-bg);
  }

  .custom-split-hero__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }

  .custom-split-hero__btn--secondary {
    background-color: transparent;
    color: var(--hero-btn-secondary-text);
    border: 2px solid var(--hero-btn-secondary-border);
  }

  .custom-split-hero__btn--secondary:hover {
    transform: translateY(-2px);
    background-color: rgba(0,0,0,0.04);
  }

  .custom-split-hero__btn-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .custom-split-hero__btn--secondary .custom-split-hero__btn-icon {
    background-color: rgba(0,0,0,0.08);
  }

  .custom-split-hero__btn-icon svg {
    width: 10px;
    height: 10px;
  }

  /* ── Trust badges ── */
  .custom-split-hero__trust {
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transform: translateY(16px);
    animation: heroFadeUp 0.6s var(--hero-transition) 0.5s forwards;
  }

  .custom-split-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--hero-text-secondary);
    font-weight: 500;
  }

  .custom-split-hero__trust-item svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    fill: {{ section.settings.trust_icon_color }};
  }

  /* ── Image column ── */
  .custom-split-hero__media {
    flex: 1 1 auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
    opacity: 0;
    transform: translateX(30px) scale(0.97);
    animation: heroSlideIn 0.75s var(--hero-transition) 0.25s forwards;
  }

  .custom-split-hero__image {
    width: 100%;
    height: 100%;
    max-height: {{ section.settings.image_max_height }}px;
    object-fit: contain;
    object-position: center bottom;
    display: block;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 30px 60px rgba(0,0,0,0.12));
  }

  /* Decorative blob behind image */
  .custom-split-hero__blob {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .custom-split-hero__blob svg {
    width: 110%;
    height: 110%;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.45;
  }

  /* ── Badge / promo pill ── */
  .custom-split-hero__badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--hero-accent);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
    width: fit-content;
    opacity: 0;
    transform: translateY(12px);
    animation: heroFadeUp 0.5s var(--hero-transition) 0.05s forwards;
  }

  {% unless section.settings.show_badge %}
    .custom-split-hero__badge { display: none; }
  {% endunless %}

  {% unless section.settings.show_rating %}
    .custom-split-hero__rating { display: none; }
  {% endunless %}

  {% unless section.settings.show_trust_badges %}
    .custom-split-hero__trust { display: none; }
  {% endunless %}

  /* ── Slide indicators ── */
  .custom-split-hero__indicators {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .custom-split-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 100px;
    background-color: rgba(0,0,0,0.2);
    cursor: pointer;
    transition: width 0.3s ease, background-color 0.3s ease;
    border: none;
    padding: 0;
  }

  .custom-split-hero__dot.is-active {
    width: 24px;
    background-color: var(--hero-btn-primary-bg);
  }

  /* ── Keyframes ── */
  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroSlideIn {
    to { opacity: 1; transform: translateX(0) scale(1); }
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .custom-split-hero__inner {
      flex-direction: column;
      padding: 48px 24px 56px;
      gap: 32px;
      text-align: center;
    }

    .custom-split-hero__content {
      align-items: center;
      max-width: 100%;
    }

    .custom-split-hero__rating,
    .custom-split-hero__badge {
      justify-content: center;
    }

    .custom-split-hero__buttons {
      justify-content: center;
    }

    .custom-split-hero__trust {
      align-items: center;
    }

    .custom-split-hero__media {
      width: 100%;
      max-width: 420px;
      min-height: 300px;
      transform: translateY(20px) scale(0.97);
    }

    @keyframes heroSlideIn {
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
  }

  @media screen and (max-width: 599px) {
    .custom-split-hero__inner {
      padding: 36px 20px 56px;
    }

    .custom-split-hero__heading {
      font-size: clamp(32px, 8vw, 44px);
    }

    .custom-split-hero__btn {
      padding: 13px 22px;
      font-size: 14px;
    }
  }
{%- endstyle -%}

<div class="custom-split-hero" id="HeroBanner-{{ section.id }}">
  <div class="custom-split-hero__inner">

    {%- comment -%} ── Content Side ── {%- endcomment -%}
    <div class="custom-split-hero__content">

      {%- if section.settings.badge_text != blank -%}
        <span class="custom-split-hero__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="custom-split-hero__rating">
          <div class="custom-split-hero__stars">
            {%- for i in (1..5) -%}
              {%- if i <= section.settings.rating_full_stars -%}
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.85L18 6.76l-4 3.9.94 5.5L10 13.77 5.06 16.16 6 10.66 2 6.76l5.61-.91z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" style="opacity:0.35"><path d="M10 1l2.39 4.85L18 6.76l-4 3.9.94 5.5L10 13.77 5.06 16.16 6 10.66 2 6.76l5.61-.91z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="custom-split-hero__rating-text">
            <strong>{{ section.settings.rating_score }}</strong> {{ section.settings.rating_label }}
          </span>
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="custom-split-hero__heading">
          {{ section.settings.heading | newline_to_br }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="custom-split-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="custom-split-hero__buttons">
        {%- if section.settings.btn_primary_label != blank -%}
          <a
            href="{{ section.settings.btn_primary_link }}"
            class="custom-split-hero__btn custom-split-hero__btn--primary"
            {% if section.settings.btn_primary_new_tab %}target="_blank" rel="noopener"{% endif %}
          >
            {{- section.settings.btn_primary_label -}}
            {%- if section.settings.btn_show_icon -%}
              <span class="custom-split-hero__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5"><path d="M2 8L8 2M8 2H3.5M8 2V6.5"/></svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- if section.settings.btn_secondary_label != blank -%}
          <a
            href="{{ section.settings.btn_secondary_link }}"
            class="custom-split-hero__btn custom-split-hero__btn--secondary"
            {% if section.settings.btn_secondary_new_tab %}target="_blank" rel="noopener"{% endif %}
          >
            {{- section.settings.btn_secondary_label -}}
            {%- if section.settings.btn_show_icon -%}
              <span class="custom-split-hero__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5"><path d="M2 8L8 2M8 2H3.5M8 2V6.5"/></svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_trust_badges -%}
        <div class="custom-split-hero__trust">
          {%- if section.settings.trust_1 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_1 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_2 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_3 }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Media Side ── {%- endcomment -%}
    <div class="custom-split-hero__media">
      <div class="custom-split-hero__blob" aria-hidden="true">
        <svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="blobGrad-{{ section.id }}" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="{{ section.settings.blob_color_inner }}" stop-opacity="0.9"/>
              <stop offset="100%" stop-color="{{ section.settings.blob_color_outer }}" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <path fill="url(#blobGrad-{{ section.id }})" d="M300,80 C420,80 520,160 520,300 C520,440 420,520 300,520 C180,520 80,440 80,300 C80,160 180,80 300,80 Z"/>
        </svg>
      </div>

      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 900
          | image_tag:
            class: 'custom-split-hero__image',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '400, 600, 900',
            sizes: '(max-width: 989px) min(90vw, 420px), 50vw',
            alt: section.settings.hero_image.alt | default: section.settings.heading
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'custom-split-hero__image' }}
      {%- endif -%}
    </div>

  </div>

  {%- if section.settings.show_indicators -%}
    <div class="custom-split-hero__indicators" role="list" aria-label="Slide indicators">
      <button class="custom-split-hero__dot" role="listitem" aria-label="Slide 1"></button>
      <button class="custom-split-hero__dot is-active" role="listitem" aria-label="Slide 2 (current)"></button>
      <button class="custom-split-hero__dot" role="listitem" aria-label="Slide 3"></button>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Custom Split Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Layout & Sizing"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Section min-height",
      "default": 560
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max content width",
      "default": 1280
    },
    {
      "type": "range",
      "id": "image_max_height",
      "min": 300,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Image max height",
      "default": 560
    },
    {
      "type": "header",
      "content": "🖼 Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Product / Hero image"
    },
    {
      "type": "header",
      "content": "🏷 Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge pill",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Summer Sale"
    },
    {
      "type": "header",
      "content": "⭐ Rating Bar"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating bar",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_full_stars",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Full stars (out of 5)",
      "default": 4
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "default": "4.7"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Rating label text",
      "default": "based on 11,060 reviews"
    },
    {
      "type": "color",
      "id": "stars_color",
      "label": "Stars color",
      "default": "#F5A623"
    },
    {
      "type": "header",
      "content": "✍️ Heading & Text"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (use new line for line break)",
      "default": "Summer's On\nSo is the Sale"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 40,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Heading max size",
      "default": 68
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extrabold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "700"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading / Description",
      "default": "15% OFF summer-ready products"
