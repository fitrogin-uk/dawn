
{% comment %}
  custom-split-hero-banner.liquid
  Place this file in: /sections/custom-split-hero-banner.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --hero-bg: {{ section.settings.background_color }};
    --hero-accent: {{ section.settings.accent_color }};
    --hero-text-primary: {{ section.settings.text_color_primary }};
    --hero-text-secondary: {{ section.settings.text_color_secondary }};
    --hero-btn-primary-bg: {{ section.settings.btn_primary_bg }};
    --hero-btn-primary-text: {{ section.settings.btn_primary_text }};
    --hero-btn-secondary-border: {{ section.settings.btn_secondary_border }};
    --hero-btn-secondary-text: {{ section.settings.btn_secondary_text }};
    --hero-min-height: {{ section.settings.section_height }}px;
    --hero-transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .custom-split-hero {
    position: relative;
    display: flex;
    align-items: stretch;
    min-height: var(--hero-min-height);
    background-color: var(--hero-bg);
    overflow: hidden;
  }

  .custom-split-hero__inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: 60px 48px;
    gap: 48px;
    position: relative;
    z-index: 2;
  }

  /* ── Content column ── */
  .custom-split-hero__content {
    flex: 0 0 auto;
    width: 100%;
    max-width: 540px;
    display: flex;
    flex-direction: column;
  }

  /* Reveal animation (JS-driven, always visible without JS) */
  .custom-split-hero__badge,
  .custom-split-hero__rating,
  .custom-split-hero__heading,
  .custom-split-hero__subheading,
  .custom-split-hero__buttons,
  .custom-split-hero__trust,
  .custom-split-hero__media {
    opacity: 1;
    transform: none;
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .csh-animate .custom-split-hero__badge       { opacity: 0; transform: translateY(10px); transition-delay: 0.05s; }
  .csh-animate .custom-split-hero__rating      { opacity: 0; transform: translateY(12px); transition-delay: 0.10s; }
  .csh-animate .custom-split-hero__heading     { opacity: 0; transform: translateY(16px); transition-delay: 0.18s; }
  .csh-animate .custom-split-hero__subheading  { opacity: 0; transform: translateY(16px); transition-delay: 0.26s; }
  .csh-animate .custom-split-hero__buttons     { opacity: 0; transform: translateY(16px); transition-delay: 0.34s; }
  .csh-animate .custom-split-hero__trust       { opacity: 0; transform: translateY(12px); transition-delay: 0.42s; }
  .csh-animate .custom-split-hero__media       { opacity: 0; transform: translateX(24px); transition-delay: 0.20s; }
  .csh-animate.csh-revealed .custom-split-hero__badge,
  .csh-animate.csh-revealed .custom-split-hero__rating,
  .csh-animate.csh-revealed .custom-split-hero__heading,
  .csh-animate.csh-revealed .custom-split-hero__subheading,
  .csh-animate.csh-revealed .custom-split-hero__buttons,
  .csh-animate.csh-revealed .custom-split-hero__trust,
  .csh-animate.csh-revealed .custom-split-hero__media {
    opacity: 1;
    transform: none;
  }

  /* ── Rating ── */
  .custom-split-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }
  .custom-split-hero__stars { display: flex; gap: 2px; }
  .custom-split-hero__stars svg { width: 16px; height: 16px; fill: {{ section.settings.stars_color }}; }
  .custom-split-hero__rating-text { font-size: 13px; font-weight: 500; color: var(--hero-text-secondary); letter-spacing: 0.01em; }
  .custom-split-hero__rating-text strong { color: var(--hero-text-primary); }

  /* ── Badge ── */
  .custom-split-hero__badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--hero-accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
    width: fit-content;
  }

  /* ── Heading ── */
  .custom-split-hero__heading {
    font-size: clamp(34px, 4.5vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--hero-text-primary);
    margin: 0 0 18px;
  }

  /* ── Subheading ── */
  .custom-split-hero__subheading {
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 400;
    color: var(--hero-text-secondary);
    margin: 0 0 28px;
    line-height: 1.55;
  }

  /* ── Buttons ── */
  .custom-split-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }
  .custom-split-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: none;
    transition: transform var(--hero-transition), box-shadow var(--hero-transition);
    white-space: nowrap;
  }
  .custom-split-hero__btn--primary {
    background-color: var(--hero-btn-primary-bg);
    color: var(--hero-btn-primary-text);
    border: 2px solid var(--hero-btn-primary-bg);
  }
  .custom-split-hero__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.18); }
  .custom-split-hero__btn--secondary {
    background-color: transparent;
    color: var(--hero-btn-secondary-text);
    border: 2px solid var(--hero-btn-secondary-border);
  }
  .custom-split-hero__btn--secondary:hover { transform: translateY(-2px); background-color: rgba(0,0,0,0.04); }
  .custom-split-hero__btn-icon {
    width: 20px; height: 20px; border-radius: 50%;
    background-color: rgba(255,255,255,0.22);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .custom-split-hero__btn--secondary .custom-split-hero__btn-icon { background-color: rgba(0,0,0,0.08); }
  .custom-split-hero__btn-icon svg { width: 10px; height: 10px; }

  /* ── Trust ── */
  .custom-split-hero__trust { display: flex; flex-direction: column; gap: 7px; }
  .custom-split-hero__trust-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 13.5px; color: var(--hero-text-secondary); font-weight: 500;
  }
  .custom-split-hero__trust-item svg { width: 16px; height: 16px; flex-shrink: 0; fill: {{ section.settings.trust_icon_color }}; }

  /* ── Media column ── */
  .custom-split-hero__media {
    flex: 1 1 auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 380px;
  }

  /* ── IMAGE SLIDESHOW ── */
  .csh-slideshow {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Blob sits behind all slides */
  .custom-split-hero__blob {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .custom-split-hero__blob svg {
    width: 110%; height: 110%;
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.5;
  }

  /* Each slide */
  .csh-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
  }
  .csh-slide.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative; /* take up space for the first slide so media col has height */
  }

  .csh-slide img,
  .csh-slide svg {
    width: 100%;
    max-height: {{ section.settings.image_max_height }}px;
    object-fit: contain;
    object-position: center center;
    display: block;
    filter: drop-shadow(0 24px 48px rgba(0,0,0,0.13));
  }

  /* ── Progress bar under dots ── */
  .custom-split-hero__indicators {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
    align-items: center;
  }
  .custom-split-hero__dot {
    position: relative;
    width: 8px; height: 8px;
    border-radius: 100px;
    background-color: rgba(0,0,0,0.15);
    border: none; padding: 0; cursor: pointer;
    overflow: hidden;
    transition: width 0.3s ease;
  }
  .custom-split-hero__dot.is-active {
    width: 40px;
    background-color: rgba(0,0,0,0.12);
  }
  /* Progress fill sweeps across active dot */
  .custom-split-hero__dot-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 0%;
    background-color: var(--hero-btn-primary-bg);
    border-radius: 100px;
    transition: none;
  }
  .csh-dot-running .custom-split-hero__dot-fill {
    width: 100%;
    transition: width {{ section.settings.slide_duration }}ms linear;
  }

  /* ── Conditional visibility ── */
  {% unless section.settings.show_badge %}
    .custom-split-hero__badge { display: none !important; }
  {% endunless %}
  {% unless section.settings.show_rating %}
    .custom-split-hero__rating { display: none !important; }
  {% endunless %}
  {% unless section.settings.show_trust_badges %}
    .custom-split-hero__trust { display: none !important; }
  {% endunless %}

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .custom-split-hero__inner {
      flex-direction: column-reverse;
      padding: 40px 20px 64px;
      gap: 28px;
      text-align: center;
    }
    .custom-split-hero__content { align-items: center; max-width: 100%; }
    .custom-split-hero__rating,
    .custom-split-hero__badge,
    .custom-split-hero__buttons { justify-content: center; }
    .custom-split-hero__trust { align-items: center; }
    .custom-split-hero__media { width: 100%; max-width: 380px; min-height: 260px; }
    .csh-animate .custom-split-hero__media { transform: translateY(16px); }
    .csh-animate.csh-revealed .custom-split-hero__media { transform: none; }
  }
  @media screen and (max-width: 479px) {
    .custom-split-hero__heading { font-size: clamp(30px, 9vw, 42px); }
    .custom-split-hero__btn { padding: 12px 20px; font-size: 14px; }
  }
{%- endstyle -%}

<div class="custom-split-hero" id="HeroBanner-{{ section.id }}">
  <div class="custom-split-hero__inner">

    <!-- Content -->
    <div class="custom-split-hero__content">

      {%- if section.settings.badge_text != blank and section.settings.show_badge -%}
        <span class="custom-split-hero__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="custom-split-hero__rating">
          <div class="custom-split-hero__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              {%- if i <= section.settings.rating_full_stars -%}
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.85L18 6.76l-4 3.9.94 5.5L10 13.77 5.06 16.16 6 10.66 2 6.76l5.61-.91z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" style="opacity:0.3"><path d="M10 1l2.39 4.85L18 6.76l-4 3.9.94 5.5L10 13.77 5.06 16.16 6 10.66 2 6.76l5.61-.91z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="custom-split-hero__rating-text">
            <strong>{{ section.settings.rating_score }}</strong> {{ section.settings.rating_label }}
          </span>
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="custom-split-hero__heading">
          {{ section.settings.heading | newline_to_br }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="custom-split-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="custom-split-hero__buttons">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_link | default: '#' }}"
             class="custom-split-hero__btn custom-split-hero__btn--primary"
             {% if section.settings.btn_primary_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{- section.settings.btn_primary_label -}}
            {%- if section.settings.btn_show_icon -%}
              <span class="custom-split-hero__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.6"><path d="M2 8L8 2M8 2H3.5M8 2V6.5"/></svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_link | default: '#' }}"
             class="custom-split-hero__btn custom-split-hero__btn--secondary"
             {% if section.settings.btn_secondary_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{- section.settings.btn_secondary_label -}}
            {%- if section.settings.btn_show_icon -%}
              <span class="custom-split-hero__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.6"><path d="M2 8L8 2M8 2H3.5M8 2V6.5"/></svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_trust_badges -%}
        <div class="custom-split-hero__trust">
          {%- if section.settings.trust_1 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_1 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_2 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <div class="custom-split-hero__trust-item">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              <span>{{ section.settings.trust_3 }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Media / Slideshow -->
    <div class="custom-split-hero__media">
      <div class="custom-split-hero__blob" aria-hidden="true">
        <svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="blobGrad-{{ section.id }}" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="{{ section.settings.blob_color_inner }}" stop-opacity="1"/>
              <stop offset="100%" stop-color="{{ section.settings.blob_color_outer }}" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <ellipse cx="300" cy="300" rx="260" ry="240" fill="url(#blobGrad-{{ section.id }})"/>
        </svg>
      </div>

      <div class="csh-slideshow" id="CshSlideshow-{{ section.id }}" aria-live="polite">

        {%- assign slide_images = section.settings.slide_image_1 | append: ',' | append: section.settings.slide_image_2 | append: ',' | append: section.settings.slide_image_3 -%}
        {%- assign has_any = false -%}
        {%- if section.settings.slide_image_1 != blank or section.settings.slide_image_2 != blank or section.settings.slide_image_3 != blank -%}
          {%- assign has_any = true -%}
        {%- endif -%}

        {%- assign slide_index = 0 -%}

        {%- if section.settings.slide_image_1 != blank -%}
          <div class="csh-slide{% if slide_index == 0 %} is-active{% endif %}" data-slide="{{ slide_index }}">
            {{
              section.settings.slide_image_1
              | image_url: width: 900
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '400, 600, 900',
                sizes: '(max-width: 989px) min(90vw, 380px), 45vw',
                alt: section.settings.slide_image_1.alt | default: section.settings.heading
            }}
          </div>
          {%- assign slide_index = slide_index | plus: 1 -%}
        {%- endif -%}

        {%- if section.settings.slide_image_2 != blank -%}
          <div class="csh-slide{% if slide_index == 0 %} is-active{% endif %}" data-slide="{{ slide_index }}">
            {{
              section.settings.slide_image_2
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900',
                sizes: '(max-width: 989px) min(90vw, 380px), 45vw',
                alt: section.settings.slide_image_2.alt | default: section.settings.heading
            }}
          </div>
          {%- assign slide_index = slide_index | plus: 1 -%}
        {%- endif -%}

        {%- if section.settings.slide_image_3 != blank -%}
          <div class="csh-slide{% if slide_index == 0 %} is-active{% endif %}" data-slide="{{ slide_index }}">
            {{
              section.settings.slide_image_3
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900',
                sizes: '(max-width: 989px) min(90vw, 380px), 45vw',
                alt: section.settings.slide_image_3.alt | default: section.settings.heading
            }}
          </div>
          {%- assign slide_index = slide_index | plus: 1 -%}
        {%- endif -%}

        {%- unless has_any -%}
          <div class="csh-slide is-active" data-slide="0">
            {{ 'product-1' | placeholder_svg_tag: 'custom-split-hero__image' }}
          </div>
        {%- endunless -%}

      </div>
    </div>

  </div>

  <!-- Dots / progress indicators -->
  <div class="custom-split-hero__indicators" id="CshDots-{{ section.id }}" aria-hidden="true">
    {%- assign dot_count = 0 -%}
    {%- if section.settings.slide_image_1 != blank -%}{%- assign dot_count = dot_count | plus: 1 -%}{%- endif -%}
    {%- if section.settings.slide_image_2 != blank -%}{%- assign dot_count = dot_count | plus: 1 -%}{%- endif -%}
    {%- if section.settings.slide_image_3 != blank -%}{%- assign dot_count = dot_count | plus: 1 -%}{%- endif -%}
    {%- if dot_count == 0 -%}{%- assign dot_count = 1 -%}{%- endif -%}
    {%- for i in (1..dot_count) -%}
      {%- assign di = forloop.index0 -%}
      <button class="custom-split-hero__dot{% if di == 0 %} is-active{% endif %}" data-dot="{{ di }}" aria-label="Go to slide {{ forloop.index }}">
        <span class="custom-split-hero__dot-fill"></span>
      </button>
    {%- endfor -%}
  </div>
</div>

<script>
(function () {
  var hero       = document.getElementById('HeroBanner-{{ section.id }}');
  var slideshow  = document.getElementById('CshSlideshow-{{ section.id }}');
  var dotsWrap   = document.getElementById('CshDots-{{ section.id }}');
  if (!hero || !slideshow) return;

  /* ── Entry animation ── */
  hero.classList.add('csh-animate');
  requestAnimationFrame(function () {
    requestAnimationFrame(function () {
      hero.classList.add('csh-revealed');
    });
  });

  /* ── Slideshow ── */
  var slides   = Array.from(slideshow.querySelectorAll('.csh-slide'));
  var dots     = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.custom-split-hero__dot')) : [];
  var duration = {{ section.settings.slide_duration }};
  var current  = 0;
  var timer    = null;

  if (slides.length <= 1) return; // only 1 image — nothing to cycle

  function goTo(index) {
    // Remove active from current slide + dot
    slides[current].classList.remove('is-active');
    if (dots[current]) {
      dots[current].classList.remove('is-active', 'csh-dot-running');
      // Reset fill width instantly
      var oldFill = dots[current].querySelector('.custom-split-hero__dot-fill');
      if (oldFill) { oldFill.style.transition = 'none'; oldFill.style.width = '0%'; }
    }

    current = (index + slides.length) % slides.length;

    // Activate new slide
    slides[current].classList.add('is-active');

    // Activate new dot + start progress fill
    if (dots[current]) {
      dots[current].classList.add('is-active');
      var fill = dots[current].querySelector('.custom-split-hero__dot-fill');
      if (fill) {
        fill.style.transition = 'none';
        fill.style.width = '0%';
        // Force reflow so transition resets cleanly
        fill.offsetWidth;
        requestAnimationFrame(function () {
          dots[current].classList.add('csh-dot-running');
        });
      }
    }
  }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(function () {
      goTo(current + 1);
    }, duration);
  }

  // Dot click = jump to that slide and restart timer
  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      goTo(i);
      startTimer();
    });
  });

  // Pause on hover
  hero.addEventListener('mouseenter', function () { clearInterval(timer); });
  hero.addEventListener('mouseleave', function () { startTimer(); });

  // Kick off
  goTo(0);
  startTimer();
})();
</script>

{% schema %}
{
  "name": "Custom Split Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Layout & Sizing"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Section min-height",
      "default": 560
    },
    {
      "type": "range",
      "id": "content_max_width",
