      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "🔲 Secondary Button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary button label",
      "default": "Take the Quiz"
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "checkbox",
      "id": "btn_secondary_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "btn_show_icon",
      "label": "Show arrow icon on buttons",
      "default": true
    },
    {
      "type": "header",
      "content": "✅ Trust Badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust badge 1",
      "default": "Doctor-founded, expert-formulated"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust badge 2",
      "default": "All products are 3rd party tested"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust badge 3",
      "default": "Clean, natural ingredients"
    },
    {
      "type": "color",
      "id": "trust_icon_color",
      "label": "Trust icon color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "🎨 Colors"
    },
    {
      "type": "color",
