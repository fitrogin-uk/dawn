{% comment %}
  Shopify Sequential-Playback Video Carousel - PART 1
  - Breakout framework to bypass nested theme containers
  - Bright, high-contrast solid white play button matching reference screenshots
  - Isolated absolute layers for the batch navigation chevrons
  - Hidden completely on mobile viewports
{% endcomment %}

<div class="video-carousel-wrapper" id="VideoCarousel-{{ section.id }}">
  <!-- Left Navigation Arrow Layer -->
  <button class="carousel-arrow arrow-left" type="button" aria-label="Previous batch">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>

  <div class="video-carousel-container">
    <div class="video-carousel-track">
      {%- for block in section.blocks -%}
        {%- if block.settings.video_select != blank -%}
          {%- assign video_url = "" -%}
          {%- for source in block.settings.video_select.sources -%}
            {%- if source.format == 'mp4' -%}
              {%- assign video_url = source.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if video_url == "" -%}{%- assign video_url = block.settings.video_select.sources.url -%}{%- endif -%}
          
          <div class="video-carousel-card" {{ block.shopify_attributes }} data-video-url="{{ video_url }}">
            <div class="video-relative-frame">
              <video src="{{ video_url }}" muted playsinline preload="metadata" style="pointer-events: none;"></video>
              <div class="play-button-overlay">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"/></svg>
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="video-carousel-card placeholder-card" {{ block.shopify_attributes }} data-video-url="">
            <div class="video-relative-frame">
              {{ 'collection-1' | placeholder_svg_tag }}
              <div class="play-button-overlay">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"/></svg>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Right Navigation Arrow Layer -->
  <button class="carousel-arrow arrow-right" type="button" aria-label="Next batch">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>
</div>

<!-- Full Screen Modal Player -->
<div class="video-popup-modal" id="VideoModal-{{ section.id }}">
  <button class="modal-close-btn" type="button">&times;</button>
  <div class="modal-video-box">
    <video controls autoplay playsinline class="modal-active-video"></video>
  </div>
</div>

<style>
.video-carousel-wrapper {
  position: relative !important;
  width: 100vw !important;
  max-width: 100vw !important;
  left: 50% !important;
  right: 50% !important;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  padding: 40px 0;
  background: transparent;
  display: block !important;
  box-sizing: border-box !important;
}

.video-carousel-container {
  overflow: hidden !important;
  width: 100% !important;
  padding-left: 5% !important;
  box-sizing: border-box !important;
}

.video-carousel-track {
  display: flex !important;
  transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1) !important;
  width: max-content !important;
}

.video-carousel-card {
  width: 390px !important;
  min-width: 390px !important;
  flex-shrink: 0 !important;
  padding-right: 12px !important;
  box-sizing: border-box !important;
  cursor: pointer !important;
}

@media (max-width: 1400px) { .video-carousel-card { width: 320px !important; min-width: 320px !important; } }
@media (max-width: 1100px) { .video-carousel-card { width: 260px !important; min-width: 260px !important; } }
@media (max-width: 749px) { .video-carousel-wrapper { display: none !important; } }

.video-relative-frame {
  position: relative !important;
  width: 100% !important;
}

.video-carousel-card video, 
.video-carousel-card svg {
  width: 100% !important;
  aspect-ratio: 9 / 16 !important;
  height: auto !important;
  border-radius: 20px !important;
  object-fit: cover !important;
  display: block !important;
  filter: brightness(0.60) !important;
  transition: filter 0.4s ease !important;
}

.video-carousel-card.active-playing video,
.video-carousel-card.active-playing svg {
  filter: brightness(1) !important;
}

.placeholder-card svg { background: #e2e2e2 !important; }

.play-button-overlay {
  position: absolute !important;
  top: 50% !important;
  left: 50% !important;
  transform: translate(-50%, -50%) !important;
  width: 64px !important;
  height: 64px !important;
  background: transparent !important;
  border: 2px solid #ffffff !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: opacity 0.3s !important;
  pointer-events: none !important;
  opacity: 0.35 !important;
}

.video-carousel-card.active-playing .play-button-overlay {
  opacity: 1 !important;
}

.play-button-overlay svg {
  width: 32px !important;
  height: 32px !important;
  color: #ffffff !important;
  fill: #ffffff !important;
  margin-left: 6px !important;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15)) !important;
}

.carousel-arrow {
  position: absolute !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  background: #ffffff !important;
  border: 1px solid #e0e0e0 !important;
  border-radius: 50% !important;
  width: 44px !important;
  height: 44px !important;
  color: #000000 !important;
  cursor: pointer !important;
  z-index: 99999999 !important;
  pointer-events: all !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 0 4px 14px rgba(0,0,0,0.15) !important;
  transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1) !important;
  padding: 0 !important;
}
.carousel-arrow:hover { transform: translateY(-50%) scale(1.15) !important; }
.carousel-arrow svg { width: 22px !important; height: 22px !important; }
.arrow-left { left: 20px !important; }
.arrow-right { right: 20px !important; }

.video-popup-modal {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background: rgba(0, 0, 0, 0.85) !important;
  backdrop-filter: blur(8px) !important;
  z-index: 999999999 !important;
  display: none;
  align-items: center !important;
  justify-content: center !important;
}
.modal-video-box {
  width: 90% !important;
  max-width: 480px !important;
  aspect-ratio: 9 / 16 !important;
}
.modal-video-box video {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  border-radius: 16px !important;
}
.modal-close-btn {
  position: absolute !important;
  top: 20px !important;
  right: 30px !important;
  background: transparent !important;
  border: none !important;
  color: #ffffff !important;
  font-size: 45px !important;
  cursor: pointer !important;
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('VideoCarousel-{{ section.id }}');
  const modal = document.getElementById('VideoModal-{{ section.id }}');
  if (!wrapper || window.innerWidth <= 749) return;

  const track = wrapper.querySelector('.video-carousel-track');
  const btnLeft = wrapper.querySelector('.arrow-left');
  const btnRight = wrapper.querySelector('.arrow-right');
  const modalVideo = modal.querySelector('.modal-active-video');
  const modalClose = modal.querySelector('.modal-close-btn');
  
  let currentIndex = 0;
  let playChainIndex = 0;
  let chainInterval = null;

  function getGroupJumpSize() {
    if (window.innerWidth <= 1100) return 2;
    if (window.innerWidth <= 1400) return 3;
    return 4; 
  }

  function updateSlidePosition() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;
    const cardWidth = cards[0].getBoundingClientRect().width;
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
  }

  function manageChainPlayback() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;

    cards.forEach((card, idx) => {
      const video = card.querySelector('video');
      if (idx === playChainIndex) {
        card.classList.add('active-playing');
        if (video && card.getAttribute('data-video-url') !== "") {
          video.currentTime = 0;
          video.play().catch((err) => console.log(err));
        }
      } else {
        card.classList.remove('active-playing');
        if (video) video.pause();
      }
    });
  }

  function runChainStep() {
    const cards = track.querySelectorAll('.video-carousel-track .video-carousel-card');
    if (cards.length === 0) return;

    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);

    // Auto-advance chain sequence by 1 video slot item every 3 seconds
    if (playChainIndex >= cards.length - 1) {
      currentIndex = 0;
      playChainIndex = 0;
    } else {
      playChainIndex++;
      // Pull the carousel viewing tracking lane forward if the next clip is hidden out of frame bounds
      if (playChainIndex >= currentIndex + jumpSize) {
        currentIndex = Math.min(maxIndex, currentIndex + 1);
      }
    }
    
    updateSlidePosition();
    manageChainPlayback();
  }

  function startChainLogic() {
    clearInterval(chainInterval);
    manageChainPlayback();
    chainInterval = setInterval(runChainStep, 3000);
  }

  function stopChainLogic() {
    clearInterval(chainInterval);
    const cards = track.querySelectorAll('.video-carousel-card');
    cards.forEach(card => {
      const video = card.querySelector('video');
      if(video) video.pause();
      card.classList.remove('active-playing');
    });
  }

  // 🚀 FIXED STEPPERS: Adjust view limits by precisely 1 index element per user pointer click interaction 
  function handleManualNext() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);

    if (currentIndex >= maxIndex) {
      currentIndex = 0; // Seamless rewind back to frame 1 block boundary limits
    } else {
      currentIndex++; // Increment track shift step by exactly 1 position index
    }
    playChainIndex = currentIndex;
    updateSlidePosition();
    startChainLogic();
  }

  function handleManualPrev() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);

    if (currentIndex <= 0) {
      currentIndex = maxIndex; // Jump forward to frame tail limits
    } else {
      currentIndex--; // Decrement track shift step by exactly 1 position index
    }
    playChainIndex = currentIndex;
    updateSlidePosition();
    startChainLogic();
  }

  btnRight.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); handleManualNext(); });
  btnLeft.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); handleManualPrev(); });
  btnRight.addEventListener('mousedown', function(e) { e.preventDefault(); e.stopPropagation(); handleManualNext(); });
  btnLeft.addEventListener('mousedown', function(e) { e.preventDefault(); e.stopPropagation(); handleManualPrev(); });

  window.addEventListener('resize', updateSlidePosition);

  track.addEventListener('click', function(e) {
    const card = e.target.closest('.video-carousel-card');
    if (!card) return;
    const targetUrl = card.getAttribute('data-video-url');
    if (targetUrl && targetUrl !== "") {
      stopChainLogic();
      modalVideo.src = targetUrl;
      modal.style.display = 'flex';
      modalVideo.play();
    }
  });

  function closePopupModal() {
    modal.style.display = 'none';
    modalVideo.pause();
    modalVideo.src = "";
    startChainLogic();
  }

  modalClose.addEventListener('click', closePopupModal);
  modal.addEventListener('click', function(e) { if(e.target === modal) closePopupModal(); });

  setTimeout(startChainLogic, 200);
});
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
