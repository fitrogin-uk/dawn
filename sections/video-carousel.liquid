{% comment %}
  Shopify Custom Fixed-Width Video Carousel
  - Strict large layout container
  - Forces 5th slide overhang on desktop screens
  - Hidden completely on mobile
{% endcomment %}

<div class="video-carousel-wrapper" id="VideoCarousel-{{ section.id }}">
  <!-- Left Navigation Arrow -->
  <button class="carousel-arrow arrow-left" aria-label="Previous slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>

  <div class="video-carousel-container">
    <div class="video-carousel-track">
      {%- for block in section.blocks -%}
        {%- if block.settings.video_select != blank -%}
          <div class="video-carousel-card" {{ block.shopify_attributes }}>
            {{ block.settings.video_select | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
          </div>
        {%- else -%}
          <div class="video-carousel-card placeholder-card" {{ block.shopify_attributes }}>
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Right Navigation Arrow -->
  <button class="carousel-arrow arrow-right" aria-label="Next slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>
</div>

<style>
/* Forces break-out of standard theme container boundaries */
.video-carousel-wrapper {
  position: relative;
  width: 100vw !important;
  max-width: 100vw !important;
  left: 50% !important;
  right: 50% !important;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  padding: 40px 0;
  background: transparent;
  display: block;
  box-sizing: border-box;
}

.video-carousel-container {
  overflow: hidden !important;
  width: 100%;
  padding-left: 5%; /* Aligns the start point elegantly with your content margins */
  box-sizing: border-box;
}

.video-carousel-track {
  display: flex !important;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  width: max-content !important; /* Prevents compression across container bounds */
}

/* 
  STRICT PIXEL SIZING: Sets a fixed width so frames remain 
  large on your desktop monitor while preserving the peeking effect.
*/
.video-carousel-card {
  width: 320px !important;
  min-width: 320px !important;
  flex-shrink: 0 !important;
  padding-right: 20px !important;
  box-sizing: border-box;
}

/* Tablet Fallback Adjustments */
@media (max-width: 1024px) {
  .video-carousel-card { 
    width: 260px !important; 
    min-width: 260px !important; 
  } 
}

/* ❌ HIDDEN COMPLETELY ON MOBILE PREVIEW WINDOWS */
@media (max-width: 749px) {
  .video-carousel-wrapper {
    display: none !important;
  }
}

/* Vertically Large Portrait Video Blocks */
.video-carousel-card video, 
.video-carousel-card svg {
  width: 100% !important;
  aspect-ratio: 9 / 16 !important; /* Strict portrait formatting lock */
  height: auto !important;
  border-radius: 24px;
  object-fit: cover;
  display: block;
}
.placeholder-card svg {
  background: #e2e2e2;
}

/* Minimalist Arrow Elements mapped securely on layout edges */
.carousel-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 48px;
  height: 48px;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  color: #000000;
  transition: transform 0.2s ease;
  padding: 0;
}

.carousel-arrow:hover {
  transform: translateY(-50%) scale(1.15);
}

.carousel-arrow svg {
  width: 40px;
  height: 40px;
}

.arrow-left { 
  left: 20px; 
}
.arrow-right { 
  right: 20px; 
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('VideoCarousel-{{ section.id }}');
  if (!wrapper || window.innerWidth <= 749) return;

  const track = wrapper.querySelector('.video-carousel-track');
  const btnLeft = wrapper.querySelector('.arrow-left');
  const btnRight = wrapper.querySelector('.arrow-right');
  
  let currentIndex = 0;

  function updateSlidePosition() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if(cards.length === 0) return;
    const cardWidth = cards[0].getBoundingClientRect().width;
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
  }

  function nextSlide() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;
    
    // Calculates window area to ensure the slider doesn't run into empty space at the end
    const visibleCards = Math.floor(window.innerWidth / cards[0].getBoundingClientRect().width);
    const maxIndex = cards.length - visibleCards;
    
    if (currentIndex >= maxIndex) {
      currentIndex = 0;
    } else {
      currentIndex++;
    }
    updateSlidePosition();
  }

  function prevSlide() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;

    const visibleCards = Math.floor(window.innerWidth / cards[0].getBoundingClientRect().width);
    const maxIndex = cards.length - visibleCards;

    if (currentIndex <= 0) {
      currentIndex = maxIndex > 0 ? maxIndex : 0;
    } else {
      currentIndex--;
    }
    updateSlidePosition();
  }

  btnRight.addEventListener('click', () => {
    nextSlide();
    resetTimer();
  });
  
  btnLeft.addEventListener('click', () => {
    prevSlide();
    resetTimer();
  });

  let carouselInterval = setInterval(nextSlide, 3000);

  function resetTimer() {
    clearInterval(carouselInterval);
    carouselInterval = setInterval(nextSlide, 3000);
  }

  wrapper.addEventListener('mouseenter', () => clearInterval(carouselInterval));
  wrapper.addEventListener('mouseleave', () => carouselInterval = setInterval(nextSlide, 3000));
  window.addEventListener('resize', updateSlidePosition);
});
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
