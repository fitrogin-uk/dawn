{% comment %}
  Shopify Custom Auto-Scrolling Video Carousel (TikTok/Reels Style)
  Moves right to left automatically every 3 seconds
  - HIDDEN ON MOBILE -
{% endcomment %}

<div class="video-carousel-container" id="VideoCarousel-{{ section.id }}">
  <div class="video-carousel-track">
    {%- for block in section.blocks -%}
      {%- if block.settings.video_select != blank -%}
        <div class="video-carousel-card" {{ block.shopify_attributes }}>
          {{ block.settings.video_select | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
        </div>
      {%- else -%}
        <!-- Placeholder when no video is selected -->
        <div class="video-carousel-card placeholder-card" {{ block.shopify_attributes }}>
          {{ 'collection-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
.video-carousel-container {
  overflow: hidden;
  width: 100%;
  max-width: 100%;
  padding: 40px 0;
  background: transparent;
  display: block; /* Shown by default on desktop */
}
.video-carousel-track {
  display: flex;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  width: 100%;
}
.video-carousel-card {
  min-width: 20%; /* Shows 5 vertical videos on desktop */
  flex-shrink: 0;
  padding: 0 8px; /* Gap between cards */
  box-sizing: border-box;
}
@media (max-width: 1200px) {
  .video-carousel-card {
    min-width: 25%; /* Shows 4 videos on smaller desktops */
  }
}
@media (max-width: 990px) {
  .video-carousel-card {
    min-width: 33.33%; /* Shows 3 videos on tablet */
  }
}

/* ❌ HIDES THE ENTIRE SECTION ON MOBILE SCREENS */
@media (max-width: 749px) {
  .video-carousel-container {
    display: none !important;
  }
}

.video-carousel-card video, 
.video-carousel-card svg {
  width: 100%;
  aspect-ratio: 9 / 16; /* Forces a tall vertical TikTok aspect ratio */
  height: auto;
  border-radius: 24px; /* Matches the clean rounded corners in your image */
  object-fit: cover;
  display: block;
}
.placeholder-card svg {
  background: #e0e0e0;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('VideoCarousel-{{ section.id }}');
  if (!container) return;

  // Don't run the script execution logic if we are on a mobile device screen width
  if (window.innerWidth <= 749) return;

  const track = container.querySelector('.video-carousel-track');
  let cards = track.querySelectorAll('.video-carousel-card');
  if (cards.length <= 1) return;

  let currentIndex = 0;

  function moveLeft() {
    cards = track.querySelectorAll('.video-carousel-card');
    
    // Dynamically calculate visible cards based on screen size
    let visibleCards = 5;
    if (window.innerWidth <= 990) visibleCards = 3;
    else if (window.innerWidth <= 1200) visibleCards = 4;

    const maxIndex = cards.length - visibleCards;
    
    currentIndex++;
    
    if (currentIndex > maxIndex || maxIndex <= 0) {
      currentIndex = 0; // Reset to the first slide
    }
    
    const cardWidth = cards.getBoundingClientRect().width;
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
  }

  // Auto scroll every 3 seconds
  let carouselInterval = setInterval(moveLeft, 3000);

  // Pause on hover
  container.addEventListener('mouseenter', () => clearInterval(carouselInterval));
  container.addEventListener('mouseleave', () => carouselInterval = setInterval(moveLeft, 3000));
});
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video",
          "info": "Upload or choose an MP4 video file from your library."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
