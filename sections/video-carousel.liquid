{% comment %}
  Shopify Custom Centered Video Carousel
  - Moves automatically every 3 seconds
  - Dual-sided overhanging peek layout (left and right)
  - Hidden completely on mobile
{% endcomment %}

<div class="video-carousel-wrapper" id="VideoCarousel-{{ section.id }}">
  <!-- Left Navigation Arrow -->
  <button class="carousel-arrow arrow-left" aria-label="Previous slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>

  <div class="video-carousel-container">
    <div class="video-carousel-track">
      {%- for block in section.blocks -%}
        {%- if block.settings.video_select != blank -%}
          <div class="video-carousel-card" {{ block.shopify_attributes }}>
            {{ block.settings.video_select | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
          </div>
        {%- else -%}
          <div class="video-carousel-card placeholder-card" {{ block.shopify_attributes }}>
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Right Navigation Arrow -->
  <button class="carousel-arrow arrow-right" aria-label="Next slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>
</div>

<style>
/* Break theme layout containers to span 100% of display screen width */
.video-carousel-wrapper {
  position: relative;
  width: 100vw;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  padding: 30px 0;
  background: transparent;
  display: block;
  box-sizing: border-box;
}

.video-carousel-container {
  overflow: hidden;
  width: 100%;
  /* Padding on container acts as the gutter boundary space for the left side peek */
  padding: 0 4vw; 
  box-sizing: border-box;
}

.video-carousel-track {
  display: flex;
  transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
}

/* 
  Calculated sizing: 21.5vw width allows exactly 4 items to sit neatly inside 
  the padded window while revealing neighboring cuts on left/right borders.
*/
.video-carousel-card {
  width: 21.5vw;
  min-width: 21.5vw;
  flex-shrink: 0;
  padding: 0 8px; /* Balanced, clean spacing gaps between frames */
  box-sizing: border-box;
}

@media (max-width: 1200px) {
  .video-carousel-container { padding: 0 5vw; }
  .video-carousel-card { width: 30vw; min-width: 30vw; } 
}
@media (max-width: 990px) {
  .video-carousel-container { padding: 0 6vw; }
  .video-carousel-card { width: 44vw; min-width: 44vw; } 
}

/* ❌ HIDDEN ON MOBILE SCREEN DEVICES */
@media (max-width: 749px) {
  .video-carousel-wrapper {
    display: none !important;
  }
}

/* Video Frame Dimensions */
.video-carousel-card video, 
.video-carousel-card svg {
  width: 100%;
  aspect-ratio: 4 / 5; /* Clean portrait aspect ratio */
  height: auto;
  border-radius: 16px;
  object-fit: cover;
  display: block;
}
.placeholder-card svg {
  background: #dbdbdb;
}

/* Custom Navigation Chevron Buttons */
.carousel-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  color: #000000;
  transition: transform 0.2s ease;
  padding: 0;
}

.carousel-arrow:hover {
  transform: translateY(-50%) scale(1.2);
}

.carousel-arrow svg {
  width: 36px;
  height: 36px;
}

/* Anchored floating arrows mapped precisely past outer container lines */
.arrow-left { 
  left: 1vw; 
}
.arrow-right { 
  right: 1vw; 
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('VideoCarousel-{{ section.id }}');
  if (!wrapper || window.innerWidth <= 749) return;

  const track = wrapper.querySelector('.video-carousel-track');
  const btnLeft = wrapper.querySelector('.arrow-left');
  const btnRight = wrapper.querySelector('.arrow-right');
  
  let currentIndex = 0;

  function getVisibleCardsCount() {
    if (window.innerWidth <= 990) return 2;
    if (window.innerWidth <= 1200) return 3;
    return 4;
  }

  function updateSlidePosition() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if(cards.length === 0) return;
    
    const cardWidth = cards[0].getBoundingClientRect().width;
    
    // Smooth translation offset calculation based on current slide selection index
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
  }

  function nextSlide() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const visibleCards = getVisibleCardsCount();
    const maxIndex = cards.length - visibleCards;
    
    if (currentIndex >= maxIndex) {
      currentIndex = 0; // Seamless loop reset to block index 0
    } else {
      currentIndex++;
    }
    updateSlidePosition();
  }

  function prevSlide() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const visibleCards = getVisibleCardsCount();
    const maxIndex = cards.length - visibleCards;

    if (currentIndex <= 0) {
      currentIndex = maxIndex > 0 ? maxIndex : 0;
    } else {
      currentIndex--;
    }
    updateSlidePosition();
  }

  btnRight.addEventListener('click', () => {
    nextSlide();
    resetTimer();
  });
  
  btnLeft.addEventListener('click', () => {
    prevSlide();
    resetTimer();
  });

  let carouselInterval = setInterval(nextSlide, 3000);

  function resetTimer() {
    clearInterval(carouselInterval);
    carouselInterval = setInterval(nextSlide, 3000);
  }

  wrapper.addEventListener('mouseenter', () => clearInterval(carouselInterval));
  wrapper.addEventListener('mouseleave', () => carouselInterval = setInterval(nextSlide, 3000));
  window.addEventListener('resize', updateSlidePosition);
});
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
