{% comment %}
  Shopify Sequential-Playback Video Carousel - PART 1
  - Breakout framework to bypass theme layout limitations
  - Play button triangle enlarged to perfectly match your screenshot
  - Safe structural layers for the left/right arrow buttons
  - Hidden completely on mobile viewports
{% endcomment %}

<div class="video-carousel-wrapper" id="VideoCarousel-{{ section.id }}">
  <!-- Left Navigation Arrow Layer -->
  <button class="carousel-arrow arrow-left" type="button" aria-label="Previous batch">&lt;</button>

  <div class="video-carousel-container">
    <div class="video-carousel-track">
      {%- for block in section.blocks -%}
        {%- if block.settings.video_select != blank -%}
          {%- assign video_url = "" -%}
          {%- for source in block.settings.video_select.sources -%}
            {%- if source.format == 'mp4' -%}
              {%- assign video_url = source.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if video_url == "" -%}{%- assign video_url = block.settings.video_select.sources.url -%}{%- endif -%}
          
          <div class="video-carousel-card" {{ block.shopify_attributes }} data-video-url="{{ video_url }}">
            <div class="video-relative-frame">
              <video src="{{ video_url }}" muted playsinline preload="metadata" style="pointer-events: none;"></video>
              <div class="play-button-overlay">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"/></svg>
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="video-carousel-card placeholder-card" {{ block.shopify_attributes }} data-video-url="">
            <div class="video-relative-frame">
              {{ 'collection-1' | placeholder_svg_tag }}
              <div class="play-button-overlay">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"/></svg>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Right Navigation Arrow Layer -->
  <button class="carousel-arrow arrow-right" type="button" aria-label="Next batch">&gt;</button>
</div>

<!-- Full Screen Modal Popup Player -->
<div class="video-popup-modal" id="VideoModal-{{ section.id }}">
  <button class="modal-close-btn" type="button">&times;</button>
  <div class="modal-video-box">
    <video controls autoplay playsinline class="modal-active-video"></video>
  </div>
</div>

<style>
.video-carousel-wrapper {
  position: relative;
  width: 100vw !important;
  max-width: 100vw !important;
  left: 50% !important;
  right: 50% !important;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  padding: 30px 0;
  background: transparent;
  display: block;
  box-sizing: border-box;
}

.video-carousel-container {
  overflow: hidden !important;
  width: 100%;
  padding-left: 4vw;
  box-sizing: border-box;
}

.video-carousel-track {
  display: flex !important;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  width: max-content !important;
}

.video-carousel-card {
  width: 22vw !important;
  min-width: 22vw !important;
  flex-shrink: 0 !important;
  padding-right: 12px !important;
  box-sizing: border-box;
  cursor: pointer;
}

@media (max-width: 1200px) { .video-carousel-card { width: 30vw !important; min-width: 30vw !important; } }
@media (max-width: 990px) { .video-carousel-card { width: 44vw !important; min-width: 44vw !important; } }
@media (max-width: 749px) { .video-carousel-wrapper { display: none !important; } }

.video-relative-frame {
  position: relative;
  width: 100%;
}

.video-carousel-card video, 
.video-carousel-card svg {
  width: 100% !important;
  aspect-ratio: 9 / 16 !important;
  height: auto !important;
  border-radius: 16px;
  object-fit: cover;
  display: block;
  filter: brightness(0.70);
  transition: filter 0.4s ease;
}

.video-carousel-card.active-playing video,
.video-carousel-card.active-playing svg {
  filter: brightness(1) !important;
}

.placeholder-card svg { background: #e2e2e2; }

/* 🎬 PLAY BUTTON: Outer circle border frame */
.play-button-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60px;
  height: 60px;
  background: transparent;
  border: 1.5px solid #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  transition: transform 0.2s ease, opacity 0.3s;
  pointer-events: none;
  opacity: 0.35;
}

.video-carousel-card.active-playing .play-button-overlay {
  opacity: 1;
}

/* ▶️ INNER TRIANGLE: Vector scale re-balanced to perfectly match screenshot dimensions */
.play-button-overlay svg {
  width: 30px !important;
  height: 30px !important;
  margin-left: 5px; /* Alignment offset for vector path weight balance */
  filter: none !important;
}

/* 🏹 HARD FIX ARROWS: Isolated to ensure clicks bypass theme bounds completely */
.carousel-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: #ffffff !important; /* Pure fallback visibility fill */
  border: 1px solid #dcdcdc !important;
  border-radius: 50% !important;
  width: 40px !important;
  height: 40px !important;
  font-family: sans-serif;
  font-size: 20px;
  font-weight: bold;
  color: #000000 !important;
  cursor: pointer !important;
  z-index: 999999 !important; /* Highest layer index possible */
  pointer-events: all !important; /* Forces the browser to listen to pointer interactions */
  display: flex !important;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  transition: transform 0.2s;
}
.carousel-arrow:hover { transform: translateY(-50%) scale(1.15); }
.arrow-left { left: 10px; }
.arrow-right { right: 10px; }

.video-popup-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(8px);
  z-index: 99999;
  display: none;
  align-items: center;
  justify-content: center;
}
.modal-video-box {
  width: 90%;
  max-width: 480px;
  aspect-ratio: 9 / 16;
}
.modal-video-box video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16px;
}
.modal-close-btn {
  position: absolute;
  top: 20px;
  right: 30px;
  background: transparent;
  border: none;
  color: #ffffff;
  font-size: 45px;
  cursor: pointer;
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('VideoCarousel-{{ section.id }}');
  const modal = document.getElementById('VideoModal-{{ section.id }}');
  if (!wrapper || window.innerWidth <= 749) return;

  const track = wrapper.querySelector('.video-carousel-track');
  const btnLeft = wrapper.querySelector('.arrow-left');
  const btnRight = wrapper.querySelector('.arrow-right');
  const modalVideo = modal.querySelector('.modal-active-video');
  const modalClose = modal.querySelector('.modal-close-btn');
  
  let currentIndex = 0;
  let playChainIndex = 0;
  let chainInterval = null;

  function getGroupJumpSize() {
    if (window.innerWidth <= 990) return 2;
    if (window.innerWidth <= 1200) return 3;
    return 4; 
  }

  function updateSlidePosition() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;
    const cardWidth = cards.getBoundingClientRect().width;
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
  }

  function manageChainPlayback() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;

    cards.forEach((card, idx) => {
      const video = card.querySelector('video');
      if (idx === playChainIndex) {
        card.classList.add('active-playing');
        if (video && card.getAttribute('data-video-url') !== "") {
          video.currentTime = 0;
          video.play().catch((err) => console.log(err));
        }
      } else {
        card.classList.remove('active-playing');
        if (video) video.pause();
      }
    });
  }

  function runChainStep() {
    const cards = track.querySelectorAll('.video-carousel-card');
    if (cards.length === 0) return;

    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);
    const lastVisibleInGroup = currentIndex + jumpSize - 1;

    if (playChainIndex === lastVisibleInGroup || playChainIndex >= cards.length - 1) {
      if (currentIndex >= maxIndex) {
        currentIndex = 0;
        playChainIndex = 0;
      } else {
        currentIndex = Math.min(maxIndex, currentIndex + jumpSize);
        playChainIndex = currentIndex;
      }
      updateSlidePosition();
    } else {
      playChainIndex++;
    }
    
    manageChainPlayback();
  }

  function startChainLogic() {
    clearInterval(chainInterval);
    manageChainPlayback();
    chainInterval = setInterval(runChainStep, 3000);
  }

  function stopChainLogic() {
    clearInterval(chainInterval);
    const cards = track.querySelectorAll('.video-carousel-card');
    cards.forEach(card => {
      const video = card.querySelector('video');
      if(video) video.pause();
      card.classList.remove('active-playing');
    });
  }

  function handleManualNext() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);

    if (currentIndex >= maxIndex) {
      currentIndex = 0;
    } else {
      currentIndex = Math.min(maxIndex, currentIndex + jumpSize);
    }
    playChainIndex = currentIndex;
    updateSlidePosition();
    startChainLogic();
  }

  function handleManualPrev() {
    const cards = track.querySelectorAll('.video-carousel-card');
    const jumpSize = getGroupJumpSize();
    const maxIndex = Math.max(0, cards.length - jumpSize);

    if (currentIndex <= 0) {
      currentIndex = maxIndex;
    } else {
      currentIndex = Math.max(0, currentIndex - jumpSize);
    }
    playChainIndex = currentIndex;
    updateSlidePosition();
    startChainLogic();
  }

  // Double layer click listener variations to absolute override iframe isolation rules
  btnRight.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); handleManualNext(); });
  btnLeft.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); handleManualPrev(); });
  btnRight.addEventListener('mousedown', function(e) { e.preventDefault(); e.stopPropagation(); handleManualNext(); });
  btnLeft.addEventListener('mousedown', function(e) { e.preventDefault(); e.stopPropagation(); handleManualPrev(); });

  window.addEventListener('resize', updateSlidePosition);

  track.addEventListener('click', function(e) {
    const card = e.target.closest('.video-carousel-card');
    if (!card) return;
    const targetUrl = card.getAttribute('data-video-url');
    if (targetUrl && targetUrl !== "") {
      stopChainLogic();
      modalVideo.src = targetUrl;
      modal.style.display = 'flex';
      modalVideo.play();
    }
  });

  function closePopupModal() {
    modal.style.display = 'none';
    modalVideo.pause();
    modalVideo.src = "";
    startChainLogic();
  }

  modalClose.addEventListener('click', closePopupModal);
  modal.addEventListener('click', function(e) { if(e.target === modal) closePopupModal(); });

  setTimeout(startChainLogic, 200);
});
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
