{% comment %}
  Shopify Enterprise Sequential Batch Video Carousel - PART 1
  - Strict pixel-based tracking engine independent of theme container widths
  - High-visibility custom solid white triangle play button overlay
  - Absolute positioning layer priority overrides for arrow navigation chevrons
  - ADDED SIDE MARGINS & OUTER ARROW EXTENSIONS MATCHING SCREENSHOT EXACTLY
  - Hidden completely on mobile viewports
{% endcomment %}

<div class="sf-video-carousel-wrapper" id="SfVideoCarousel-{{ section.id }}">
  
  <!-- Hard-Layered Absolute Chevron Nav Elements with strict Global click execution routing -->
  <button class="sf-nav-arrow sf-btn-prev" type="button" onclick="window.sfMoveCarouselGroup('{{ section.id }}', 'prev')" aria-label="Previous Video Batch">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  
  <button class="sf-nav-arrow sf-btn-next" type="button" onclick="window.sfMoveCarouselGroup('{{ section.id }}', 'next')" aria-label="Next Video Batch">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>

  <div class="sf-video-carousel-viewport">
    <div class="sf-video-carousel-track">
      {%- for block in section.blocks -%}
        {%- assign current_video_url = "" -%}
        
        {%- if block.settings.video_select != blank -%}
          {%- for source in block.settings.video_select.sources -%}
            {%- if source.format == 'mp4' -%}
              {%- assign current_video_url = source.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if current_video_url == blank or current_video_url == "" -%}
            {%- assign current_video_url = block.settings.video_select.sources.url -%}
          {%- endif -%}
        {%- endif -%}

        <div class="sf-video-card{% if current_video_url == blank %} sf-placeholder-state{% endif %}" {{ block.shopify_attributes }} data-sf-url="{{ current_video_url | escape }}" data-index="{{ forloop.index0 }}">
          <div class="sf-video-inner-frame">
            {%- if current_video_url != blank -%}
              <video src="{{ current_video_url }}" muted playsinline preload="metadata" style="pointer-events: none; width: 100%; height: 100%; display: block;"></video>
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
            
            <!-- 🎬 PLAY BUTTON OVERLAY -->
            <div class="sf-play-circle-overlay">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"/></svg>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- Full-Screen Lightbox Audio Modal Portal Layout Container -->
<div class="sf-video-lightbox-portal" id="SfModal-{{ section.id }}" onclick="if(event.target === this) window.sfCloseLightboxPortal('{{ section.id }}')">
  <button class="sf-portal-close" type="button" onclick="window.sfCloseLightboxPortal('{{ section.id }}')">&times;</button>
  <div class="sf-portal-box">
    <video controls autoplay playsinline class="sf-portal-active-video"></video>
  </div>
</div>

<style>
/* Reset and breakout past theme boundary width limits */
.sf-video-carousel-wrapper {
  position: relative !important;
  width: 100vw !important;
  max-width: 100vw !important;
  left: 50% !important;
  right: 50% !important;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  padding: 40px 0 !important;
  background: transparent;
  display: block !important;
  box-sizing: border-box !important;
}

.sf-video-carousel-viewport {
  overflow: hidden !important;
  width: 100%;
  /* 🏁 FIXED MARGIN: Creates clean side gaps so videos align perfectly with your theme layout padding bounds */
  padding-left: 6% !important; 
  padding-right: 6% !important;
  box-sizing: border-box !important;
}

.sf-video-carousel-track {
  display: flex !important;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1) !important;
  width: max-content !important;
  will-change: transform !important;
}

/* Stable card framework geometry matrices */
.sf-video-card {
  width: 390px !important;
  min-width: 390px !important;
  max-width: 390px !important;
  flex-shrink: 0 !important;
  padding-right: 16px !important; /* Elegant modern side distance between video cards */
  box-sizing: border-box !important;
  cursor: pointer !important;
  user-select: none !important;
}

@media (max-width: 1400px) {
  .sf-video-card { width: 310px !important; min-width: 310px !important; max-width: 310px !important; }
}
@media (max-width: 1100px) {
  .sf-video-card { width: 250px !important; min-width: 250px !important; max-width: 250px !important; }
}

/* Hidden entirely on mobile viewports */
@media (max-width: 749px) {
  .sf-video-carousel-wrapper {
    display: none !important;
  }
}

.sf-video-inner-frame {
  position: relative !important;
  width: 100% !important;
}

.sf-video-card video, 
.sf-video-card svg {
  width: 100% !important;
  aspect-ratio: 9 / 16 !important;
  height: auto !important;
  border-radius: 20px !important;
  object-fit: cover !important;
  display: block !important;
  filter: brightness(0.60) !important;
  transition: filter 0.4s ease !important;
}

.sf-video-card.sf-active-chain video,
.sf-video-card.sf-active-chain svg {
  filter: brightness(1) !important;
}

.sf-placeholder-state svg {
  background: #e2e2e2 !important;
}

/* Play button ring controller styling overlays */
.sf-play-circle-overlay {
  position: absolute !important;
  top: 50% !important;
  left: 50% !important;
  transform: translate(-50%, -50%) !important;
  width: 64px !important;
  height: 64px !important;
  background: transparent !important;
  border: 2px solid #ffffff !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: opacity 0.3s, transform 0.2s ease !important;
  pointer-events: none !important;
  opacity: 0.35 !important;
}

.sf-video-card.sf-active-chain .sf-play-circle-overlay {
  opacity: 1 !important;
  transform: translate(-50%, -50%) scale(1.05) !important;
}

.sf-play-circle-overlay svg {
  width: 32px !important;
  height: 32px !important;
  color: #ffffff !important;
  fill: #ffffff !important;
  margin-left: 6px !important;
  filter: drop-shadow(0 2px 6px rgba(0,0,0,0.2)) !important;
}

/* 🏹 HARD FIXED NAVIGATION CHEVRONS: Moved cleanly past side padding gaps into absolute safety borders */
.sf-nav-arrow {
  position: absolute !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  background: transparent !important; /* Transparent background matching your reference image layout precisely */
  border: none !important;
  width: 44px !important;
  height: 44px !important;
  color: #000000 !important;
  cursor: pointer !important;
  z-index: 2147483647 !important;
  pointer-events: all !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1) !important;
  padding: 0 !important;
}
.sf-nav-arrow:hover {
  transform: translateY(-50%) scale(1.25) !important;
}
.sf-nav-arrow svg {
  width: 28px !important; /* Crisp, slightly larger typographic chevrons */
  height: 28px !important;
  display: block !important;
}
/* Aligned past the inner padding lines to hover cleanly outside video boundaries */
.sf-btn-prev { left: 2% !important; }
.sf-btn-next { right: 2% !important; }

/* Lightbox Modal Structure */
.sf-video-lightbox-portal {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background: rgba(0, 0, 0, 0.88) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
  z-index: 2147483647 !important;
  display: none;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
}
.sf-portal-box {
  width: 90% !important;
  max-width: 460px !important;
  aspect-ratio: 9 / 16 !important;
}
.sf-portal-box video {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  border-radius: 16px !important;
  box-shadow: 0 10px 40px rgba(0,0,0,0.6) !important;
}
.sf-portal-close {
  position: absolute !important;
  top: 24px !important;
  right: 32px !important;
  background: transparent !important;
  border: none !important;
  color: #ffffff !important;
  font-size: 50px !important;
  cursor: pointer !important;
  line-height: 1 !important;
}
</style>
<script>
(function() {
  const sectionId = "{{ section.id }}";
  
  // Expose global orchestration container layers for the window context
  window.sfCarouselInstances = window.sfCarouselInstances || {};

  function initSfCarousel() {
    const wrapper = document.getElementById('SfVideoCarousel-' + sectionId);
    if (!wrapper) return;

    const track = wrapper.querySelector('.sf-video-carousel-track');
    const cards = track.querySelectorAll('.sf-video-card');
    if (cards.length === 0) return;

    const instance = {
      currentIndex: 0,
      playChainIndex: 0,
      chainInterval: null,
      cards: cards,
      track: track,
      wrapper: wrapper,
      getGroupSize: function() {
        if (window.innerWidth <= 1100) return 2;
        if (window.innerWidth <= 1400) return 3;
        return 4;
      },
      updateTrackView: function() {
        if (this.cards.length === 0) return;
        const cardWidth = this.cards[0].getBoundingClientRect().width;
        this.track.style.transform = `translateX(-${this.currentIndex * cardWidth}px)`;
      },
      managePlaybackCycle: function() {
        this.cards.forEach((card, idx) => {
          const video = card.querySelector('video');
          if (idx === this.playChainIndex) {
            card.classList.add('sf-active-chain');
            if (video && card.getAttribute('data-sf-url') !== "") {
              video.currentTime = 0;
              video.play().catch(() => {});
            }
          } else {
            card.classList.remove('sf-active-chain');
            if (video) video.pause();
          }
        });
      },
      runLoopEngineStep: function() {
        const jumpSize = this.getGroupSize();
        const maxIdx = Math.max(0, this.cards.length - jumpSize);
        const lastVisibleGroupMember = this.currentIndex + jumpSize - 1;

        if (this.playChainIndex >= lastVisibleGroupMember || this.playChainIndex >= this.cards.length - 1) {
          if (this.currentIndex >= maxIdx) {
            this.currentIndex = 0;
            this.playChainIndex = 0;
          } else {
            this.currentIndex = Math.min(maxIdx, this.currentIndex + jumpSize);
            this.playChainIndex = this.currentIndex;
          }
          this.updateTrackView();
        } else {
          this.playChainIndex++;
        }
        this.managePlaybackCycle();
      },
      startMasterTimerLoop: function() {
        clearInterval(this.chainInterval);
        this.managePlaybackCycle();
        this.chainInterval = setInterval(() => this.runLoopEngineStep(), 3000);
      },
      stopMasterTimerLoop: function() {
        clearInterval(this.chainInterval);
        this.cards.forEach(card => {
          const video = card.querySelector('video');
          if (video) video.pause();
          card.classList.remove('sf-active-chain');
        });
      }
    };

    window.sfCarouselInstances[sectionId] = instance;

    // Attach native card interaction handlers to click triggers
    cards.forEach(card => {
      card.addEventListener('click', function(e) {
        const url = this.getAttribute('data-sf-url');
        if (url && url !== "") {
          instance.stopMasterTimerLoop();
          const modal = document.getElementById('SfModal-' + sectionId);
          const modalVideo = modal.querySelector('.sf-portal-active-video');
          modalVideo.src = url;
          modal.style.display = 'flex';
          modalVideo.play().catch(() => {});
        }
      });
    });

    // Setup initial delay loops to stop simultaneous browser fires
    setTimeout(() => {
      const initialVideos = track.querySelectorAll('video');
      initialVideos.forEach(v => { v.pause(); v.currentTime = 0; });
      instance.startMasterTimerLoop();
    }, 150);

    window.addEventListener('resize', () => instance.updateTrackView());
  }

  // Exposed global Window hooks to bypass Shopify iframe sandbox limits entirely
  window.sfMoveCarouselGroup = function(id, direction) {
    const inst = window.sfCarouselInstances[id];
    if (!inst) return;

    const jumpSize = inst.getGroupSize();
    const maxIdx = Math.max(0, inst.cards.length - jumpSize);

    if (direction === 'next') {
      if (inst.currentIndex >= maxIdx) {
        inst.currentIndex = 0;
      } else {
        inst.currentIndex = Math.min(maxIdx, inst.currentIndex + jumpSize);
      }
    } else {
      if (inst.currentIndex <= 0) {
        inst.currentIndex = maxIdx;
      } else {
        inst.currentIndex = Math.max(0, inst.currentIndex - jumpSize);
      }
    }

    inst.playChainIndex = inst.currentIndex;
    inst.updateTrackView();
    inst.startMasterTimerLoop();
  };

  window.sfCloseLightboxPortal = function(id) {
    const modal = document.getElementById('SfModal-' + id);
    if (!modal) return;
    const modalVideo = modal.querySelector('.sf-portal-active-video');
    modal.style.display = 'none';
    modalVideo.pause();
    modalVideo.src = "";
    
    const inst = window.sfCarouselInstances[id];
    if (inst) inst.startMasterTimerLoop();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSfCarousel);
  } else {
    initSfCarousel();
  }
})();
</script>

{% schema %}
{
  "name": "Auto Video Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video_select",
          "label": "Select Video Content (.mp4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
