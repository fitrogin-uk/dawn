{%- comment -%}
  Custom Product Main Section — Novomins style
  Image gallery (left) + product info / buy box / accordions (right)
{%- endcomment -%}

<style>
  .cpm { --cpm-accent: {{ section.settings.accent_color }}; --cpm-green: #1c7c45; }
  .cpm__breadcrumb { max-width: 100%; padding: 12px 40px 0; font-size: 13px; color: #777; }
  .cpm__breadcrumb a { color: #777; text-decoration: none; }
  .cpm__breadcrumb a:hover { text-decoration: underline; }
  .cpm__crumb-sep { margin: 0 6px; color: #aaa; }
  .cpm__crumb-current { color: #777; }
  .cpm__wrap { display: grid; grid-template-columns: 55fr 45fr; gap: 32px; max-width: 100%; margin: 0 auto; padding: 16px 40px 24px; }

  /* ---------- LEFT: Gallery ---------- */
  .cpm__gallery { position: relative; }
  .cpm__main-img { position: relative; border-radius: 16px; overflow: hidden; background: #f6f6f6; min-height: 520px; display: flex; align-items: center; justify-content: center; }
  .cpm__main-img img { width: 100%; height: auto; display: block; }
  .cpm__main-img .cpm__slide { display: none; width: 100%; }
  .cpm__main-img .cpm__slide.is-active { display: block; }
  .cpm__nav { position: absolute; top: 50%; transform: translateY(-50%); width: 36px; height: 36px; border-radius: 50%; background: #fff; border: 1px solid #e3e3e3; box-shadow: 0 2px 6px rgba(0,0,0,0.10); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 2; color: #111; font-size: 18px; line-height: 1; }
  .cpm__nav:hover { background: #f5f5f5; }
  .cpm__nav--prev { left: 10px; } .cpm__nav--next { right: 10px; }
  .cpm__thumbs { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .cpm__thumb { width: 72px; height: 72px; border-radius: 10px; overflow: hidden; border: 2px solid transparent; cursor: pointer; background: #f6f6f6; padding: 0; }
  .cpm__thumb.is-active { border-color: var(--cpm-accent); }
  .cpm__thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* ---------- RIGHT: Info ---------- */
  .cpm__info { max-width: 100%; color: #222; }
  .cpm__info a { text-decoration: none; }
  .cpm__reviews { display: flex; align-items: center; gap: 4px; margin-bottom: 12px; }
  .cpm__stars { display: inline-flex; align-items: center; gap: 1px; }
  .cpm__stars svg { display: block; }
  .cpm__reviews-count { font-size: 11px; color: #111; font-weight: 500; line-height: 1; align-self: center; }
  .cpm__title { font-size: 50px; font-weight: 800; color: #111; margin: 0 0 6px; letter-spacing: -0.5px; line-height: 1.05; }
  .cpm__subtitle { font-size: 22px; font-weight: 700; color: #111; margin: 0 0 18px; }

  .cpm__tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .cpm__tag { border: 1px solid #d8d8d8; background: #fff !important; border-radius: 6px; padding: 8px 14px; font-size: 15px; font-weight: 400; color: #444 !important; white-space: nowrap; }

  .cpm__badge { display: inline-flex; align-items: center; gap: 10px; background: #fff !important; color: #1f2d27 !important; border: 1px solid #cfe3d6; border-radius: 999px; padding: 7px 16px 7px 7px; font-size: 14px; font-weight: 600; text-decoration: none; margin-bottom: 18px; }
  .cpm__badge-check { display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; background: var(--cpm-green) !important; border-radius: 50%; flex: 0 0 26px; }
  .cpm__badge-label { display: flex; flex-direction: column; line-height: 1.15; text-align: left; }
  .cpm__badge-label > span { color: #1f2d27 !important; font-weight: 700; }
  .cpm__badge-label small { font-size: 10px; font-weight: 600; color: #8a9a90 !important; letter-spacing: 0.06em; }
  .cpm__badge-arrow { color: #4a4a4a !important; font-size: 18px; font-weight: 700; line-height: 1; }

  .cpm__desc { font-size: 16px; line-height: 1.55; color: #333 !important; margin: 0 0 20px; }

  .cpm__benefits { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; margin-bottom: 24px; }
  .cpm__benefit { display: flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 500; color: #222 !important; }
  .cpm__benefit-check { flex: 0 0 20px; width: 20px; height: 20px; background: #fff !important; border: 1.5px solid #444; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }

  /* Buy box */
  .cpm__buybox { border: 1px solid #e3e3e3; border-radius: 16px; overflow: hidden; margin-bottom: 16px; }
  .cpm__plan { border-bottom: 1px solid #eee; }
  .cpm__plan:last-child { border-bottom: none; }
  .cpm__plan-head { display: flex; align-items: center; gap: 12px; padding: 16px; cursor: pointer; }
  .cpm__buybox { border: 1px solid #e3e3e3; border-radius: 16px; overflow: visible; }
  .cpm__plan { position: relative; border: 2px solid transparent; border-bottom: 1px solid #eee; }
  .cpm__plan.is-active { background: #fdf5f8; border: 2px solid var(--cpm-pink, #f4c2d2); border-radius: 14px; }
  .cpm__radio { flex: 0 0 20px; width: 20px; height: 20px; border-radius: 50%; border: 2px solid #ccc; position: relative; }
  .cpm__plan.is-active .cpm__radio { border-color: #111; }
  .cpm__plan.is-active .cpm__radio::after { content: ''; position: absolute; inset: 3px; border-radius: 50%; background: #111; }
  .cpm__plan-name { font-weight: 700; font-size: 16px; color: #111; }
  .cpm__plan-sub { font-size: 13px; color: #666; }
  .cpm__plan-price { margin-left: auto; text-align: right; display: flex; flex-direction: column; align-items: flex-end; }
  .cpm__plan-price .price-row { display: flex; align-items: baseline; gap: 6px; }
  .cpm__plan-price .now { font-weight: 800; font-size: 18px; color: #111; }
  .cpm__plan-price .was { font-size: 13px; color: #999; text-decoration: line-through; }
  .cpm__plan-price .perday { font-size: 12px; color: #999; }
  .cpm__sale-pill { display: inline-block; background: #111; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px; margin-right: 6px; vertical-align: middle; }
  .cpm__plan-perks { padding: 0 16px 16px 48px; }
  .cpm__plan-perk { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #444; margin-bottom: 4px; }

  /* Trust / shipping / payment */
  .cpm__shipline { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 14px; color: #444; margin: 14px 0; }
  .cpm__pay { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 14px; }
  .cpm__pay img, .cpm__pay svg { height: 24px; width: auto; border-radius: 4px; }
  .cpm__rewards { display: flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #e3e3e3; border-radius: 10px; padding: 12px; font-size: 14px; color: #333; margin-bottom: 24px; }
  .cpm__rewards svg { flex: 0 0 18px; }

  /* Accordions */
  .cpm__acc { border-top: 1px solid #eee; }
  .cpm__acc details { border-bottom: 1px solid #eee; }
  .cpm__acc summary { display: flex; align-items: center; justify-content: space-between; padding: 22px 4px; cursor: pointer; font-weight: 600; font-size: 22px; color: #111; list-style: none; }
  .cpm__acc summary::-webkit-details-marker { display: none; }
  .cpm__acc summary::after { content: ''; width: 14px; height: 14px; border-right: 2px solid #888; border-bottom: 2px solid #888; transform: rotate(45deg); transition: transform 0.2s; margin-right: 6px; }
  .cpm__acc details[open] summary::after { transform: rotate(-135deg); }
  .cpm__acc-body { padding: 0 4px 18px; font-size: 15px; line-height: 1.6; color: #444; }

  .cpm__atc { position: relative; width: 100%; background: var(--cpm-accent); color: #fff; border: none; border-radius: 999px; padding: 18px; font-size: 17px; font-weight: 700; cursor: pointer; margin-bottom: 12px; display: flex; align-items: center; justify-content: center; }
  .cpm__atc:hover { opacity: 0.92; }
  .cpm__atc-cart { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); width: 38px; height: 38px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; }
  .cpm__atc-cart svg { color: #111; }

  /* ===== Hard overrides to beat Dawn colour scheme ===== */
  .cpm .cpm__desc, .cpm .cpm__desc * { color: #333 !important; }
  .cpm .cpm__reviews-count { color: #111 !important; }
  .cpm .cpm__benefit, .cpm .cpm__benefit span { color: #222 !important; }
  .cpm .cpm__title, .cpm .cpm__subtitle { color: #111 !important; }
  .cpm .cpm__tag { color: #555 !important; background: #fff !important; font-weight: 400 !important; font-size: 17px !important; border-radius: 8px !important; border: 1px solid #999 !important; padding: 11px 18px !important; }
  .cpm a.cpm__badge, .cpm a.cpm__badge .cpm__badge-label > span { color: #1f2d27 !important; background: #fff !important; }
  .cpm a.cpm__badge .cpm__badge-label small { color: #8a9a90 !important; background: transparent !important; }
  .cpm a.cpm__badge .cpm__badge-arrow { color: #4a4a4a !important; }
  .cpm a.cpm__badge .cpm__badge-check { background: #1c7c45 !important; }
  .cpm .cpm__benefit-check { background: #fff !important; }

  @media (max-width: 989px) {
    .cpm__wrap { grid-template-columns: 1fr; gap: 28px; padding: 16px; }
    .cpm__title { font-size: 34px; }
    .cpm__benefits { grid-template-columns: 1fr; }
  }
</style>

<div class="cpm">
  <nav class="cpm__breadcrumb" aria-label="breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="cpm__crumb-sep">›</span>
    {%- if collection.url != blank -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
    {%- else -%}
      <a href="{{ routes.all_products_collection_url }}">All products</a>
    {%- endif -%}
    <span class="cpm__crumb-sep">›</span>
    <span class="cpm__crumb-current">{{ product.title }}</span>
  </nav>
  <div class="cpm__wrap">

    {%- comment -%} ============ LEFT: GALLERY ============ {%- endcomment -%}
    <div class="cpm__gallery">
      <div class="cpm__main-img" id="cpmMain">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <div class="cpm__slide{% if forloop.first %} is-active{% endif %}" data-cpm-slide="{{ forloop.index0 }}">
              {{ media | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {%- endfor -%}
          {%- if product.media.size > 1 -%}
            <button class="cpm__nav cpm__nav--prev" data-cpm-prev aria-label="Previous"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M8 2L2 8l6 6" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
            <button class="cpm__nav cpm__nav--next" data-cpm-next aria-label="Next"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M2 2l6 6-6 6" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
          {%- endif -%}
        {%- else -%}
          <div class="cpm__slide is-active">{{ 'product-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="cpm__thumbs" id="cpmThumbs">
          {%- for media in product.media -%}
            <button class="cpm__thumb{% if forloop.first %} is-active{% endif %}" data-cpm-thumb="{{ forloop.index0 }}">
              {{ media | image_url: width: 150 | image_tag: loading: 'lazy', alt: product.title }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ============ RIGHT: INFO ============ {%- endcomment -%}
    <div class="cpm__info">

      {%- comment -%} Reviews {%- endcomment -%}
      {%- assign rating = section.settings.review_rating | times: 1.0 -%}
      {%- assign r_floor = rating | floor -%}
      {%- assign r_ceil = rating | ceil -%}
      {%- assign r_half = false -%}
      {%- if r_ceil != r_floor -%}{%- assign r_half = true -%}{%- endif -%}
      <div class="cpm__reviews">
        <span class="cpm__stars">
          {%- for i in (1..5) -%}
            {%- if i <= r_floor -%}
              <svg width="21" height="21" viewBox="0 0 24 24" fill="#111"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" stroke="#111" stroke-width="0.8" stroke-linejoin="miter"/></svg>
            {%- elsif i == r_ceil and r_half -%}
              <svg width="21" height="21" viewBox="0 0 24 24"><defs><linearGradient id="cpmhalf"><stop offset="75%" stop-color="#111"/><stop offset="75%" stop-color="#fff"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" fill="url(#cpmhalf)" stroke="#111" stroke-width="0.8" stroke-linejoin="miter"/></svg>
            {%- else -%}
              <svg width="21" height="21" viewBox="0 0 24 24" fill="#fff"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" stroke="#111" stroke-width="0.8" stroke-linejoin="miter"/></svg>
            {%- endif -%}
          {%- endfor -%}
        </span>
        <span class="cpm__reviews-count">({{ section.settings.review_count }} Reviews)</span>
      </div>

      {%- comment -%} Title + subtitle {%- endcomment -%}
      <h1 class="cpm__title">{{ product.title }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="cpm__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- comment -%} Tags {%- endcomment -%}
      {%- if section.settings.tags != blank -%}
        <div class="cpm__tags">
          {%- assign tag_items = section.settings.tags | split: ',' -%}
          {%- for t in tag_items -%}
            <span class="cpm__tag">{{ t | strip }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Green badge {%- endcomment -%}
      {%- if section.settings.badge_text != blank -%}
        <a href="{{ section.settings.badge_link | default: '#' }}" class="cpm__badge">
          <span class="cpm__badge-check">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="cpm__badge-label">
            <span>{{ section.settings.badge_text }}</span>
            {%- if section.settings.badge_subtext != blank -%}<small>{{ section.settings.badge_subtext }}&reg;</small>{%- endif -%}
          </span>
          <span class="cpm__badge-arrow">›</span>
        </a>
      {%- endif -%}

      {%- comment -%} Description {%- endcomment -%}
      {%- if section.settings.description != blank -%}
        <p class="cpm__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- comment -%} Benefits grid {%- endcomment -%}
      {%- if section.settings.benefits != blank -%}
        <div class="cpm__benefits">
          {%- assign benefit_items = section.settings.benefits | newline_to_br | split: '<br />' -%}
          {%- for b in benefit_items -%}
            {%- assign bt = b | strip -%}
            {%- if bt != blank -%}
              <div class="cpm__benefit">
                <span class="cpm__benefit-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                <span>{{ bt }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} ============ BUY FORM ============ {%- endcomment -%}
      {%- form 'product', product, id: 'cpmForm' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="cpm__buybox">
          {%- comment -%} Subscribe plan (if available) {%- endcomment -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          {%- if current_variant.selling_plan_allocations.size > 0 -%}
            {%- assign plan_alloc = current_variant.selling_plan_allocations.first -%}
            <div class="cpm__plan is-active" data-cpm-plan="subscribe">
              <label class="cpm__plan-head">
                <input type="radio" name="selling_plan" value="{{ plan_alloc.selling_plan.id }}" style="display:none;" checked>
                <span class="cpm__radio"></span>
                <span>
                  <span class="cpm__plan-name">Subscribe &amp; Save</span><br>
                  <span class="cpm__plan-sub">{{ plan_alloc.selling_plan.name }}</span>
                </span>
                <span class="cpm__plan-price">
                  <span class="now">{{ plan_alloc.price | money }}</span><br>
                  {%- if plan_alloc.compare_at_price > plan_alloc.price -%}<span class="was">{{ plan_alloc.compare_at_price | money }}</span>{%- endif -%}
                </span>
              </label>
              <div class="cpm__plan-perks">
                <div class="cpm__plan-perk">✓ Lowest price</div>
                <div class="cpm__plan-perk">✓ Cancel anytime</div>
                <div class="cpm__plan-perk">✓ Earn points &amp; rewards</div>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} One-time purchase {%- endcomment -%}
          <div class="cpm__plan{% unless current_variant.selling_plan_allocations.size > 0 %} is-active{% endunless %}" data-cpm-plan="onetime">
            <label class="cpm__plan-head">
              <input type="radio" name="selling_plan" value="" style="display:none;"{% unless current_variant.selling_plan_allocations.size > 0 %} checked{% endunless %}>
              <span class="cpm__radio"></span>
              <span>
                <span class="cpm__plan-name">Buy Once</span><br>
                <span class="cpm__plan-sub">One-time purchase</span>
              </span>
              <span class="cpm__plan-price">
                <span class="price-row">
                  {%- if current_variant.compare_at_price > current_variant.price -%}
                    {%- assign saved = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
                    <span class="cpm__sale-pill">Sale {{ saved }}% Off</span>
                  {%- endif -%}
                  <span class="now">{{ current_variant.price | money }}</span>
                  {%- if current_variant.compare_at_price > current_variant.price -%}<span class="was">{{ current_variant.compare_at_price | money }}</span>{%- endif -%}
                </span>
                {%- if section.settings.per_day_text != blank -%}<span class="perday">{{ section.settings.per_day_text }}</span>{%- endif -%}
              </span>
            </label>
          </div>
        </div>

        <button type="submit" name="add" class="cpm__atc">
          <span>Add to cart</span>
          <span class="cpm__atc-cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </span>
        </button>
      {%- endform -%}

      {%- comment -%} Free shipping line {%- endcomment -%}
      {%- if section.settings.ship_text != blank -%}
        <div class="cpm__shipline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>{{ section.settings.ship_text }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} Payment icons {%- endcomment -%}
      <div class="cpm__pay">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'cpm__pay-icon' }}
        {%- endfor -%}
      </div>

      {%- comment -%} Rewards bar {%- endcomment -%}
      {%- if section.settings.rewards_text != blank -%}
        <div class="cpm__rewards">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/></svg>
          <span>{{ section.settings.rewards_text }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} ============ ACCORDIONS ============ {%- endcomment -%}
      <div class="cpm__acc">
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details {{ block.shopify_attributes }}{% if block.settings.open %} open{% endif %}>
              <summary>{{ block.settings.heading }}</summary>
              <div class="cpm__acc-body">{{ block.settings.content }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

<script>
  (function(){
    var root = document.currentScript.previousElementSibling || document;
    // Gallery
    var main = document.getElementById('cpmMain');
    var thumbs = document.getElementById('cpmThumbs');
    if (main) {
      var slides = main.querySelectorAll('[data-cpm-slide]');
      var thumbBtns = thumbs ? thumbs.querySelectorAll('[data-cpm-thumb]') : [];
      var cur = 0;
      function show(i){
        if (i < 0) i = slides.length - 1;
        if (i >= slides.length) i = 0;
        slides[cur].classList.remove('is-active');
        if (thumbBtns[cur]) thumbBtns[cur].classList.remove('is-active');
        cur = i;
        slides[cur].classList.add('is-active');
        if (thumbBtns[cur]) thumbBtns[cur].classList.add('is-active');
      }
      thumbBtns.forEach(function(b){ b.addEventListener('click', function(){ show(parseInt(b.dataset.cpmThumb)); }); });
      var prev = main.querySelector('[data-cpm-prev]');
      var next = main.querySelector('[data-cpm-next]');
      if (prev) prev.addEventListener('click', function(){ show(cur - 1); });
      if (next) next.addEventListener('click', function(){ show(cur + 1); });
    }
    // Plan selector
    var plans = document.querySelectorAll('[data-cpm-plan]');
    plans.forEach(function(p){
      p.querySelector('.cpm__plan-head').addEventListener('click', function(){
        plans.forEach(function(x){ x.classList.remove('is-active'); });
        p.classList.add('is-active');
        var radio = p.querySelector('input[type=radio]');
        if (radio) radio.checked = true;
      });
    });
  })();
</script>

