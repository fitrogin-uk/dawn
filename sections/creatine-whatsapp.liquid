<div class="cr-whatsapp">
  <div class="cr-whatsapp__inner">
    <div class="cr-whatsapp__icon-wrap">
      <svg class="cr-whatsapp__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </div>
    <div class="cr-whatsapp__content">
      <h2 class="cr-whatsapp__title">{{ section.settings.title }}</h2>
      <p class="cr-whatsapp__subtitle">{{ section.settings.subtitle }}</p>
      <ul class="cr-whatsapp__perks">
        <li>🎁 Exclusive member discounts &amp; early access</li>
        <li>💬 Direct access to our nutrition team</li>
        <li>📦 Order updates &amp; restock alerts</li>
        <li>🏆 Community challenges &amp; prizes</li>
      </ul>
      <a
        href="{{ section.settings.whatsapp_url }}"
        class="cr-whatsapp__cta"
        target="_blank"
        rel="noopener"
        aria-label="Join Fitrogin WhatsApp community">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {{ section.settings.cta_text }}
      </a>
    </div>
    <div class="cr-whatsapp__qr" aria-hidden="true">
      <div class="cr-whatsapp__qr-placeholder">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" width="120" height="120">
          <rect x="5" y="5" width="35" height="35" rx="4" fill="white" opacity="0.9"/>
          <rect x="10" y="10" width="25" height="25" rx="2" fill="#25D366"/>
          <rect x="60" y="5" width="35" height="35" rx="4" fill="white" opacity="0.9"/>
          <rect x="65" y="10" width="25" height="25" rx="2" fill="#25D366"/>
          <rect x="5" y="60" width="35" height="35" rx="4" fill="white" opacity="0.9"/>
          <rect x="10" y="65" width="25" height="25" rx="2" fill="#25D366"/>
          <rect x="60" y="60" width="10" height="10" rx="1" fill="white" opacity="0.9"/>
          <rect x="75" y="60" width="10" height="10" rx="1" fill="white" opacity="0.9"/>
          <rect x="60" y="75" width="10" height="10" rx="1" fill="white" opacity="0.9"/>
          <rect x="75" y="75" width="20" height="10" rx="1" fill="white" opacity="0.9"/>
          <rect x="85" y="60" width="10" height="10" rx="1" fill="white" opacity="0.9"/>
        </svg>
        <p>Scan to join</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "WhatsApp Community",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Join Our Community" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Be the first to know about new products, exclusive offers, and get direct access to our nutrition team. Over 2,000 members already inside." },
    { "type": "url", "id": "whatsapp_url", "label": "WhatsApp group link" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Join WhatsApp Group" }
  ],
  "presets": [{ "name": "WhatsApp Community" }]
}
{% endschema %}
