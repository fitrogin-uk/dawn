{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (Seconds)",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 56
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Height (Pixels)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 35
    },
  ],
  "presets": [
    {
      "name": "Marquee Banner"
    }
  ]
}
{% endschema %}

<div class="inline-marquee-container" style="background-color: {{ section.settings.bg_color }};">
  <div class="marquee-sub-wrapper">
    <span class="marquee-label"><strong style="color: #666666 !important;">As seen in</strong></span>

    <div class="marquee-window fading-mask">
      <div class="marquee-content animate-left" style="animation-duration: {{ section.settings.speed }}s;">

        {% for i in (1..4) %}
        <div class="marquee-group" style="--logo-h: {{ section.settings.logo_height }}px;">

          <!-- Mirror -->
          <svg class="marquee-logo" viewBox="0 0 130 38" xmlns="http://www.w3.org/2000/svg">
            <rect x="0" y="0" width="128" height="38" rx="2" fill="#000"/>
            <text x="64" y="27" font-family="Arial, sans-serif" font-size="18" font-weight="900" fill="#fff" text-anchor="middle" letter-spacing="2">MIRROR</text>
          </svg>

          <!-- The Sun -->
          <svg class="marquee-logo" viewBox="0 0 90 38" xmlns="http://www.w3.org/2000/svg">
            <rect x="0" y="0" width="88" height="38" rx="2" fill="#000"/>
            <text x="44" y="13" font-family="Arial, sans-serif" font-size="8" fill="#fff" text-anchor="middle" letter-spacing="2">THE</text>
            <text x="44" y="32" font-family="Arial Black, sans-serif" font-size="22" font-weight="900" fill="#fff" text-anchor="middle">Sun</text>
          </svg>

          <!-- Cosmopolitan -->
          <svg class="marquee-logo" viewBox="0 0 200 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="28" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="#000" letter-spacing="2">COSMOPOLITAN</text>
          </svg>

          <!-- Natural Health -->
          <svg class="marquee-logo" viewBox="0 0 80 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="15" font-family="Georgia, serif" font-size="11" font-style="italic" fill="#000">Natural</text>
            <text x="0" y="32" font-family="Georgia, serif" font-size="15" font-weight="700" fill="#000">Health</text>
          </svg>

          <!-- Bazaar -->
          <svg class="marquee-logo" viewBox="0 0 130 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="30" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#000" letter-spacing="4">BAZAAR</text>
          </svg>

          <!-- Sky News -->
          <svg class="marquee-logo" viewBox="0 0 110 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="28" font-family="Arial, sans-serif" font-size="22" font-weight="400" fill="#000">sky</text>
            <text x="48" y="28" font-family="Arial, sans-serif" font-size="22" font-weight="900" fill="#000">news</text>
          </svg>

          <!-- Vogue -->
          <svg class="marquee-logo" viewBox="0 0 130 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="30" font-family="Georgia, serif" font-size="30" font-weight="700" fill="#000" letter-spacing="4">VOGUE</text>
          </svg>

          <!-- GQ -->
          <svg class="marquee-logo" viewBox="0 0 70 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="34" font-family="Georgia, serif" font-size="40" font-weight="900" fill="#000">GQ</text>
          </svg>

          <!-- Glamour -->
          <svg class="marquee-logo" viewBox="0 0 140 38" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="28" font-family="Arial, sans-serif" font-size="22" font-weight="700" fill="#000" letter-spacing="3">GLAMOUR</text>
          </svg>

          <!-- The Independent -->
          <svg class="marquee-logo" viewBox="0 0 190 38" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="19" r="9" fill="#000"/>
            <text x="25" y="24" font-family="Georgia, serif" font-size="15" font-weight="700" fill="#000">The Independent</text>
          </svg>

        </div>
        {% endfor %}

      </div>
    </div>
  </div>
</div>

<style>
.inline-marquee-container {
  display: block;
  width: 100%;
  padding-top: 25px;
  padding-bottom: 25px;
  padding-left: 55px;
  padding-right: 55px;
  box-sizing: border-box;
  margin: 0 auto;
}
.marquee-sub-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 30px;
}
.marquee-label {
  font-family: Arial, sans-serif !important;
  font-size: 15px !important;
  white-space: nowrap;
}
.marquee-label strong {
  font-weight: 700 !important;
  display: inline-block;
  color: #666666 !important;
}
.marquee-window {
  overflow: hidden;
  flex-grow: 1;
  display: flex;
  align-items: center;
}
.fading-mask {
  -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 8%, rgba(0,0,0,1) 92%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 8%, rgba(0,0,0,1) 92%, transparent 100%);
}
.marquee-content {
  display: flex;
  width: max-content;
}
.marquee-group {
  display: flex;
  align-items: center;
  gap: 40px;
  padding-right: 40px;
}
.marquee-logo {
  height: var(--logo-h, 35px);
  width: auto;
  display: block;
  opacity: 1;
  transition: opacity 0.2s ease;
  flex-shrink: 0;
}
.marquee-logo:hover {
  opacity: 0.7;
}
.animate-left {
  animation: inline-scroll-left linear infinite;
}
@keyframes inline-scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-25%); }
}

@media screen and (max-width: 767px) {
  .inline-marquee-container {
    padding-left: 15px !important;
    padding-right: 15px !important;
    padding-top: 15px;
    padding-bottom: 15px;
  }
  .marquee-sub-wrapper { gap: 15px; }
  .marquee-label { font-size: 13px !important; }
  .fading-mask {
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, transparent 100%);
  }
  .marquee-group { gap: 20px; padding-right: 20px; }
  .marquee-logo { height: calc(var(--logo-h, 35px) * 0.73) !important; }
}
</style>