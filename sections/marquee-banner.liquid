{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (Seconds)",
      "min": 10,
      "max": 40,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Height (Pixels)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side Spacing (Pixels)",
      "min": 20,
      "max": 150,
      "step": 5,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

<div class="inline-marquee-container" style="background-color: {{ section.settings.bg_color }}; padding-left: {{ section.settings.side_padding }}px; padding-right: {{ section.settings.side_padding }}px;">
  <div class="marquee-sub-wrapper">
    <!-- "As seen in" Text Label -->
    <span class="marquee-label" style="font-weight: 700; font-size: 18px; margin-right: 15px;">As seen in</span>
    
    <!-- Moving Ticker Window -->
    <div class="marquee-window">
      <div class="marquee-content animate-left" style="animation-duration: {{ section.settings.speed }}s;">
        {% for i in (1..3) %}
          <div class="marquee-group">
            {% for block in section.blocks %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt }}" loading="lazy" style="height: {{ section.settings.logo_height }}px;">
              {% else %}
                <span class="placeholder-text">Logo Placeholder</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
.inline-marquee-container {
  display: block;
  width: 100%;
  padding-top: 20px;   /* Retained top padding to keep vertical height */
  padding-bottom: 20px;/* Retained bottom padding to keep vertical height */
  box-sizing: border-box;
  margin: 0 auto;
}
.marquee-sub-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 40px; 
}
.marquee-label {
  font-size: 14px; 
  color: #999999;
  font-family: inherit;
  white-space: nowrap;
  font-weight: 500;
}
.marquee-window {
  overflow: hidden;
  flex-grow: 1;
  display: flex;
  align-items: center;
}
.marquee-content {
  display: flex;
  width: max-content;
}
.marquee-group {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 70px; 
  padding-right: 70px;
}
.marquee-group img {
  width: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.8; 
}
.marquee-group .placeholder-text {
  color: #ccc;
  font-size: 13px;
  white-space: nowrap;
}
.animate-left {
  animation: inline-scroll-left linear infinite;
}
@keyframes inline-scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-33.333%); }
}
</style>
