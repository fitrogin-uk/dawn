{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (Seconds)",
      "min": 10,
      "max": 40,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

<div class="inline-marquee-container" style="background-color: {{ section.settings.bg_color }};">
  <div class="marquee-sub-wrapper">
    <!-- "As seen in" Text Label -->
    <span class="marquee-label">As seen in</span>
    
    <!-- Moving Ticker Window -->
    <div class="marquee-window">
      <div class="marquee-content animate-left" style="animation-duration: {{ section.settings.speed }}s;">
        {% for i in (1..3) %}
          <div class="marquee-group">
            {% for block in section.blocks %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
              {% else %}
                <span class="placeholder-text">Logo Placeholder</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
.inline-marquee-container {
  display: block;
  width: 100%;
  clear: both;
  float: left;
  padding: 25px 0;
  box-sizing: border-box;
}
.marquee-sub-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 20px;
}
.marquee-label {
  font-size: 14px;
  color: #999999;
  font-family: inherit;
  white-space: nowrap;
  font-weight: 500;
}
.marquee-window {
  overflow: hidden;
  flex-grow: 1;
  display: flex;
  align-items: center;
}
.marquee-content {
  display: flex;
  width: max-content;
}
.marquee-group {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 50px;
  padding-right: 50px;
}
.marquee-group img {
  height: 28px;
  width: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.7;
}
.marquee-group .placeholder-text {
  color: #ccc;
  font-size: 13px;
  white-space: nowrap;
}
.animate-left {
  animation: inline-scroll-left linear infinite;
}
@keyframes inline-scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-33.333%); }
}
</style>
