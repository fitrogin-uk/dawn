{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (Seconds)",
      "min": 10,
      "max": 40,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

<div class="marquee-wrapper" style="background-color: {{ section.settings.bg_color }};">
  <div class="marquee-content animate-left" style="animation-duration: {{ section.settings.speed }}s;">
    {% for i in (1..2) %}
      <div class="marquee-group">
        {% for block in section.blocks %}
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
          {% else %}
            <span class="placeholder-text" style="color: #ccc; margin: 0 20px;">Logo Placeholder</span>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
.marquee-wrapper {
  overflow: hidden;
  width: 100%;
  padding: 30px 0;
  display: flex;
  align-items: center;
}
.marquee-content {
  display: flex;
  width: max-content;
}
.marquee-group {
  display: flex;
  align-items: center;
  justify-content: space-around;
  min-width: 100%;
  gap: 80px;
  padding-right: 80px;
}
.marquee-group img {
  height: 35px;
  width: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.6;
}
.animate-left {
  animation: scroll-left linear infinite;
}
@keyframes scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>
