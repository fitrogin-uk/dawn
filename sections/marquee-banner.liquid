{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (Seconds)",
      "min": 10,
      "max": 40,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Height (Pixels)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side Spacing (Pixels)",
      "min": 10,
      "max": 150,
      "step": 5,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

<div class="inline-marquee-container" style="background-color: {{ section.settings.bg_color }};">
  <div class="marquee-sub-wrapper">
    <!-- Inline Override styling directly on the text characters -->
    <span class="marquee-label"><strong style="color: #666666 !important;">As seen in</strong></span>
    
    <!-- Moving Ticker Window with Fading Effect -->
    <div class="marquee-window fading-mask">
      <div class="marquee-content animate-left" style="animation-duration: {{ section.settings.speed }}s;">
        {% for i in (1..4) %}
          <div class="marquee-group">
            {% for block in section.blocks %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt }}" loading="lazy" style="--desktop-height: {{ section.settings.logo_height }}px;">
              {% else %}
                <span class="placeholder-text">Logo</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
/* DESKTOP STYLES */
.inline-marquee-container {
  display: block;
  width: 100%;
  padding-top: 25px;   
  padding-bottom: 25px;
  padding-left: {{ section.settings.side_padding }}px;
  padding-right: {{ section.settings.side_padding }}px;
  box-sizing: border-box;
  margin: 0 auto;
}
.marquee-sub-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 30px; 
}
.marquee-label {
  font-family: Arial, sans-serif !important; 
  font-size: 15px !important; 
  white-space: nowrap;
}
.marquee-label strong {
  font-weight: 700 !important; 
  display: inline-block;
  color: #666666 !important; 
}
.marquee-window {
  overflow: hidden;
  flex-grow: 1;
  display: flex;
  align-items: center;
}

/* GRADIENT FADE EFFECT FOR MOVING LOGOS (Desktop & Mobile) */
.fading-mask {
  -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 8%, rgba(0,0,0,1) 92%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 8%, rgba(0,0,0,1) 92%, transparent 100%);
}

.marquee-content {
  display: flex;
  width: max-content;
}
.marquee-group {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 65px; 
  padding-right: 65px;
}
.marquee-group img {
  height: var(--desktop-height);
  width: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.85; 
}
.marquee-group .placeholder-text {
  color: #ccc;
  font-size: 13px;
  white-space: nowrap;
  margin-right: 40px;
}
.animate-left {
  animation: inline-scroll-left linear infinite;
}
@keyframes inline-scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-25%); }
}

/* MOBILE RESPONSIVE FIXES */
@media screen and (max-width: 767px) {
  .inline-marquee-container {
    padding-left: 15px !important;  
    padding-right: 15px !important;
    padding-top: 15px;
    padding-bottom: 15px;
  }
  .marquee-sub-wrapper {
    gap: 15px; 
  }
  .marquee-label {
    font-size: 13px !important; 
  }
  
  /* Slightly deeper fade edge for tight mobile view screens */
  .fading-mask {
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, transparent 100%);
  }

  .marquee-group {
    gap: 25px; 
    padding-right: 25px;
  }
  .marquee-group img {
    height: calc(var(--desktop-height) * 0.73) !important; 
  }
}
</style>
