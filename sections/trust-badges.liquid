<div class="badge-container">
  <!-- Card 1 -->
  <div class="badge-card">
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 11l7-4 7 4M12 7v11M5 11v6l7 4m7-10v6l-7 4" /><path d="M2 7h3M3 10h2" stroke-linecap="round"/></svg>
    </div>
    <div class="badge-text">
      <strong>Free Shipping</strong>
      <span>Orders Over £30</span>
    </div>
  </div>

  <!-- Card 2 -->
  <div class="badge-card">
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 4v5a7 7 0 0014 0V4M8 3h2M14 3h2M12 16v5M12 21a2 2 0 100-4 2 2 0 000 4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="badge-text">
      <strong>Doctor Founded</strong>
      <span>Company</span>
    </div>
  </div>

  <!-- Card 3 -->
  <div class="badge-card">
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="5" width="12" height="15" rx="2" /><path d="M9 3h6v2H9zM9 10h1M9 13h1M9 16h1M12 10h3M12 13h3M12 16h3" stroke-linecap="round"/></svg>
    </div>
    <div class="badge-text">
      <span>All Products</span>
      <strong>3rd Party Tested</strong>
    </div>
  </div>

  <!-- Card 4 -->
  <div class="badge-card">
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l2.5 5 5.5.5-4 4 1 5.5-5-3-5 3 1-5.5-4-4 5.5-.5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="badge-text">
      <span>Earn</span>
      <strong>Reward Points</strong>
    </div>
  </div>

  <!-- Card 5 -->
  <div class="badge-card full-width-mobile">
    <div class="badge-text text-left-mobile">
      <span>Real Customer</span>
      <strong>Support</strong>
    </div>
    <div class="badge-icon headset-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 14c0-4.4 3.6-8 8-8s8 3.6 8 8M4 13h2v4H4v-4zm14 0h2v4h-2v-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="support-hours">Mon-Fri<br>9am to 5pm</span>
    </div>
  </div>
</div>

<style>
  /* Base Layout (Desktop - Side by Side) */
  .badge-container {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 15px 4%; 
    max-width: 1400px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    box-sizing: border-box;
    width: 100%;
  }

  .badge-card {
    flex: 1;
    background-color: #f1f1f1;
    border-radius: 16px;
    padding: 14px 20px;
    display: flex;
    flex-direction: row; /* Desktop: Icon next to text */
    align-items: center;
    justify-content: flex-start;
    gap: 14px;
    box-sizing: border-box;
  }

  /* Desktop Text Layout */
  .badge-text {
    display: flex;
    flex-direction: column;
    color: #1a1a1a;
    line-height: 1.3;
    text-align: left;
  }
  .badge-text strong { font-size: 13px; font-weight: 700; }
  .badge-text span { font-size: 11px; color: #666666; }

  /* Desktop Icon Sizes */
  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: #000000;
    flex-shrink: 0;
  }
  .badge-icon svg { width: 100%; height: 100%; }

  /* Headset Icon Container Overlap Fix */
  .headset-icon { 
    position: relative; 
    width: 58px; /* Wider canvas to keep text from touching headphone earcups */
    height: 46px; 
  }
  .support-hours {
    position: absolute;
    font-size: 7px;
    font-weight: bold;
    text-align: center;
    line-height: 1.1;
    top: 46%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    color: #000000;
  }

  /* Desktop configuration for the 5th item */
  .badge-card.full-width-mobile {
    justify-content: space-between;
  }

  /* Mobile Layout Breakpoint (Stops desktop style) */
  @media (max-width: 767px) {
    .badge-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      padding: 15px;
    }

    /* Mobile: Icon stacked on top of text */
    .badge-card {
      flex: none;
      width: 100%;
      flex-direction: column; 
      justify-content: center;
      align-items: center;
      text-align: center;
      border-radius: 24px;
      padding: 24px 15px;
      gap: 12px;
    }

    .badge-text {
      text-align: center;
    }

    /* Mobile: Icons are larger when stacked */
    .badge-icon {
      width: 44px;
      height: 44px;
    }

    /* Keep Support row layout side-by-side on mobile */
    .badge-card.full-width-mobile {
      grid-column: span 2;
      flex-direction: row; 
      justify-content: space-between;
      align-items: center;
      padding: 20px 24px;
    }

    .badge-card.full-width-mobile .badge-icon {
      width: 58px;
      height: 46px;
    }

    .text-left-mobile {
      text-align: left;
    }
  }
</style>

