  <!-- Card 5 -->
  <div class="badge-card full-width-mobile">
    <div class="badge-text text-left-mobile">
      <span>Real Customer</span>
      <strong>Support</strong>
    </div>
    <div class="badge-icon headset-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 14c0-4.4 3.6-8 8-8s8 3.6 8 8M4 13h2v4H4v-4zm14 0h2v4h-2v-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="support-hours">Mon-Fri<br>9am to 5pm</span>
    </div>
  </div>
</div>

<style>
  /* Base Layout (Desktop) */
  .badge-container {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 4%; /* Generous but controlled margins */
    max-width: 1400px; /* Prevents stretching too wide on massive screens */
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    box-sizing: border-box;
    width: 100%;
  }

  .badge-card {
    flex: 1; /* Makes all boxes equal size and fills available desktop space */
    background-color: #f1f1f1;
    border-radius: 20px;
    padding: 20px;
    display: flex;
    flex-direction: column; /* Stacked layout on desktop */
    align-items: center;
    justify-content: center;
    text-align: center;
    box-sizing: border-box;
    min-height: 140px;
  }

  /* Font Styling */
  .badge-text {
    display: flex;
    flex-direction: column;
    color: #1a1a1a;
    line-height: 1.4;
    margin-top: 12px;
  }
  .badge-text strong { font-size: 14px; font-weight: 700; }
  .badge-text span { font-size: 13px; color: #555555; }

  /* Icon Sizing */
  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: #000000;
    flex-shrink: 0;
  }
  .badge-icon svg { width: 100%; height: 100%; }

  /* Support Icon Adjustments */
  .headset-icon { position: relative; width: 50px; height: 50px; }
  .support-hours {
    position: absolute;
    font-size: 8px;
    font-weight: bold;
    text-align: center;
    line-height: 1.1;
    top: 45%;
    left: 50://;
    transform: translate(-50%, -50%);
    white-space: nowrap;
  }

  /* Desktop layout override for the last item (Support badge) */
  .badge-card.full-width-mobile {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
  .badge-card.full-width-mobile .badge-text {
    margin-top: 0;
    text-align: left;
  }

  /* Mobile Layout Breakpoint */
  @media (max-width: 767px) {
    .badge-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr); /* Exactly 2 columns */
      gap: 12px;
      padding: 15px;
    }

    .badge-card {
      flex: none;
      width: 100%;
      border-radius: 24px; /* More rounded as seen in mobile mockup */
      padding: 24px 15px;
      min-height: auto;
    }

    /* Target the 5th item (Support) to go full width and change layout direction */
    .badge-card.full-width-mobile {
      grid-column: span 2; /* Spans across both columns */
      flex-direction: row !important; /* Forces side-by-side layout on mobile */
      justify-content: space-between !important;
      padding: 20px 24px;
    }

    .text-left-mobile {
      text-align: left !important;
      margin-top: 0 !important;
    }
  }
</style>

