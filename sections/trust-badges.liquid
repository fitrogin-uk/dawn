<div class="custom-badge-wrapper">
  <div class="badge-container">
    <!-- Card 1 -->
    <div class="badge-card">
      <div class="badge-text">
        <strong class="title">Free Shipping</strong>
        <span class="subtitle">Orders Over £30</span>
      </div>
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          <path d="M3 5.5v3M5 4.5v4" stroke-width="1"/>
        </svg>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="badge-card">
      <div class="badge-text">
        <strong class="title">Doctor Founded</strong>
        <span class="subtitle">Company</span>
      </div>
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M6 3v6a6 6 0 0012 0V3M9 2h1M14 2h1M12 15v4M10 21h4"/>
          <circle cx="12" cy="20" r="1"/>
        </svg>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="badge-card">
      <div class="badge-text">
        <span class="subtitle">All Products</span>
        <strong class="title">3rd Party Tested</strong>
      </div>
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="5" y="4" width="14" height="16" rx="2"/>
          <path d="M9 8h6M9 12h6M9 16h6"/>
        </svg>
      </div>
    </div>

    <!-- Card 4 -->
    <div class="badge-card">
      <div class="badge-text">
        <span class="subtitle">Earn</span>
        <strong class="title">Reward Points</strong>
      </div>
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </div>
    </div>

    <!-- Card 5 -->
    <div class="badge-card full-width-mobile">
      <div class="badge-text support-text-mobile">
        <span class="subtitle">Real Customer</span>
        <strong class="title">Support</strong>
      </div>
      <div class="badge-icon headset-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M3 14c0-4.97 4.03-9 9-9s9 4.03 9 9M3 12h2v4H3v-4zm16 0h2v4h-2v-4z" stroke-linecap="round"/>
        </svg>
        <span class="support-hours">Mon-Fri<br>9am to 5pm</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* Outermost wrapper forces layout out of compressed theme constraints */
  .custom-badge-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    padding: 24px 0 !important;
    background-color: #ffffff;
    box-sizing: border-box;
  }

  /* Desktop Layout Container */
  .custom-badge-wrapper .badge-container {
    display: flex !important;
    justify-content: space-between !important;
    gap: 16px !important;
    padding: 0 4% !important;
    max-width: 1440px !important;
    margin: 0 auto !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    box-sizing: border-box;
    width: 100% !important;
  }

  /* Individual Badge Elements */
  .custom-badge-wrapper .badge-card {
    flex: 1 !important;
    background-color: #f3f4f6 !important; /* Premium light grey fill */
    border-radius: 16px !important;
    padding: 16px 20px !important;
    display: flex !important;
    flex-direction: row !important; /* Text left, icon right */
    align-items: center !important;
    justify-content: space-between !important; 
    box-sizing: border-box !important;
    min-height: 80px !important;
  }

  /* Desktop Text Layout rules */
  .custom-badge-wrapper .badge-text {
    display: flex !important;
    flex-direction: column !important;
    color: #000000 !important;
    line-height: 1.3 !important;
    text-align: left !important;
  }
  
  .custom-badge-wrapper .badge-text .title { 
    font-size: 14px !important; 
    font-weight: 600 !important; 
  }
  
  .custom-badge-wrapper .badge-text .subtitle { 
    font-size: 12px !important; 
    color: #6b7280 !important; 
  }

  /* Logo Properties */
  .custom-badge-wrapper .badge-icon {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 36px !important;
    height: 36px !important;
    color: #000000 !important;
    flex-shrink: 0 !important;
  }
  .custom-badge-wrapper .badge-icon svg { 
    width: 100% !important; 
    height: 100% !important; 
  }

  /* Headset Specific Spacing Rules */
  .custom-badge-wrapper .headset-icon { 
    position: relative !important; 
    width: 54px !important; 
    height: 42px !important; 
  }
  
  .custom-badge-wrapper .support-hours {
    position: absolute !important;
    font-size: 7px !important;
    font-weight: 700 !important;
    text-align: center !important;
    line-height: 1.1 !important;
    top: 42%;
    left: 47%;
    transform: translate(-50%, -50%) !important;
    white-space: nowrap !important;
    color: #000000 !important;
  }

  /* ==========================================================================
     MOBILE RESPONSIVE BREAKPOINT (Exact alignment to image 3)
     ========================================================================== */
  @media (max-width: 767px) {
    .custom-badge-wrapper .badge-container {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important; /* Clean 2-column mobile grid */
      gap: 12px !important;
      padding: 0 16px !important;
    }

    /* Cards 1 to 4 stacked layout rule override */
    .custom-badge-wrapper .badge-card {
      flex: none !important;
      width: 100% !important;
      flex-direction: column-reverse !important; /* Places logo straight on top */
      justify-content: center !important;
      align-items: center !important;
      border-radius: 24px !important; 
      padding: 24px 16px !important;
      gap: 14px !important;
      min-height: 150px !important;
    }

    .custom-badge-wrapper .badge-text {
      text-align: center !important;
    }
    
    .custom-badge-wrapper .badge-text .title { font-size: 14px !important; }
    .custom-badge-wrapper .badge-text .subtitle { font-size: 12px !important; }

    /* Increase icon bounds for stacked appearance */
    .custom-badge-wrapper .badge-card .badge-icon {
      width: 46px !important;
      height: 46px !important;
    }

    /* Card 5 layout override for full bottom row span */
    .custom-badge-wrapper .badge-card.full-width-mobile {
      grid-column: span 2 !important;
      flex-direction: row !important; /* Keeps row alignment */
      justify-content: space-between !important;
      align-items: center !important;
      padding: 20px 24px !important;
      min-height: 80px !important;
    }

    .custom-badge-wrapper .badge-card.full-width-mobile .support-text-mobile {
      text-align: left !important;
    }

    .custom-badge-wrapper .badge-card.full-width-mobile .headset-icon {
      width: 60px !important;
      height: 46px !important;
    }
    
    .custom-badge-wrapper .badge-card.full-width-mobile .support-hours {
      font-size: 7.5px !important;
      top: 42%;
      left: 46%;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Badges Section",
  "settings": [],
  "presets": [
    {
      "name": "Trust Badges Section"
    }
  ]
}
{% endschema %}
