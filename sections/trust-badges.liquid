<div class="badge-container">
  <!-- Card 1 -->
  <div class="badge-card">
    <div class="badge-text">
      <strong>Free Shipping</strong>
      <span>Orders Over £30</span>
    </div>
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 11l7-4 7 4M12 7v11M5 11v6l7 4m7-10v6l-7 4" /><path d="M2 7h3M3 10h2" stroke-linecap="round"/></svg>
    </div>
  </div>

  <!-- Card 2 -->
  <div class="badge-card">
    <div class="badge-text">
      <strong>Doctor Founded</strong>
      <span>Company</span>
    </div>
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 4v5a7 7 0 0014 0V4M8 3h2M14 3h2M12 16v5M12 21a2 2 0 100-4 2 2 0 000 4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
  </div>

  <!-- Card 3 -->
  <div class="badge-card">
    <div class="badge-text">
      <span>All Products</span>
      <strong>3rd Party Tested</strong>
    </div>
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="5" width="12" height="15" rx="2" /><path d="M9 3h6v2H9zM9 10h1M9 13h1M9 16h1M12 10h3M12 13h3M12 16h3" stroke-linecap="round"/></svg>
    </div>
  </div>

  <!-- Card 4 -->
  <div class="badge-card">
    <div class="badge-text">
      <span>Earn</span>
      <strong>Reward Points</strong>
    </div>
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l2.5 5 5.5.5-4 4 1 5.5-5-3-5 3 1-5.5-4-4 5.5-.5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
  </div>

  <!-- Card 5 (Full Width on Mobile) -->
  <div class="badge-card full-width-mobile">
    <div class="badge-text support-text-mobile">
      <span>Real Customer</span>
      <strong>Support</strong>
    </div>
    <div class="badge-icon headset-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 14c0-4.4 3.6-8 8-8s8 3.6 8 8M4 13h2v4H4v-4zm14 0h2v4h-2v-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="support-hours">Mon-Fri<br>9am to 5pm</span>
    </div>
  </div>
</div>

<style>
  /* ==========================================================================
     DESKTOP LAYOUT (Default Screen Styles)
     ========================================================================== */
  .badge-container {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 15px 2%; 
    max-width: 100%;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    box-sizing: border-box;
    width: 100%;
  }

  .badge-card {
    flex: 1;
    background-color: #f1f1f1;
    border-radius: 14px;
    padding: 14px 18px;
    display: flex;
    flex-direction: row; /* Desktop layout: Row text on left, logo on right */
    align-items: center;
    justify-content: space-between; /* Dynamic split */
    box-sizing: border-box;
  }

  /* Desktop Typography */
  .badge-text {
    display: flex;
    flex-direction: column;
    color: #1a1a1a;
    line-height: 1.3;
    text-align: left;
  }
  .badge-text strong { font-size: 13px; font-weight: 700; }
  .badge-text span { font-size: 11px; color: #666666; }

  /* Desktop Icon Sizes */
  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #000000;
    flex-shrink: 0;
  }
  .badge-icon svg { width: 100%; height: 100%; }

  /* Headset Frame Positioning */
  .headset-icon { 
    position: relative; 
    width: 52px; 
    height: 40px; 
  }
  .support-hours {
    position: absolute;
    font-size: 6.5px;
    font-weight: bold;
    text-align: center;
    line-height: 1.1;
    top: 42%;
    left: 47%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    color: #000000;
  }

  /* ==========================================================================
     MOBILE RESPONSIVE LAYOUT (Screens under 768px)
     ========================================================================== */
  @media (max-width: 767px) {
    .badge-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr); /* Forms exact 2-column mobile grid */
      gap: 12px;
      padding: 15px;
    }

    /* Cards 1 to 4: Exact Mobile Mockup Stacked Layout */
    .badge-card {
      flex: none;
      width: 100%;
      flex-direction: column-reverse; /* Places logo above text */
      justify-content: center;
      align-items: center;
      text-align: center;
      border-radius: 28px; /* Extra rounded style matching mobile mockup */
      padding: 24px 15px;
      gap: 12px;
    }

    .badge-text {
      text-align: center;
    }
    .badge-text strong { font-size: 14px; }
    .badge-text span { font-size: 12px; }

    /* Increase mobile logo size for stacked grids */
    .badge-card .badge-icon {
      width: 56px;
      height: 56px;
    }

    /* Card 5: Stretch full-width and maintain clean layout */
    .badge-card.full-width-mobile {
      grid-column: span 2; /* Forces block to fill row width */
      flex-direction: row; /* Horizontal text and logo alignment */
      justify-content: space-between;
      align-items: center;
      padding: 20px 24px;
    }

    /* Keep support text left aligned on mobile */
    .badge-card.full-width-mobile .support-text-mobile {
      text-align: left;
    }

    /* Maintain headphone proportion without overlap */
    .badge-card.full-width-mobile .headset-icon {
      width: 62px;
      height: 48px;
    }
    .badge-card.full-width-mobile .support-hours {
      font-size: 7.5px;
      top: 43%;
      left: 46%;
    }
  }
</style>

