<div class="shopify-trust-badges-section">
  
  <!-- ========================================== -->
  <!-- 1. DESKTOP VIEW CONTAINER                  -->
  <!-- ========================================== -->
  <div class="badges-desktop-view">
    
    <!-- Card 1: Free Shipping -->
    <div class="badge-card">
      <div class="badge-text">
        <strong class="title">Free Shipping</strong>
        <span class="subtitle">Orders Over £30</span>
      </div>
      <div class="badge-icon-wrap img-box"></div>
    </div>

    <!-- Card 2: Doctor Founded -->
    <div class="badge-card">
      <div class="badge-text">
        <strong class="title">Doctor Founded</strong>
        <span class="subtitle">Company</span>
      </div>
      <div class="badge-icon-wrap img-stethoscope"></div>
    </div>

    <!-- Card 3: 3rd Party Tested -->
    <div class="badge-card">
      <div class="badge-text">
        <span class="subtitle">All Products</span>
        <strong class="title">3rd Party Tested</strong>
      </div>
      <div class="badge-icon-wrap img-clipboard"></div>
    </div>

    <!-- Card 4: Reward Points -->
    <div class="badge-card">
      <div class="badge-text">
        <span class="subtitle">Earn</span>
        <strong class="title">Reward Points</strong>
      </div>
      <div class="badge-icon-wrap img-stars"></div>
    </div>

    <!-- Card 5: Support -->
    <div class="badge-card">
      <div class="badge-text">
        <span class="subtitle">Real Customer</span>
        <strong class="title">Support</strong>
      </div>
      <div class="badge-icon-wrap img-headset-desktop"></div>
    </div>
    
  </div>

  <!-- ========================================== -->
  <!-- 2. MOBILE VIEW CONTAINER                   -->
  <!-- ========================================== -->
  <div class="badges-mobile-view">
    
    <!-- Card 1 -->
    <div class="badge-card">
      <div class="badge-icon-wrap img-box"></div>
      <div class="badge-text">
        <strong class="title">Free Shipping</strong>
        <span class="subtitle">Orders Over £30</span>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="badge-card">
      <div class="badge-icon-wrap img-stethoscope"></div>
      <div class="badge-text">
        <strong class="title">Doctor Founded</strong>
        <span class="subtitle">Company</span>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="badge-card">
      <div class="badge-icon-wrap img-clipboard"></div>
      <div class="badge-text">
        <span class="subtitle">All Products</span>
        <strong class="title">3rd Party Tested</strong>
      </div>
    </div>

    <!-- Card 4 -->
    <div class="badge-card">
      <div class="badge-icon-wrap img-stars"></div>
      <div class="badge-text">
        <span class="subtitle">Earn</span>
        <strong class="title">Reward Points</strong>
      </div>
    </div>

    <!-- Card 5: Full Width Row -->
    <div class="badge-card-full">
      <div class="badge-text">
        <span class="subtitle">Real Customer</span>
        <strong class="title">Support</strong>
      </div>
      <div class="badge-icon-wrap img-headset-mobile"></div>
    </div>

  </div>
</div>

{% raw %}
<style>
  /* ========================================== */
  /* CSS ARCHITECTURE & STYLING                 */
  /* ========================================== */
  
  /* Break out of tight Shopify page limits */
  .shopify-trust-badges-section {
    width: 100% !important;
    display: block !important;
    margin: 20px 0 !important;
    padding: 0 20px !important;
    box-sizing: border-box !important;
  }

  /* Shared Text Styling */
  .shopify-trust-badges-section .badge-text {
    display: flex !important;
    flex-direction: column !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
    line-height: 1.25 !important;
  }
  .shopify-trust-badges-section .title {
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #111111 !important;
  }
  .shopify-trust-badges-section .subtitle {
    font-size: 11px !important;
    color: #777777 !important;
    font-weight: 400 !important;
  }

  /* Pure CSS Icons drawn using Background SVGs to avoid distortion */
  .shopify-trust-badges-section .badge-icon-wrap {
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: contain !important;
    display: block !important;
  }
  
  .img-box { width: 34px; height: 34px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.3' viewBox='0 0 24 24'%3E%3Cpath d='M5 11l7-4 7 4M12 7v11M5 11v6l7 4m7-10v6l-7 4M2 7h3M3 10h2' stroke-linecap='round'/%3E%3C/svg%3E"); }
  .img-stethoscope { width: 34px; height: 34px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.3' viewBox='0 0 24 24'%3E%3Cpath d='M5 4v5a7 7 0 0 0 14 0V4M8 3h2M14 3h2M12 16v5M12 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4z' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); }
  .img-clipboard { width: 34px; height: 34px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.3' viewBox='0 0 24 24'%3E%3Crect x='6' y='5' width='12' height='15' rx='2'/%3E%3Cpath d='M9 3h6v2H9zM9 9h6M9 12h6M9 15h3' stroke-linecap='round'/%3E%3C/svg%3E"); }
  .img-stars { width: 36px; height: 34px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.2' viewBox='0 0 24 24'%3E%3Cpath d='M7 10.5l1.5 3 3.5.5-2.5 2.5.5 3.5-3-2-3 2 .5-3.5-2.5-2.5 3.5-.5zM17 5.5l1 2.5 3 .5-2 2 .5 3-2.5-1.5-2.5 1.5.5-3-2-2 3-.5z'/%3E%3C/svg%3E"); }
  
  /* Desktop Support Badge with nested scheduler hours */
  .img-headset-desktop { width: 44px; height: 36px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.3' viewBox='0 0 24 24'%3E%3Cpath d='M4 14c0-4.4 3.6-8 8-8s8 3.6 8 8M4 13h1.5v4H4v-4zm14.5 0H20v4h-1.5v-4z'/%3E%3Ctext x='50%25' y='55%25' font-size='3' font-weight='bold' font-family='sans-serif' text-anchor='middle' fill='%23000'%3EMon-Fri%3C/text%3E%3Ctext x='50%25' y='67%25' font-size='2.2' font-family='sans-serif' text-anchor='middle' fill='%23555'%3E9am to 5pm%3C/text%3E%3C/svg%3E"); }
  
  /* Mobile Support Badge (Slightly cleaner text sizing for phone panels) */
  .img-headset-mobile { width: 54px; height: 44px; background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' fill='none' stroke='%23000' stroke-width='1.3' viewBox='0 0 24 24'%3E%3Cpath d='M4 14c0-4.4 3.6-8 8-8s8 3.6 8 8M4 13h1.5v4H4v-4zm14.5 0H20v4h-1.5v-4z'/%3E%3Ctext x='50%25' y='55%25' font-size='3' font-weight='bold' font-family='sans-serif' text-anchor='middle' fill='%23000'%3EMon-Fri%3C/text%3E%3Ctext x='50%25' y='67%25' font-size='2.2' font-family='sans-serif' text-anchor='middle' fill='%23555'%3E9am to 5pm%3C/text%3E%3C/svg%3E"); }

  /* ------------------------------------------ */
  /* DESKTOP ENGINE RULES                       */
  /* ------------------------------------------ */
  @media (min-width: 768px) {
    .shopify-trust-badges-section .badges-mobile-view { display: none !important; }
    
    .shopify-trust-badges-section .badges-desktop-view {
      display: flex !important;
      justify-content: space-between !important;
      gap: 12px !important;
      max-width: 1380px !important;
      margin: 0 auto !important;
      width: 100% !important;
    }

    .shopify-trust-badges-section .badges-desktop-view .badge-card {
      flex: 1 !important;
      background-color: #f1f2f4 !important;
      border-radius: 12px !important;
      padding: 14px 18px !important;
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
    }
  }

  /* ------------------------------------------ */
  /* MOBILE ENGINE RULES                        */
  /* ------------------------------------------ */
  @media (max-width: 767px) {
    .shopify-trust-badges-section .badges-desktop-view { display: none !important; }
    
    .shopify-trust-badges-section .badges-mobile-view {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 12px !important;
      width: 100% !important;
    }

    /* Cards 1 - 4: Square Stacked Layout Blocks */
    .shopify-trust-badges-section .badges-mobile-view .badge-card {
      background-color: #f1f2f4 !important;
      border-radius: 20px !important;
      padding: 24px 12px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      text-align: center !important;
      gap: 14px !important;
      box-sizing: border-box !important;
    }
    
    .shopify-trust-badges-section .badges-mobile-view .badge-card .badge-text {
      align-items: center !important;
      text-align: center !important;
    }

    /* Card 5: Full Width Horizontal Row Block */
    .shopify-trust-badges-section .badge-card-full {
      grid-column: span 2 !important;
      background-color: #f1f2f4 !important;
      border-radius: 20px !important;
      padding: 16px 20px !important;
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      box-sizing: border-box !important;
    }
    
    .shopify-trust-badges-section .badges-mobile-view .badge-card .badge-icon-wrap {
      width: 44px !important;
      height: 44px !important;
    }
  }
</style>
{% endraw %}

