{% schema %}
{
  "name": "Clinical Proven Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EAE5F4"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Clinically Proven"
    },
    {
      "type": "text",
      "id": "heading_pink",
      "label": "Heading Pink Text",
      "default": "Better Absorption"
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading Black Text",
      "default": "Than Tablets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "A comparative study found that vitamin D gummies achieved double nutrient absorption levels than standard vitamin D tablets."
    },
    {
      "type": "image_picker",
      "id": "chart_image",
      "label": "Upload Chart Graphic"
    }
  ],
  "presets": [
    {
      "name": "Clinical Proven Section"
    }
  ]
}
{% endschema %}

<div class="clinical-section-wrapper">
  <div class="clinical-container" style="background-color: {{ section.settings.bg_color }};">
    
    <!-- Element 1: Headings -->
    <div class="clinical-headings-block" style="margin-top: -50px !important;">
      <span class="clinical-subheading">{{ section.settings.sub_heading }}</span>
      <h2 class="clinical-heading">
        <span class="pink-text">{{ section.settings.heading_pink }}</span>
        <span class="black-text">{{ section.settings.heading_black }}</span>
      </h2>
    </div>
    
    <!-- Element 2: Graphic/Image -->
    <div class="clinical-graphic-col">
      <div class="chart-card-box">
        {% if section.settings.chart_image != blank %}
          <img src="{{ section.settings.chart_image | image_url: width: 1000 }}" alt="Absorption Chart Graphic" loading="lazy">
        {% else %}
          <div class="chart-placeholder">Upload your graph image in Theme Settings</div>
        {% endif %}
      </div>
    </div>

    <!-- Element 3: Description -->
    <div class="clinical-description-block">
      <p class="clinical-description">{{ section.settings.description }}</p>
    </div>

  </div>
</div>

<style>
/* Outer Wrapper Structural Layout styles */
.clinical-section-wrapper {
  width: 100%;
  padding-top: 15px;         
  padding-bottom: 40px;     
  padding-left: 24px;       
  padding-right: 24px;     
  box-sizing: border-box;
}

/* Inner Layout Card: Back to a clean grid but mapping all 3 items uniquely */
.clinical-container {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas: 
    "headings graphic"
    "desc     graphic";
  gap: 20px 60px; 
  align-items: center;
  border-radius: 32px;     
  padding-top: 80px;      
  padding-bottom: 80px;   
  padding-left: 70px;      
  padding-right: 70px;     
  box-sizing: border-box;
}

/* Assigning positions for desktop */
.clinical-headings-block {
  grid-area: headings;
  align-self: end;
}

.clinical-graphic-col {
  grid-area: graphic;
  width: 100%;
}

.clinical-description-block {
  grid-area: desc;
  align-self: start;
}

.clinical-subheading {
  font-size: 18px;
  font-weight: 600;
  color: #222222;
  margin-bottom: 12px;
  display: block;
  margin-top: -20px;
}
.clinical-heading {
  font-size: 54px;             
  line-height: 1.15;
  font-weight: 700;
  margin: 0;
  font-family: serif; 
}
.clinical-heading span {
  display: block;
}
.clinical-heading .pink-text {
  color: #E04B77; 
}
.clinical-heading .black-text {
  color: #1A1A1A;
}
.clinical-description {
  font-size: 16px;
  line-height: 1.6;
  color: #4A4A4A;
  max-width: 480px;
  margin: 0;
}

.chart-card-box {
  background: transparent;  
  border-radius: 0px;       
  padding: 0px;             
  box-shadow: none;         
  width: 100%;
  overflow: hidden;
}
.chart-card-box img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;      
}
.chart-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ffffff;
  color: #999;
  border-radius: 16px;
  font-size: 14px;
  width: 100%;
  min-height: 320px; /* Big vertical sizing on desktop */
  padding: 20px;
  box-sizing: border-box;
}

/* Tablet Layout Scaling Adjustments */
@media (max-width: 991px) {
  .clinical-container {
    padding: 60px 40px;
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    gap: 30px;
  }
}

/* Mobile Layout Core Spacing Rules */
@media (max-width: 768px) {
  .clinical-section-wrapper {
    padding-top: 0px !important;      
    padding-bottom: 15px !important;  
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .clinical-container {
    grid-template-columns: 1fr;
    /* This completely re-arranges the order on mobile screens */
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    padding-top: 40px;       
    padding-bottom: 40px;    
    padding-left: 24px;
    padding-right: 24px;
    border-radius: 24px;
    gap: 24px;               
  }
  
  .clinical-heading {
    font-size: 36px;         
  }
  
  .chart-placeholder {
    min-height: 240px; /* Makes it a clean size for mobile */
  }
}
</style>
