{% schema %}
{
  "name": "Clinical Proven Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EAE5F4"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Clinically Proven"
    },
    {
      "type": "text",
      "id": "heading_pink",
      "label": "Heading Pink Text",
      "default": "Better Absorption"
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading Black Text",
      "default": "Than Tablets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "A comparative study found that vitamin D gummies achieved double nutrient absorption levels than standard vitamin D tablets."
    },
    {
      "type": "image_picker",
      "id": "chart_image",
      "label": "Upload Chart Graphic"
    }
  ],
  "presets": [
    {
      "name": "Clinical Proven Section"
    }
  ]
}
{% endschema %}

<div class="clinical-section-wrapper">
  <div class="clinical-container" style="background-color: {{ section.settings.bg_color }};">
    
    <!-- Group 1: The Main Headings Block -->
    <div class="clinical-headings-block">
      <span class="clinical-subheading">{{ section.settings.sub_heading }}</span>
      <h2 class="clinical-heading">
        <span class="pink-text">{{ section.settings.heading_pink }}</span>
        <span class="black-text">{{ section.settings.heading_black }}</span>
      </h2>
    </div>
    
    <!-- Group 2: The Description Paragraph Block -->
    <div class="clinical-description-block">
      <p class="clinical-description">{{ section.settings.description }}</p>
    </div>
    
    <!-- Group 3: Chart Image Graphic Block -->
    <div class="clinical-graphic-col">
      <div class="chart-card-box">
        {% if section.settings.chart_image != blank %}
          <img src="{{ section.settings.chart_image | image_url: width: 1000 }}" alt="Absorption Chart Graphic" loading="lazy">
        {% else %}
          <div class="chart-placeholder">Upload your graph image in Theme Settings</div>
        {% endif %}
      </div>
    </div>

  </div>
</div>

<style>
/* Outer Wrapper Structural Layout styles */
.clinical-section-wrapper {
  width: 100%;
  padding-top: 15px;         
  padding-bottom: 40px;     
  padding-left: 24px;       
  padding-right: 24px;     
  box-sizing: border-box;
}

/* Inner Layout Card: Grid setup for Desktop view */
.clinical-container {
  max-width: 1340px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas: 
    "headings graphic"
    "desc     graphic";
  gap: 30px 50px; 
  align-items: center;
  border-radius: 32px;     
  padding-top: 100px;      /* Slightly reduced desktop padding */
  padding-bottom: 100px;   
  padding-left: 60px;       
  padding-right: 60px;     
  box-sizing: border-box;
}

/* Mapping layout elements to desktop grid template coordinates */
.clinical-headings-block {
  grid-area: headings;
  display: flex;
  flex-direction: column;
  align-self: end; 
}

.clinical-description-block {
  grid-area: desc;
  display: flex;
  flex-direction: column;
  align-self: start; 
}

.clinical-graphic-col {
  grid-area: graphic;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
}

.clinical-subheading {
  font-size: 18px;
  font-weight: 600;
  color: #222222;
  margin-bottom: 15px;
}
.clinical-heading {
  font-size: 56px;
  line-height: 1.1;
  font-weight: 700;
  margin: 0;
  font-family: serif; 
}
.clinical-heading span {
  display: block;
}
.clinical-heading .pink-text {
  color: #E04B77; 
}
.clinical-heading .black-text {
  color: #1A1A1A;
}
.clinical-description {
  font-size: 16px;
  line-height: 1.6;
  color: #4A4A4A;
  max-width: 450px;
  margin: 0;
}

/* Chart Container: White card styles removed so image matches your reference layout */
.chart-card-box {
  background: transparent;  /* Removed white card background */
  border-radius: 0px;       
  padding: 0px;             /* Removed padding so image spans full width */
  box-shadow: none;         /* Removed dropshadow box outline */
  width: 100%;
  max-width: 550px;
  overflow: hidden;
}
.chart-card-box img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;      /* Smoothly rounds the chart image corners directly */
}
.chart-placeholder {
  padding: 80px 20px;
  text-align: center;
  background: #ffffff;
  color: #999;
  border-radius: 12px;
  font-size: 14px;
  width: 100%;
}

/* Tablet Scaling Adjustments */
@media (max-width: 991px) {
  .clinical-container {
    padding-top: 80px;
    padding-bottom: 80px;
    padding-left: 30px;
    padding-right: 30px;
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    gap: 25px;
  }
  .clinical-headings-block, 
  .clinical-description-block {
    align-self: center;
  }
}

/* Mobile Core Layout Fixes */
@media (max-width: 768px) {
  .clinical-section-wrapper {
    padding-top: 0px !important;      
    padding-bottom: 15px !important;  
    padding-left: 15px;
    padding-right: 15px;
  }
  
  /* Drastically reduced padding to prevent the section from looking overly tall/big */
  .clinical-container {
    padding-top: 35px;       
    padding-bottom: 35px;    
    padding-left: 20px;
    padding-right: 20px;
    border-radius: 24px;
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    gap: 20px;               /* Tightened gaps between elements */
  }
  
  .clinical-heading {
    font-size: 34px;         /* Slightly smaller heading to match mobile ratio */
  }
  
  .chart-card-box {
    max-width: 100%;         /* Forces image layout wrapper to stretch full-width */
  }
}
</style>
