<style>
/* Outer Wrapper Structural Layout styles */
.clinical-section-wrapper {
  width: 100%;
  padding-top: 15px;         
  padding-bottom: 40px;     
  padding-left: 24px;       
  padding-right: 24px;     
  box-sizing: border-box;
}

/* Inner Layout Card - EXPANDED FOR WIDER DESKTOP VIEW */
.clinical-container {
  max-width: 1600px;           /* Increased from 1400px to stretch wider */
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas: 
    "headings graphic"
    "desc     graphic";
  gap: 20px 60px; 
  align-items: center;
  border-radius: 32px;     
  padding-top: 80px;      
  padding-bottom: 80px;   
  padding-left: 40px;          /* Decreased from 70px to stop crushing content inward */
  padding-right: 40px;         /* Decreased from 70px to stop crushing content inward */
  box-sizing: border-box;
}

/* Assigning positions for desktop */
.clinical-headings-block {
  grid-area: headings;
  align-self: end;
  margin-top: -55px; 
}

.clinical-graphic-col {
  grid-area: graphic;
  width: 100%;
}

.clinical-description-block {
  grid-area: desc;
  align-self: start;
}

.clinical-subheading {
  font-size: 18px;
  font-weight: 600;
  color: #222222;
  margin-bottom: 12px;
  display: block;
}

.clinical-heading {
  font-size: 54px;             
  line-height: 1.15;
  font-weight: 700;
  margin: 0;
  font-family: serif; 
}

.clinical-heading span {
  display: block;
}

.clinical-heading .pink-text {
  color: #E04B77; 
}

.clinical-heading .black-text {
  color: #1A1A1A;
}

.clinical-description {
  font-size: 16px;
  line-height: 1.6;
  color: #4A4A4A;
  max-width: 480px;
  margin: 0;
}

.chart-card-box {
  background: transparent;  
  border-radius: 0px;       
  padding: 0px;             
  box-shadow: none;         
  width: 100%;
  overflow: hidden;
}

.chart-card-box img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;      
}

.chart-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ffffff;
  color: #999;
  border-radius: 16px;
  font-size: 14px;
  width: 100%;
  min-height: 320px; 
  padding: 20px;
  box-sizing: border-box;
}

/* Tablet Layout Scaling Adjustments */
@media (max-width: 991px) {
  .clinical-container {
    padding: 60px 40px;
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    gap: 30px;
  }
}

/* Mobile Layout Spacing and Alignment Fixes */
@media (max-width: 768px) {
  .clinical-section-wrapper {
    padding-top: 0px !important;      
    padding-bottom: 15px !important;  
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .clinical-container {
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    padding-top: 40px;       
    padding-bottom: 40px;    
    padding-left: 20px;       
    padding-right: 20px;      
    border-radius: 24px;
    gap: 24px;               
  }
  
  .clinical-headings-block {
    margin-top: 0px !important; 
  }
  
  .clinical-heading {
    font-size: 36px;         
  }
  
  .chart-placeholder {
    min-height: 240px; 
  }
}
</style>
