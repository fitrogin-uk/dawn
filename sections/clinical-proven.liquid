{% schema %}
{
  "name": "Clinical Proven Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EAE5F4"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Clinically Proven"
    },
    {
      "type": "text",
      "id": "heading_pink",
      "label": "Heading Pink Text",
      "default": "Better Absorption"
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading Black Text",
      "default": "Than Tablets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "A comparative study found that vitamin D gummies achieved double nutrient absorption levels than standard vitamin D tablets."
    },
    {
      "type": "image_picker",
      "id": "chart_image",
      "label": "Upload Chart Graphic"
    },
    {
      "type": "text",
      "id": "reference_text",
      "label": "Reference Citation Text",
      "default": "Reference: https://mdpi.com"
    }
  ],
  "presets": [
    {
      "name": "Clinical Proven Section"
    }
  ]
}
{% endschema %}

<div class="clinical-section-wrapper">
  <div class="clinical-container" style="background-color: {{ section.settings.bg_color }};">
    
    <!-- Element 1: Headings -->
    <div class="clinical-headings-block">
      <span class="clinical-subheading">{{ section.settings.sub_heading }}</span>
      <h2 class="clinical-heading">
        <span class="pink-text">{{ section.settings.heading_pink }}</span>
        <span class="black-text">{{ section.settings.heading_black }}</span>
      </h2>
    </div>
    
    <!-- Element 2: Graphic/Image -->
    <div class="clinical-graphic-col">
      <div class="chart-card-box">
        {% if section.settings.chart_image != blank %}
          <img src="{{ section.settings.chart_image | image_url: width: 1200 }}" alt="Absorption Chart Graphic" loading="lazy">
        {% else %}
          <div class="chart-placeholder">Upload your graph image in Theme Settings</div>
        {% endif %}
        
        {% if section.settings.reference_text != blank %}
          <p class="clinical-reference-link">{{ section.settings.reference_text }}</p>
        {% endif %}
      </div>
    </div>

    <!-- Element 3: Description -->
    <div class="clinical-description-block">
      <p class="clinical-description">
        <!-- Explicit bold style treatment matching sample image structure -->
        <strong>A comparative study found that vitamin D gummies achieved double nutrient absorption levels than standard vitamin D tablets.</strong>
      </p>
    </div>

  </div>
</div>

<style>
/* Outer Wrapper Structural Layout styles */
.clinical-section-wrapper {
  width: 100%;
  padding-top: 15px;         
  padding-bottom: 40px;     
  padding-left: 15px;          /* Minimal outer padding to stretch wide */
  padding-right: 15px;     
  box-sizing: border-box;
}

/* Inner Layout Card - EXTANDED STRUCTURAL SIZE AND COMPACT SIDE CLEARANCE */
.clinical-container {
  max-width: 1760px;           /* Stretches near edge-to-edge on desktop monitors */
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas: 
    "headings graphic"
    "desc     graphic";
  gap: 20px 60px; 
  align-items: center;
  border-radius: 32px;     
  padding-top: 100px;      
  padding-bottom: 100px;   
  padding-left: 45px;          /* Drastically reduced from 70px to stop content squeeze */
  padding-right: 45px;         /* Drastically reduced from 70px to stop content squeeze */
  box-sizing: border-box;
}

/* Assigning positions for desktop layout */
.clinical-headings-block {
  grid-area: headings;
  align-self: end;
  margin-top: -35px; 
}

.clinical-graphic-col {
  grid-area: graphic;
  width: 100%;
}

.clinical-description-block {
  grid-area: desc;
  align-self: start;
}

.clinical-subheading {
  font-size: 19px;
  font-weight: 600;
  color: #222222;
  margin-bottom: 12px;
  display: block;
}

.clinical-heading {
  font-size: 80px;             /* INCREASED: Bold editorial type scales up */
  line-height: 1.05;
  font-weight: 800;            /* INCREASED: Heavier bold value */
  margin: 0;
  font-family: serif; 
  letter-spacing: -0.01em;
}

.clinical-heading span {
  display: block;
}

.clinical-heading .pink-text {
  color: #E04B77; 
}

.clinical-heading .black-text {
  color: #1A1A1A;
}

.clinical-description {
  font-size: 19px;             /* INCREASED: Expanded paragraph visibility scale */
  line-height: 1.5;
  color: #1A1A1A;              /* Darkened for cleaner visual punch */
  max-width: 530px;
  margin: 0;
}

.chart-card-box {
  background: transparent;  
  border-radius: 0px;       
  padding: 0px;             
  box-shadow: none;         
  width: 100%;
  overflow: hidden;
}

.chart-card-box img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;      
}

.chart-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ffffff;
  color: #999;
  border-radius: 16px;
  font-size: 14px;
  width: 100%;
  min-height: 420px;           /* Large, clean height proportion window */
  padding: 20px;
  box-sizing: border-box;
}

.clinical-reference-link {
  font-size: 11px;
  color: #777777;
  margin-top: 12px;
  margin-bottom: 0px;
  letter-spacing: 0.02em;
}

/* Tablet Layout Scaling Adjustments */
@media (max-width: 991px) {
  .clinical-container {
    padding: 60px 40px;
    grid-template-columns: 1fr;
    grid-template-areas: 
      "headings"
      "graphic"
      "desc";
    gap: 30px;
  }
}

/* Mobile Layout: LOCKED SEQUENCE RE-ALIGNMENT */
@media (max-width: 768px) {
  .clinical-section-wrapper {
    padding-top: 0px !important;      
    padding-bottom: 15px !important;  
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .clinical-container {
    grid-template-columns: 1fr;
    /* LOCKED ORDER: Graph image is hard-pinned between title and description blocks */
    grid-template-areas: 
      "headings"
      "graphic"
      "desc" !important;
    padding-top: 40px;       
    padding-bottom: 40px;    
    padding-left: 20px;       
    padding-right: 20px;      
    border-radius: 24px;
    gap: 24px;               
  }
  
  /* Reset desktop alignment overrides on phone screens */
  .clinical-headings-block {
    margin-top: 0px !important; 
  }
  
  .clinical-heading {
    font-size: 36px;         
    font-weight: 700;
  }
  
  .chart-placeholder {
    min-height: 240px; 
  }
  
  .clinical-reference-link {
    text-align: center;
  }
}
</style>
