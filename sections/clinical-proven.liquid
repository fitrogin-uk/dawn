{% schema %}
{
  "name": "Clinical Proven Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EAE5F4"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Clinically Proven"
    },
    {
      "type": "text",
      "id": "heading_pink",
      "label": "Heading Pink Text",
      "default": "Better Absorption"
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading Black Text",
      "default": "Than Tablets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "A comparative study found that vitamin D gummies achieved double nutrient absorption levels than standard vitamin D tablets."
    },
    {
      "type": "image_picker",
      "id": "chart_image",
      "label": "Upload Chart Graphic"
    },
    {
      "type": "text",
      "id": "reference_text",
      "label": "Reference Citation Text",
      "default": "Reference: https://mdpi.com"
    }
  ],
  "presets": [
    {
      "name": "Clinical Proven Section"
    }
  ]
}
{% endschema %}

<div class="clinical-section-wrapper">
  <div class="clinical-container" style="background-color: {{ section.settings.bg_color }};">
    
    <!-- Left Column: Unified Text Container matching sample spacing layout -->
    <div class="clinical-text-column">
      <div class="clinical-headings-block">
        <span class="clinical-subheading">{{ section.settings.sub_heading }}</span>
        <h2 class="clinical-heading">
          <span class="pink-text">{{ section.settings.heading_pink }}</span>
          <span class="black-text">{{ section.settings.heading_black }}</span>
        </h2>
      </div>
      <div class="clinical-description-block">
        <p class="clinical-description">{{ section.settings.description }}</p>
      </div>
    </div>
    
    <!-- Right Column: Expansive Graphic Layout matching sample proportions -->
    <div class="clinical-graphic-column">
      <div class="chart-card-box">
        {% if section.settings.chart_image != blank %}
          <img src="{{ section.settings.chart_image | image_url: width: 1200 }}" alt="Absorption Chart Graphic" loading="lazy">
        {% else %}
          <div class="chart-placeholder">Upload your graph image in Theme Settings</div>
        {% endif %}
        
        <!-- NEW FEATURE: Small reference text snippet exactly like sample image -->
        {% if section.settings.reference_text != blank %}
          <p class="clinical-reference-link">{{ section.settings.reference_text }}</p>
        {% endif %}
      </div>
    </div>

  </div>
</div>

<style>
/* Outer Section Frame Wrapper */
.clinical-section-wrapper {
  width: 100%;
  padding-top: 15px;         
  padding-bottom: 40px;     
  padding-left: 24px;       
  padding-right: 24px;     
  box-sizing: border-box;
}

/* Inner Layout Container */
.clinical-container {
  max-width: 1440px;           
  margin: 0 auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 80px;                   
  border-radius: 32px;     
  padding-top: 75px;           
  padding-bottom: 75px;   
  padding-left: 65px;          
  padding-right: 65px;     
  box-sizing: border-box;
}

/* Left Column Sizing & Element Placement Logic */
.clinical-text-column {
  flex: 1.1;                   
  max-width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 40px;                   
}

/* Right Column Graphic Container Logic */
.clinical-graphic-column {
  flex: 0.9;                   
  max-width: 50%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  width: 100%;
}

.clinical-subheading {
  font-size: 20px;             
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24px;         
  display: block;
}

.clinical-heading {
  font-size: 64px;             
  line-height: 1.05;
  font-weight: 700;
  margin: 0;
  font-family: serif; 
  letter-spacing: -0.02em;
}

.clinical-heading span {
  display: block;
}

.clinical-heading .pink-text {
  color: #E04B77; 
}

.clinical-heading .black-text {
  color: #1A1A1A;
}

.clinical-description {
  font-size: 18px;             
  line-height: 1.5;
  color: #333333;
  max-width: 490px;            
  margin: 0;
}

/* Graphic Container & Image Area Balancing */
.chart-card-box {
  background: transparent;  
  border-radius: 0px;       
  padding: 0px;             
  box-shadow: none;         
  width: 100%;
  max-width: 560px;            
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.chart-card-box img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 20px;         
}

.chart-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ffffff;
  color: #999;
  border-radius: 20px;
  font-size: 15px;
  width: 100%;
  min-height: 380px;           
  padding: 20px;
  box-sizing: border-box;
}

/* STYLE FOR CITATION REFERENCE: Small gray text directly below graph box on desktop */
.clinical-reference-link {
  font-size: 11px;
  color: #777777;
  margin-top: 12px;
  margin-bottom: 0px;
  font-family: inherit;
  letter-spacing: 0.02em;
  line-height: 1.2;
}

/* Tablet Device Scaling Adjustments */
@media (max-width: 1199px) {
  .clinical-container {
    padding: 50px 40px;
    gap: 40px;
  }
  .clinical-heading {
    font-size: 48px;
  }
}

@media (max-width: 991px) {
  .clinical-container {
    flex-direction: column;
    align-items: flex-start;
    gap: 30px;
  }
  .clinical-text-column,
  .clinical-graphic-column {
    max-width: 100%;
    flex: none;
  }
  .clinical-graphic-column {
    justify-content: center;
  }
}

/* Mobile Layout Configuration */
@media (max-width: 768px) {
  .clinical-section-wrapper {
    padding-top: 0px !important;      
    padding-bottom: 15px !important;  
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .clinical-container {
    display: flex;
    flex-direction: column;
    padding-top: 40px;       
    padding-bottom: 40px;    
    padding-left: 20px;       
    padding-right: 20px;      
    border-radius: 24px;
    gap: 24px;               
  }
  
  .clinical-text-column {
    max-width: 100%;
    flex: none;
    gap: 24px;
  }
  
  .clinical-graphic-column {
    max-width: 100%;
    flex: none;
    order: 2;                  
  }
  
  .clinical-headings-block { order: 1; }
  .clinical-description-block { order: 3; }
  
  .clinical-heading {
    font-size: 36px;         
  }
  
  .clinical-description {
    font-size: 16px;
  }
  
  .chart-placeholder {
    min-height: 240px; 
  }
  
  /* Centers reference text nicely under the graphic box when viewed on phones */
  .clinical-reference-link {
    text-align: center;
    margin-top: 10px;
  }
}
</style>
