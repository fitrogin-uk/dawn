{%- comment -%} Instagram Feed — manual image grid with optional link overlay {%- endcomment -%}

<section class="ig-feed-{{ section.id }} ig-feed">
  <div class="ig-feed__header">
    <h2 class="ig-feed__title">{{ section.settings.title | default: 'Instagram @novomins' }}</h2>
    <div class="ig-feed__divider" aria-hidden="true"></div>
    {%- if section.settings.instagram_url != blank -%}
      <a
        href="{{ section.settings.instagram_url }}"
        class="ig-feed__follow-btn"
        target="_blank"
        rel="noopener"
        aria-label="Follow us on Instagram"
      >
        <svg class="ig-feed__follow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
        </svg>
        {{ section.settings.button_label | default: 'Follow Us' }}
        <svg class="ig-feed__arrow" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
          <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>

  <div class="ig-feed__grid">
    {%- for block in section.blocks -%}
      <div class="ig-feed__item{% if block.settings.image == blank %} ig-feed__item--placeholder{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}

          {%- if block.settings.post_url != blank -%}
            <a href="{{ block.settings.post_url }}" target="_blank" rel="noopener" class="ig-feed__link" aria-label="View on Instagram">
          {%- endif -%}

          {{
            block.settings.image
            | image_url: width: 600
            | image_tag:
              class: 'ig-feed__img',
              loading: 'lazy',
              widths: '300, 400, 600',
              sizes: '(max-width: 640px) calc(33vw - 8px), (max-width: 1024px) calc(16.66vw - 8px), 200px',
              alt: block.settings.alt_text | default: 'Instagram post'
          }}

          <div class="ig-feed__overlay" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="28" height="28">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1.2" fill="#fff" stroke="none"/>
            </svg>
          </div>

          {%- if block.settings.post_url != blank -%}
            </a>
          {%- endif -%}

        {%- else -%}

          <div class="ig-feed__placeholder" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" width="32" height="32">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1.2" fill="#ccc" stroke="none"/>
            </svg>
          </div>

        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .ig-feed-{{ section.id }} {
    display: block !important;
    width: 100% !important;
    box-sizing: border-box !important;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: {{ section.settings.section_padding_top | default: 48 }}px 0 {{ section.settings.section_padding_bottom | default: 48 }}px;
  }

  /* ── Header ─────────────────────────────────────────── */
  .ig-feed-{{ section.id }} .ig-feed__header {
    display: grid !important;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0;
    width: 100% !important;
    box-sizing: border-box;
    padding: 0 max(20px, 5vw) 24px;
  }

  .ig-feed-{{ section.id }} .ig-feed__title {
    font-size: clamp(18px, 2.5vw, 26px);
    font-weight: 700;
    margin: 0;
    color: {{ section.settings.title_color | default: '#111111' }};
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .ig-feed-{{ section.id }} .ig-feed__divider {
    display: block !important;
    height: 2px;
    background-color: {{ section.settings.divider_color | default: '#111111' }};
    margin: 0 28px;
    min-width: 0;
    width: auto;
  }

  .ig-feed-{{ section.id }} .ig-feed__follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 50px;
    background: {{ section.settings.button_bg | default: '#111111' }};
    color: {{ section.settings.button_text_color | default: '#ffffff' }};
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.15s ease;
    justify-self: end;
  }
  .ig-feed-{{ section.id }} .ig-feed__follow-btn:hover {
    background: {{ section.settings.button_hover_bg | default: '#333333' }};
    transform: scale(1.03);
  }

  /* ── Grid ────────────────────────────────────────────── */
  .ig-feed__grid {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 0 max(20px, 5vw);
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 6 }}, 1fr);
    gap: {{ section.settings.gap | default: 8 }}px;
  }

  /* ── Individual tile ─────────────────────────────────── */
  .ig-feed__item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | default: 12 }}px;
    aspect-ratio: 1 / 1;
    background: #f0f0f0;
  }

  .ig-feed__item--placeholder {
    background: #ebebeb;
  }

  .ig-feed__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ig-feed__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ig-feed__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .ig-feed__item:hover .ig-feed__img {
    transform: scale(1.05);
  }

  /* ── Hover overlay ───────────────────────────────────── */
  .ig-feed__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .ig-feed__item:hover .ig-feed__overlay { opacity: 1; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 1024px) {
    .ig-feed__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 4 }}, 1fr);
    }
  }
  @media (max-width: 640px) {
    .ig-feed__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile | default: 3 }}, 1fr);
      gap: 4px;
    }
    .ig-feed__item { border-radius: 8px; }
  }
</style>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Instagram @novomins"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Follow Us"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns — desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns — tablet",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns — mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image corner radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider line colour",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading colour",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "post_url",
          "label": "Post URL (optional)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Instagram post"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}