{%- style -%}
  .header {
    padding: 6px 0rem;
    overflow: hidden;
  }

  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header.page-width {
      padding-left: 5.5rem !important;
      padding-right: 3rem !important;
    }
    .header {
      padding: 0 1.5rem;
      overflow: hidden;
      min-height: unset;
      height: 55px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      position: relative;
    }
    .header__heading-link {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    .header__heading-logo-wrapper {
      display: flex;
      align-items: center;
    }
    .header__heading-logo-wrapper img {
      max-height: 42px;
      width: auto;
    }
    .header__icon {
      width: 36px;
      height: 36px;
      min-width: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border-radius: 50%;
      background-color: #e8e8e8;
      box-sizing: border-box;
      margin: 0 3px;
    }
    .header__icon:hover {
      background-color: #d8d8d8;
    }
    .header__icons {
      display: flex;
      align-items: center;
      gap: 0;
      margin-left: auto;
    }
    .header__menu-item,
    .header__inline-menu {
      display: flex;
      align-items: center;
    }
    .header__menu-item span,
    .list-menu__item--link,
    .header__inline-menu .list-menu__item--link {
      font-size: 20px;
      line-height: 1;
      padding-top: 0;
      padding-bottom: 0;
      display: flex;
      align-items: center;
    }
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}
{%- endstyle -%}